Make TextureSamplerDescriptor::Empty honour its documented contract when either side of the
descriptor is null. Random-texture lookup deliberately returns a default descriptor when no
texture files are available; dereferencing that descriptor caused an uncatchable SIGSEGV while
loading/rendering otherwise-valid Milkdrop presets. Applied by scripts/build-projectm.sh.

--- a/src/libprojectM/Renderer/TextureSamplerDescriptor.cpp
+++ b/src/libprojectM/Renderer/TextureSamplerDescriptor.cpp
@@ -20,7 +20,7 @@
 
 auto TextureSamplerDescriptor::Empty() const -> bool
 {
-    return m_texture->Empty();
+    return !m_texture || !m_sampler || m_texture->Empty();
 }
 
 void TextureSamplerDescriptor::Bind(GLint unit, const Shader& shader) const
