<Project Sdk="Microsoft.NET.Sdk">

    <!-- Phase 3 gate: VideoPlayer salvage end-to-end. Opens a video via the registry (FFmpeg), schedules
         it against a free-running MediaClock, and counts presented frames headlessly (DiscardingVideoOutput
         + the FramePresentationTimePresented event). Proves decode -> sync -> present through VideoPlayer. -->

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <IsAotCompatible>false</IsAotCompatible>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="../../Media/S.Media.Players/S.Media.Players.csproj" />
        <ProjectReference Include="../../Media/S.Media.Decode.FFmpeg/S.Media.Decode.FFmpeg.csproj" />
    </ItemGroup>

</Project>
