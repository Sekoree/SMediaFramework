<Project Sdk="Microsoft.NET.Sdk">

    <!-- Phase 2 video-decode validation: opens a file's video track via the registry and pulls frames
         (no display; on-screen video is Phase 3). Pass the media path as the first argument (optionally a
         max-frame count). Needs native FFmpeg present at runtime. -->

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <IsAotCompatible>false</IsAotCompatible>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="../../Media/S.Media.Players/S.Media.Players.csproj" />
        <ProjectReference Include="../../Media/S.Media.Decode.FFmpeg/S.Media.Decode.FFmpeg.csproj" />
    </ItemGroup>

</Project>
