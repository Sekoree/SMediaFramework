<Project Sdk="Microsoft.NET.Sdk">

    <!-- S.Media.Core - primitives + contracts + media registry. NO backend deps (arch-test enforced).
         Common build settings come from Directory.Build.props; versions from
         Directory.Packages.props. -->

    <ItemGroup>
        <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    </ItemGroup>

    <!-- The old single-assembly Core was split into Core/Time/Routing/Players (D1). Salvaged code in
         those assemblies keeps the internal access it had when everything lived in one assembly. -->
    <ItemGroup>
        <InternalsVisibleTo Include="S.Media.Time" />
        <InternalsVisibleTo Include="S.Media.Routing" />
        <InternalsVisibleTo Include="S.Media.Players" />
        <InternalsVisibleTo Include="S.Media.Core.Tests" />
    </ItemGroup>

</Project>
