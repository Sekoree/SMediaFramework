<Project Sdk="Microsoft.NET.Sdk">

    <!-- S.Media.Source.MMD: managed PMX/VMD parsing and playback with BDEF/SDEF/QDEF skinning,
         morphs, CCD IK, secondary physics, VMD scene tracks, and an MMD material/shadow GL surface.
         The software rasterizer remains the CPU fallback. Reference implementations consulted under
         Reference/MMDTest (behavioral reference only). -->

    <ItemGroup>
        <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
        <Compile Include="../../Shared/SystemFirstNativeLibraryResolver.cs" Link="Runtime/SystemFirstNativeLibraryResolver.cs" />
        <!-- System.Text.Encoding.CodePages (Shift-JIS / cp932 for VMD bone names) is NOT referenced as a
             package: its assembly ships in the .NET 10 shared framework + NativeAOT runtime pack, so the
             explicit PackageReference was redundant (SDK NU1510). CodePagesEncodingProvider resolves from
             the framework. -->
        <!-- GL layer-surface renderer (NXT-10 consumer): bindings + image decode are pure managed;
             a GL context only ever comes from the hosting compositor, so the module still carries no
             native runtime of its own. -->
        <PackageReference Include="Silk.NET.OpenGL" />
        <PackageReference Include="StbImageSharp" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="../S.Media.Core/S.Media.Core.csproj" />
        <ProjectReference Include="../S.Media.Time/S.Media.Time.csproj" />
        <ProjectReference Include="../S.Media.Compositor/S.Media.Compositor.csproj" />
    </ItemGroup>

    <ItemGroup>
        <InternalsVisibleTo Include="S.Media.Source.MMD.Tests" />
    </ItemGroup>

    <!-- Native MMD physics: real Bullet 3.25 via the mmd_bullet C shim (MediaFramework/Native/mmd_bullet).
         Stage the built shared library next to every consumer's binary so the P/Invoke resolver finds it:
         libmmd_bullet.so on Linux, mmd_bullet.dll on Windows (build.sh emits the platform-default name).
         CI builds the shim first (build.sh); locally, run MediaFramework/Native/mmd_bullet/build.sh once. -->
    <ItemGroup>
        <None Include="$(MSBuildThisFileDirectory)../../Native/mmd_bullet/libmmd_bullet.so"
              Condition="Exists('$(MSBuildThisFileDirectory)../../Native/mmd_bullet/libmmd_bullet.so')">
            <Link>libmmd_bullet.so</Link>
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </None>
        <None Include="$(MSBuildThisFileDirectory)../../Native/mmd_bullet/mmd_bullet.dll"
              Condition="Exists('$(MSBuildThisFileDirectory)../../Native/mmd_bullet/mmd_bullet.dll')">
            <Link>mmd_bullet.dll</Link>
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </None>
    </ItemGroup>

    <ItemGroup>
        <Using Include="S.Media.Core" />
        <Using Include="S.Media.Core.Video" />
        <Using Include="S.Media.Core.Registry" />
        <Using Include="System.Numerics" />
    </ItemGroup>


    <PropertyGroup>
        <Description>MikuMikuDance (PMX/VMD) scene source for MFPlayer with Bullet-physics-backed animation. Requires the mmd_bullet native shim built by this repo.</Description>
    </PropertyGroup>
</Project>
