        <ProjectReference Include="../S.Media.Routing/S.Media.Routing.csproj" />
        <ProjectReference Include="../../NDI/NDILib/NDILib.csproj" />
    </ItemGroup>

    <ItemGroup>
        <InternalsVisibleTo Include="S.Media.NDI.Tests" />
        <InternalsVisibleTo Include="HaPlay.Tests" />
    </ItemGroup>

</Project>
