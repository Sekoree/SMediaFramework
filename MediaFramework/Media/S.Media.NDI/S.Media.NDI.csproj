<Project Sdk="Microsoft.NET.Sdk">

    <!-- S.Media.NDI - NDI sender + receiver, registered into the media registry via NDIModule (no static
         MediaFrameworkRuntime hook, P2). Receiver opens 'ndi:' URIs as IVideoSource/IAudioSource; the
         NDI runtime is acquired by the module. The native libndi is host-supplied (NDILibraryResolver). -->

    <ItemGroup>
        <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="../S.Media.Core/S.Media.Core.csproj" />
        <ProjectReference Include="../S.Media.Time/S.Media.Time.csproj" />
        <ProjectReference Include="../S.Media.Routing/S.Media.Routing.csproj" />
        <ProjectReference Include="../../NDI/NDILib/NDILib.csproj" />
    </ItemGroup>

    <ItemGroup>
        <InternalsVisibleTo Include="S.Media.NDI.Tests" />
        <InternalsVisibleTo Include="HaPlay.Tests" />
    </ItemGroup>


    <PropertyGroup>
        <Description>NDI send/receive for MFPlayer: sources, outputs, audio receivers and fusion pacing hints. Requires the proprietary NDI v6 runtime installed on the host.</Description>
    </PropertyGroup>
</Project>
