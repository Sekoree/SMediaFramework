         .CpuFrameConverterFactory (registry-wired IVideoCpuFrameConverter), never S.Media.FFmpeg. -->

    <ItemGroup>
        <ProjectReference Include="../S.Media.Core/S.Media.Core.csproj" />
        <ProjectReference Include="../S.Media.Gpu/S.Media.Gpu.csproj" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
        <PackageReference Include="Silk.NET.OpenGL" />
    </ItemGroup>

    <ItemGroup>
        <EmbeddedResource Include="OpenGL/Shaders/*.glsl" />
    </ItemGroup>

    <ItemGroup>
        <InternalsVisibleTo Include="S.Media.Compositor.Tests" />
        <InternalsVisibleTo Include="S.Media.Session" />
    </ItemGroup>

</Project>
