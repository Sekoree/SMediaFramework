<Project Sdk="Microsoft.NET.Sdk">

    <!-- S.Media.Players - single-stream playback. Phase 2 is audio-first: a registry-driven MediaPlayer
         (open URI → AudioRouter → master output → MediaClock). VideoPlayer + AvPlaybackCoordinator
         (the video-centric A/V coordinator) are salvaged in Phase 3 alongside the GPU/present tier. -->

    <ItemGroup>
        <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="../S.Media.Core/S.Media.Core.csproj" />
        <ProjectReference Include="../S.Media.Time/S.Media.Time.csproj" />
        <ProjectReference Include="../S.Media.Routing/S.Media.Routing.csproj" />
    </ItemGroup>

    <ItemGroup>
        <Using Include="S.Media.Core" />
        <Using Include="S.Media.Core.Audio" />
        <Using Include="S.Media.Core.Registry" />
        <Using Include="S.Media.Core.Diagnostics" />
        <Using Include="S.Media.Time" />
        <Using Include="S.Media.Routing" />
    </ItemGroup>

    <ItemGroup>
        <InternalsVisibleTo Include="S.Media.Players.Tests" />
    </ItemGroup>

</Project>
