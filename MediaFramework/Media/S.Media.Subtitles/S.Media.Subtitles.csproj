<Project Sdk="Microsoft.NET.Sdk">

    <!-- S.Media.Subtitles - subtitle overlay layer source ([Core] + LibAssLib). Subtitles render through libass:
         sidecar ASS/SSA directly, and every other format (SRT/VTT/MicroDVD/SAMI/…) + in-container streams via
         FFmpeg-decoded ASS events (the FFmpeg path lives in the host). Output is Bgra32-premultiplied overlay
         frames aligned to the master clock; bitmap (PGS/DVB via Decode.FFmpeg) lands later in the phase. -->

    <ItemGroup>
        <ProjectReference Include="../S.Media.Core/S.Media.Core.csproj" />
        <ProjectReference Include="../../Subtitles/LibAssLib/LibAssLib.csproj" />
    </ItemGroup>


    <PropertyGroup>
        <Description>libass subtitle rendering for MFPlayer (ASS/SSA and converted text subtitles). Requires libass 0.17.5+ at runtime.</Description>
    </PropertyGroup>
</Project>
