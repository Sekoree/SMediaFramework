<Project Sdk="Microsoft.NET.Sdk">

    <!-- S.Media.Routing - N->M audio matrix + video fan-out (backend-neutral). Salvaged AudioRouter/
         VideoRouter/pumps/router-clocks. Common build settings from Directory.Build.props. -->

    <ItemGroup>
        <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="../S.Media.Core/S.Media.Core.csproj" />
        <ProjectReference Include="../S.Media.Time/S.Media.Time.csproj" />
    </ItemGroup>

    <!-- Salvaged routing code keeps the cross-namespace access it had when Core was one assembly; these
         project-level global usings replace the per-file usings (no churn, no duplicate-using warnings). -->
    <ItemGroup>
        <Using Include="S.Media.Core" />
        <Using Include="S.Media.Core.Audio" />
        <Using Include="S.Media.Core.Video" />
        <Using Include="S.Media.Core.Diagnostics" />
        <Using Include="S.Media.Core.Threading" />
        <Using Include="S.Media.Core.Triggers" />
        <Using Include="S.Media.Time" />
    </ItemGroup>

    <ItemGroup>
        <InternalsVisibleTo Include="S.Media.Players" />
        <InternalsVisibleTo Include="S.Media.Core.Tests" />
        <InternalsVisibleTo Include="S.Media.Audio.Benchmarks" />
    </ItemGroup>


    <PropertyGroup>
        <Description>Audio routing for MFPlayer: multi-route mixing, shared device outputs, channel mapping, mix groups and backend failover.</Description>
    </PropertyGroup>
</Project>
