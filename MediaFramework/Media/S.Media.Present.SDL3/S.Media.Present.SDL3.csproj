        <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
        <PackageReference Include="SDL3-CS" />
    </ItemGroup>

    <ItemGroup>
        <InternalsVisibleTo Include="S.Media.Present.SDL3.Tests" />
    </ItemGroup>

</Project>
