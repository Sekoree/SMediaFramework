<Project Sdk="Microsoft.NET.Sdk">

    <!-- S.Media.Present.SDL3 - IVideoOutput on its own GL render thread (salvaged from S.Media.SDL3).
         Output + GL context only: [Core, Gpu]. The SDL3 GL *compositor backend* lives in the separate
         S.Media.Present.SDL3.Compositor bridge so this presenter never references S.Media.Compositor. -->

    <ItemGroup>
        <ProjectReference Include="../S.Media.Core/S.Media.Core.csproj" />
        <ProjectReference Include="../S.Media.Gpu/S.Media.Gpu.csproj" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
        <PackageReference Include="SDL3-CS" />
        <Compile Include="../../Shared/SystemFirstNativeLibraryResolver.cs" Link="Runtime/SystemFirstNativeLibraryResolver.cs" />
    </ItemGroup>

    <ItemGroup>
        <InternalsVisibleTo Include="S.Media.Present.SDL3.Tests" />
    </ItemGroup>


    <PropertyGroup>
        <Description>SDL3 window/fullscreen presentation for MFPlayer video. Requires the SDL3 native library (shipped by the SDL3-CS NuGet).</Description>
    </PropertyGroup>
</Project>
