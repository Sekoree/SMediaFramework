<Project Sdk="Microsoft.NET.Sdk">

    <!-- OSCLib - Open Sound Control over UDP: client/server, address-pattern matching, bundle/time-tag scheduling,
         packet codec. The OSC transport for S.Control (the analogue of PMLib for MIDI); framework trigger
         adaptation lives in S.Control. Pure managed; common build settings come from Directory.Build.props. -->

    <ItemGroup>
        <InternalsVisibleTo Include="OSCLib.Tests" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    </ItemGroup>


    <PropertyGroup>
        <Description>OSC (Open Sound Control) client/server library: codecs, routing, bundles and address matching. Usable standalone; also part of S.Media.Control.</Description>
    </PropertyGroup>
</Project>
