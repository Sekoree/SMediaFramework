<Project Sdk="Microsoft.NET.Sdk">

    <!-- Entry/meta package (review P2-5): dependency-only. No assembly ships (IncludeBuildOutput=false;
         NU5128 is the expected "no lib/ assets" pack warning for that) - consumers get the composed leaf
         packages. Composition mirrors Doc/Packages.md. -->
    <PropertyGroup>
        <IncludeBuildOutput>false</IncludeBuildOutput>
        <NoWarn>$(NoWarn);NU5128</NoWarn>
        <Description>Show control for MFPlayer: control surfaces, Mond scripting, command dispatch and bindings plus PortMidi MIDI and OSC integration.</Description>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="../../Control/S.Control/S.Control.csproj" />
        <ProjectReference Include="../../Control/S.Control.Abstractions/S.Control.Abstractions.csproj" />
        <ProjectReference Include="../../MIDI/PMLib/PMLib.csproj" />
        <ProjectReference Include="../../OSC/OSCLib/OSCLib.csproj" />
    </ItemGroup>
</Project>
