<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="using:HaPlay.Resources"
        xmlns:vm="using:HaPlay.ViewModels.Dialogs"
        x:Class="HaPlay.Views.Dialogs.AddYouTubeDialog"
        x:DataType="vm:AddYouTubeDialogViewModel"
        Title="{Binding DialogTitle}"
        Width="620" Height="560"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        MinWidth="520" MinHeight="480">
  <DockPanel Margin="16">
    <StackPanel DockPanel.Dock="Bottom" Spacing="8" Margin="0,16,0,0">
      <StackPanel Spacing="4" IsVisible="{Binding IsPreparing}">
        <ProgressBar Minimum="0" Maximum="1" Value="{Binding PrepareProgress}" />
        <TextBlock Opacity="0.8" FontSize="11" Text="{Binding PrepareStatus}" />
      </StackPanel>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
        <Button Content="{x:Static res:Strings.CancelButton}" Click="CancelClick" IsCancel="True" />
        <Button Content="{Binding PrimaryButtonLabel}" Command="{Binding PrepareAndAcceptCommand}"
                IsDefault="True" IsEnabled="{Binding HasManifest}" />
      </StackPanel>
    </StackPanel>

    <ScrollViewer>
      <StackPanel Spacing="10">
        <TextBlock Text="{Binding ValidationMessage}" Foreground="#C62828" TextWrapping="Wrap" />

        <TextBlock Text="{x:Static res:Strings.YouTubeUrlLabel}" FontWeight="SemiBold" />
        <Grid ColumnDefinitions="*,Auto">
          <TextBox Grid.Column="0" Text="{Binding Url}" Watermark="https://www.youtube.com/watch?v=…" />
          <Button Grid.Column="1" Margin="6,0,0,0" Content="{x:Static res:Strings.YouTubeResolveButton}"
                  Command="{Binding ResolveCommand}" IsEnabled="{Binding !IsResolving}" />
        </Grid>

        <Border Background="#15808080" CornerRadius="4" Padding="10" IsVisible="{Binding HasManifest}">
          <StackPanel Spacing="4">
            <TextBlock Text="{Binding VideoTitle}" FontWeight="SemiBold" TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" Spacing="12">
              <TextBlock Opacity="0.8" FontSize="11" Text="{Binding VideoAuthor}" />
              <TextBlock Opacity="0.8" FontSize="11" Text="{Binding VideoDurationText}" />
            </StackPanel>
          </StackPanel>
        </Border>

        <StackPanel Spacing="10" IsVisible="{Binding HasManifest}">
          <CheckBox Content="{x:Static res:Strings.YouTubeAudioOnlyCheckbox}" IsChecked="{Binding AudioOnly}" />

          <StackPanel Spacing="6" IsVisible="{Binding !AudioOnly}">
            <TextBlock Text="{x:Static res:Strings.YouTubeVideoStreamLabel}" FontWeight="SemiBold" />
            <ComboBox ItemsSource="{Binding VideoStreams}" SelectedItem="{Binding SelectedVideoStream}"
                      HorizontalAlignment="Stretch" />
          </StackPanel>

          <TextBlock Text="{x:Static res:Strings.YouTubeAudioStreamLabel}" FontWeight="SemiBold" />
          <ComboBox ItemsSource="{Binding AudioStreams}" SelectedItem="{Binding SelectedAudioStream}"
                    HorizontalAlignment="Stretch" />

          <TextBlock Text="{x:Static res:Strings.YouTubeSubtitleTrackLabel}" FontWeight="SemiBold" />
          <ComboBox ItemsSource="{Binding SubtitleTracks}" SelectedItem="{Binding SelectedSubtitleTrack}"
                    HorizontalAlignment="Stretch" />

          <TextBlock Opacity="0.75" FontSize="11" TextWrapping="Wrap" Text="{Binding CacheStatus}" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</Window>
