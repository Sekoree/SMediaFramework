<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="using:HaPlay.Resources"
        xmlns:vm="using:HaPlay.ViewModels.Dialogs"
        x:Class="HaPlay.Views.Dialogs.AddNDIInputDialog"
        x:DataType="vm:AddNDIInputDialogViewModel"
        Title="{Binding DialogTitle}"
        Width="560" Height="620"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        MinWidth="460" MinHeight="520">
  <DockPanel Margin="16">
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,16,0,0">
      <Button Content="{x:Static res:Strings.CancelButton}" Click="CancelClick" IsCancel="True" />
      <Button Content="{Binding PrimaryButtonLabel}" Click="OkClick" IsDefault="True" />
    </StackPanel>

    <ScrollViewer>
      <StackPanel Spacing="10">
        <TextBlock Text="{Binding ValidationMessage}" Foreground="#C62828" TextWrapping="Wrap" />

        <TextBlock Text="{x:Static res:Strings.DisplayNameLabel}" FontWeight="SemiBold" />
        <TextBox Text="{Binding DisplayName}" />

        <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,0">
          <ToggleButton Grid.Column="0" Content="{x:Static res:Strings.LiveDiscoveredSourcesToggle}"
                        IsChecked="{Binding UseDiscovery}"
                        HorizontalContentAlignment="Center"
                        ToolTip.Tip="{x:Static res:Strings.LiveDiscoveredSourcesTooltip}" />
          <Button Grid.Column="1" Content="{x:Static res:Strings.RescanButton}" Margin="6,0,0,0"
                  Command="{Binding RefreshCommand}"
                  IsEnabled="{Binding UseDiscovery}" />
        </Grid>

        <StackPanel Spacing="6" IsVisible="{Binding UseDiscovery}">
          <ComboBox ItemsSource="{Binding DiscoveredSources}"
                    SelectedItem="{Binding SelectedDiscoveredSource}"
                    HorizontalAlignment="Stretch" />
          <TextBlock Opacity="0.7" FontSize="11" Text="{Binding DiscoveryStatus}" TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Spacing="6" IsVisible="{Binding !UseDiscovery}">
          <TextBlock Text="{x:Static res:Strings.ManualSourceNameLabel}" FontWeight="SemiBold" />
          <TextBox Text="{Binding SourceName}" PlaceholderText="{x:Static res:Strings.ManualSourceNamePlaceholder}" />
          <TextBlock Opacity="0.7" FontSize="11" TextWrapping="Wrap"
                     Text="{x:Static res:Strings.ManualSourceNameHint}" />
        </StackPanel>

        <Border Background="#15808080" CornerRadius="4" Padding="10" Margin="0,8,0,0">
          <StackPanel Spacing="6">
            <TextBlock Text="{x:Static res:Strings.ConnectionHintsLabel}" FontWeight="SemiBold" />
            <CheckBox Content="{x:Static res:Strings.LowBandwidthPreviewCheckbox}" IsChecked="{Binding LowBandwidth}" />
            <CheckBox Content="{x:Static res:Strings.AudioOnlyCheckbox}" IsChecked="{Binding AudioOnly}" />
            <CheckBox Content="{x:Static res:Strings.VideoOnlyCheckbox}" IsChecked="{Binding VideoOnly}" />
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock VerticalAlignment="Center" Text="{x:Static res:Strings.ReconnectIntervalSecondsLabel}" />
              <NumericUpDown Minimum="0" Maximum="600" Increment="1" Value="{Binding RetrySeconds}" Width="100" />
              <TextBlock VerticalAlignment="Center" Opacity="0.7" FontSize="11"
                         Text="{x:Static res:Strings.ZeroDisablesRetriesHint}" />
            </StackPanel>

            <StackPanel Spacing="4" Margin="0,6,0,0">
              <TextBlock Text="Audio latency" FontWeight="SemiBold" />
              <TextBlock Opacity="0.7" FontSize="11" TextWrapping="Wrap"
                         Text="Audio jitter-buffer reserve. Empty = framework default (~50 ms). Smaller = lower latency (audio closer to the live video) at more underrun risk. Probe to find the lowest glitch-free size for this network." />
              <StackPanel Orientation="Horizontal" Spacing="6">
                <NumericUpDown Minimum="0" Maximum="2000" Increment="1" Width="130"
                               Watermark="default" Value="{Binding AudioBufferOverrideMs}" />
                <TextBlock VerticalAlignment="Center" Opacity="0.7" Text="ms" />
                <Button Content="Probe lowest" Command="{Binding ProbeBufferCommand}"
                        IsEnabled="{Binding !IsProbingBuffer}" />
                <Button Content="Cancel" Command="{Binding CancelBufferProbeCommand}"
                        IsVisible="{Binding IsProbingBuffer}" />
              </StackPanel>
              <TextBlock Opacity="0.8" FontSize="11" TextWrapping="Wrap" Text="{Binding BufferProbeStatus}" />
            </StackPanel>
          </StackPanel>
        </Border>

        <TextBlock TextWrapping="Wrap" Opacity="0.7" FontSize="11" Margin="0,4,0,0"
                   Text="{x:Static res:Strings.NdiVideoOnlyBehaviorHint}" />
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</Window>
