<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HaPlay.ViewModels"
        x:Class="HaPlay.Views.Dialogs.DetachedPlayerWindow"
        x:DataType="vm:MediaPlayerViewModel"
        Title="{Binding DetachedWindowTitle}"
        Width="780" Height="680"
        MinWidth="480" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        CanResize="True">
  <ContentControl Content="{Binding}" Margin="8" />
</Window>
