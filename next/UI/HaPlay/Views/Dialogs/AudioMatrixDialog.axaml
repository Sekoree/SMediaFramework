<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="using:HaPlay.Resources"
        xmlns:vm="using:HaPlay.ViewModels"
        x:Class="HaPlay.Views.Dialogs.AudioMatrixDialog"
        x:DataType="vm:MediaPlayerViewModel"
        Title="{x:Static res:Strings.AudioMatrixDialogTitle}"
        Width="760" Height="540"
        MinWidth="560" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        CanResize="True">
  <DockPanel Margin="10">
    <StackPanel DockPanel.Dock="Bottom"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,10,0,0">
      <Button Content="{x:Static res:Strings.CloseButton}" Click="CloseClick" IsCancel="True" />
    </StackPanel>

    <ScrollViewer HorizontalScrollBarVisibility="Auto">
      <StackPanel Spacing="10">

        <Grid ColumnDefinitions="Auto,96,*" ColumnSpacing="8">
          <TextBlock Grid.Column="0" Text="Source channels" VerticalAlignment="Center" />
          <NumericUpDown Grid.Column="1"
                         Minimum="1"
                         Maximum="64"
                         FormatString="0"
                         Value="{Binding AudioMatrixSourceChannels, Mode=TwoWay}"
                         ToolTip.Tip="Expected source channel count for preparing the matrix before media is opened." />
          <TextBlock Grid.Column="2" VerticalAlignment="Center" Opacity="0.65" FontSize="12"
                     Text="{x:Static res:Strings.AudioMatrixSimpleHint}" />
        </Grid>

        <Border Classes="Card" Padding="8">
          <StackPanel Spacing="6">
            <TextBlock Classes="SectionText" Text="{x:Static res:Strings.AudioMatrixOutputsTitle}" />
            <ItemsControl ItemsSource="{Binding AudioMatrixOutputSummaries}"
                          IsVisible="{Binding HasAudioMatrixOutputs}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:AudioMatrixOutputSummary">
                  <Grid ColumnDefinitions="88,*,96" ColumnSpacing="8" Margin="0,1">
                    <TextBlock Grid.Column="0" Text="{Binding KindLabel}" Opacity="0.7" />
                    <TextBlock Grid.Column="1" Text="{Binding Name}"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="2" Text="{Binding ChannelSummary}" Opacity="0.75"
                               HorizontalAlignment="Right" />
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock Opacity="0.55" FontSize="11"
                       IsVisible="{Binding !HasAudioMatrixOutputs}"
                       Text="{x:Static res:Strings.AudioMatrixNoAudioOutputsHint}" />
          </StackPanel>
        </Border>

        <TreeDataGrid Name="MatrixTreeGrid"
                      MinHeight="120" MaxHeight="400"
                      IsVisible="{Binding HasAudioMatrix}"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="False"
                      ShowColumnHeaders="True" />
        <TextBlock Opacity="0.55" FontSize="11"
                   IsVisible="{Binding !HasAudioMatrix}"
                   Text="{x:Static res:Strings.AudioMatrixEmptyHint}" />
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</Window>
