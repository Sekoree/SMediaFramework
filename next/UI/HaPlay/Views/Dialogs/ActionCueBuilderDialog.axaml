<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="using:HaPlay.Resources"
        xmlns:rootvm="using:HaPlay.ViewModels"
        xmlns:vm="using:HaPlay.ViewModels.Dialogs"
        x:Class="HaPlay.Views.Dialogs.ActionCueBuilderDialog"
        x:DataType="vm:ActionCueBuilderDialogViewModel"
        Title="{Binding DialogTitle}"
        Width="520" Height="420"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        MinWidth="420" MinHeight="360">
  <DockPanel Margin="16">
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,16,0,0">
      <Button Content="{x:Static res:Strings.CancelButton}" Click="CancelClick" IsCancel="True" />
      <Button Content="{x:Static res:Strings.ApplyButton}" Click="OkClick" IsDefault="True" />
    </StackPanel>

    <StackPanel Spacing="10">
      <TextBlock Text="{Binding ValidationMessage}" Foreground="#C62828" TextWrapping="Wrap" />

      <Grid ColumnDefinitions="90,*" ColumnSpacing="6">
        <TextBlock Grid.Column="0" Text="{x:Static res:Strings.ActionCueKindLabel}" VerticalAlignment="Center" />
        <ComboBox Grid.Column="1"
                  ItemsSource="{Binding ActionKinds}"
                  SelectedItem="{Binding ActionKind, Mode=TwoWay}">
          <ComboBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Converter={x:Static rootvm:EnumDisplayConverter.Instance}}" />
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>
      </Grid>

      <Grid ColumnDefinitions="90,*,Auto" ColumnSpacing="6">
        <TextBlock Grid.Column="0" Text="{x:Static res:Strings.ActionCueEndpointLabel}" VerticalAlignment="Center" />
        <ComboBox Grid.Column="1"
                  ItemsSource="{Binding Endpoints}"
                  SelectedItem="{Binding SelectedEndpoint, Mode=TwoWay}">
          <ComboBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Name}" />
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>
      </Grid>

      <Grid IsVisible="{Binding IsOSCVisible}" ColumnDefinitions="90,*,*" ColumnSpacing="6">
        <TextBlock Grid.Column="0" Text="{x:Static res:Strings.OSCTabHeader}" VerticalAlignment="Center" />
        <TextBox Grid.Column="1" Text="{Binding OSCAddress, Mode=TwoWay}" PlaceholderText="{x:Static res:Strings.OSCAddressPlaceholder}" />
        <TextBox Grid.Column="2" Text="{Binding OSCArguments, Mode=TwoWay}" PlaceholderText="{x:Static res:Strings.OSCArgumentsPlaceholder}" />
      </Grid>

      <StackPanel IsVisible="{Binding IsMIDIVisible}" Spacing="6">
        <Grid ColumnDefinitions="90,*" ColumnSpacing="6">
          <TextBlock Grid.Column="0" Text="{x:Static res:Strings.MIDITabHeader}" VerticalAlignment="Center" />
          <ComboBox Grid.Column="1"
                    ItemsSource="{Binding MIDICommandTypes}"
                    SelectedItem="{Binding MIDICommandType, Mode=TwoWay}">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Converter={x:Static rootvm:EnumDisplayConverter.Instance}}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
        </Grid>
        <WrapPanel ItemSpacing="8" LineSpacing="6">
          <StackPanel Width="82" IsVisible="{Binding IsMIDIChannelVisible}">
            <TextBlock Text="{x:Static res:Strings.ChannelLabel}" FontSize="11" Opacity="0.7" />
            <NumericUpDown FormatString="0" Minimum="1" Maximum="16" Value="{Binding MIDIChannel, Mode=TwoWay}" />
          </StackPanel>
          <StackPanel Width="112" IsVisible="{Binding IsMIDIData1Visible}">
            <TextBlock Text="{Binding MIDIData1Label}" FontSize="11" Opacity="0.7" />
            <NumericUpDown FormatString="0" Minimum="{Binding MIDIData1Minimum}"
                           Maximum="{Binding MIDIData1Maximum}"
                           Value="{Binding MIDIData1, Mode=TwoWay}" />
          </StackPanel>
          <StackPanel Width="112" IsVisible="{Binding IsMIDIData2Visible}">
            <TextBlock Text="{Binding MIDIData2Label}" FontSize="11" Opacity="0.7" />
            <NumericUpDown FormatString="0" Minimum="{Binding MIDIData2Minimum}"
                           Maximum="{Binding MIDIData2Maximum}"
                           Value="{Binding MIDIData2, Mode=TwoWay}" />
          </StackPanel>
        </WrapPanel>
        <Grid ColumnDefinitions="90,*" ColumnSpacing="6" IsVisible="{Binding IsMIDIDataTextVisible}">
          <TextBlock Grid.Column="0" Text="SysEx bytes" VerticalAlignment="Center" />
          <TextBox Grid.Column="1"
                   Text="{Binding MIDIDataText, Mode=TwoWay}"
                   PlaceholderText="F0 7D 00 F7" />
        </Grid>
      </StackPanel>
    </StackPanel>
  </DockPanel>
</Window>
