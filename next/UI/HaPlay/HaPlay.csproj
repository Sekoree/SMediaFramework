<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <LangVersion>latest</LangVersion>
        <AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
    </PropertyGroup>

    <ItemGroup>
        <AvaloniaResource Include="Assets\**"/>
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Avalonia"/>
        <PackageReference Include="Avalonia.AvaloniaEdit" />
        <PackageReference Include="Avalonia.Controls.ColorPicker" />
        <PackageReference Include="Avalonia.Desktop"/>
        <PackageReference Include="Avalonia.Themes.Fluent"/>
        <PackageReference Include="Avalonia.Fonts.Inter"/>
        <PackageReference Include="AvaloniaUI.DiagnosticsSupport" Condition="'$(Configuration)' == 'Debug' Or '$(Configuration)' == ''" />
        <PackageReference Include="CommunityToolkit.Mvvm"/>
        <PackageReference Include="StbImageSharp" />
        <PackageReference Include="TreeDataGrid.Avalonia" />
        <PackageReference Include="Xaml.Behaviors.Avalonia" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="SkiaSharp" />
    </ItemGroup>

    <!-- Repointed to the rewritten (next/) framework. Old→new module map:
         Effects→Compositor, FFmpeg→Decode.FFmpeg, PortAudio→Audio.PortAudio, MiniAudio→Audio.MiniAudio,
         SDL3→Present.SDL3, Avalonia→Present.Avalonia, Playback→Session; plus the new tiers Time/Routing/
         Players/Gpu the old monolithic Core/Playback have been split into. -->
    <ItemGroup>
        <ProjectReference Include="..\..\MediaFramework\Media\S.Media.Core\S.Media.Core.csproj" />
        <ProjectReference Include="..\..\MediaFramework\Media\S.Media.Time\S.Media.Time.csproj" />
        <ProjectReference Include="..\..\MediaFramework\Media\S.Media.Routing\S.Media.Routing.csproj" />
        <ProjectReference Include="..\..\MediaFramework\Media\S.Media.Players\S.Media.Players.csproj" />
        <ProjectReference Include="..\..\MediaFramework\Media\S.Media.Gpu\S.Media.Gpu.csproj" />
        <ProjectReference Include="..\..\MediaFramework\Media\S.Media.Compositor\S.Media.Compositor.csproj" />
        <ProjectReference Include="..\..\MediaFramework\Media\S.Media.Session\S.Media.Session.csproj" />
        <!-- Subtitle overlay bridge (sidecar/container/bitmap → IVideoOverlaySource) + libass. HaPlay is a host,
             so like S.Media.Interop it may reference both Decode.FFmpeg and Subtitles. -->
        <ProjectReference Include="..\..\MediaFramework\Media\S.Media.Subtitles\S.Media.Subtitles.csproj" />
        <ProjectReference Include="..\..\MediaFramework\Interop\S.Media.Interop\S.Media.Interop.csproj" />
        <ProjectReference Include="..\..\MediaFramework\Interop\S.Abi\S.Abi.csproj" />
        <ProjectReference Include="..\..\MediaFramework\Media\S.Media.Decode.FFmpeg\S.Media.Decode.FFmpeg.csproj" />
        <ProjectReference Include="..\..\MediaFramework\Media\S.Media.Source.YouTube\S.Media.Source.YouTube.csproj" />
        <ProjectReference Include="..\..\MediaFramework\Media\S.Media.Source.MMD\S.Media.Source.MMD.csproj" />
        <ProjectReference Include="..\..\MediaFramework\Media\S.Media.Audio.PortAudio\S.Media.Audio.PortAudio.csproj" />
        <ProjectReference Include="..\..\MediaFramework\Media\S.Media.Audio.MiniAudio\S.Media.Audio.MiniAudio.csproj" />
        <ProjectReference Include="..\..\MediaFramework\Media\S.Media.NDI\S.Media.NDI.csproj" />
        <ProjectReference Include="..\..\MediaFramework\Media\S.Media.Present.SDL3\S.Media.Present.SDL3.csproj" />
        <ProjectReference Include="..\..\MediaFramework\Media\S.Media.Present.SDL3.Compositor\S.Media.Present.SDL3.Compositor.csproj" />
        <ProjectReference Include="..\..\MediaFramework\Media\S.Media.Present.Avalonia\S.Media.Present.Avalonia.csproj" />
        <ProjectReference Include="..\..\MediaFramework\Control\S.Control\S.Control.csproj" />
        <ProjectReference Include="..\..\MediaFramework\Control\S.Control.Abstractions\S.Control.Abstractions.csproj" />
        <ProjectReference Include="..\..\MediaFramework\MIDI\PMLib\PMLib.csproj" />
        <ProjectReference Include="..\..\MediaFramework\OSC\OSCLib\OSCLib.csproj" />
    </ItemGroup>
</Project>
