<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:HaPlay.Core;assembly=HaPlay.Core"
        x:Class="HaPlay.App.MainWindow"
        x:DataType="vm:ShowSessionViewModel"
        Width="520" Height="660" Title="HaPlay">
    <StackPanel Margin="16" Spacing="8">
        <TextBlock Text="HaPlay — ShowSession spine" FontWeight="Bold" FontSize="16" />
        <StackPanel Orientation="Horizontal" Spacing="6">
            <Button Content="Load show…" Click="OnLoadShowClick" />
            <Button Content="Save show…" Click="OnSaveShowClick" />
            <Button Content="GO" Command="{Binding GoCommand}" />
            <Button Content="Stop" Command="{Binding StopCommand}" />
            <Button Content="Refresh" Command="{Binding RefreshCommand}" />
        </StackPanel>
        <TextBlock Text="{Binding CueCount, StringFormat='cues: {0}'}" />
        <ListBox ItemsSource="{Binding Cues}" SelectedItem="{Binding SelectedCue}" Height="110">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:CueListItem">
                    <TextBlock Text="{Binding Display}" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <StackPanel Orientation="Horizontal" Spacing="6">
            <Button Content="Add" Command="{Binding AddCueCommand}" />
            <Button Content="Remove" Command="{Binding RemoveSelectedCueCommand}" />
            <Button Content="Up" Command="{Binding MoveCueUpCommand}" />
            <Button Content="Down" Command="{Binding MoveCueDownCommand}" />
            <Button Content="Set clip…" Click="OnSetClipClick" />
            <Button Content="Fire" Command="{Binding FireSelectedCueCommand}" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBox Text="{Binding NewCueLabel}" Watermark="New label" Width="180" />
            <Button Content="Rename" Command="{Binding RenameSelectedCueCommand}" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBox Text="{Binding SeekSeconds}" Watermark="seconds" Width="80" />
            <Button Content="Seek" Command="{Binding SeekCommand}" />
            <TextBlock VerticalAlignment="Center" Text="{Binding PositionTicks, StringFormat='pos: {0}'}" />
            <TextBlock VerticalAlignment="Center" Text="{Binding IsRunning, StringFormat='running: {0}'}" />
        </StackPanel>
        <TextBlock Text="cue log" FontWeight="Bold" />
        <ListBox ItemsSource="{Binding CueLog}" Height="90" />
        <TextBlock Text="{Binding StatusMessage, StringFormat='status: {0}'}" Foreground="#888888" />
    </StackPanel>
</Window>
