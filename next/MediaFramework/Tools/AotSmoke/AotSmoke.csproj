<Project Sdk="Microsoft.NET.Sdk">

  <!-- Phase 0 AOT gate: the minimal executable that must `dotnet publish -p:PublishAot=true`.
       It references S.Media.Core so the NativeAOT toolchain exercises the framework keystone.
       Real parity-harness apps (PlaybackSmoke, CompositorSmoke, …) arrive in their phases. -->

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <PublishAot>true</PublishAot>
    <InvariantGlobalization>true</InvariantGlobalization>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="../../Media/S.Media.Core/S.Media.Core.csproj" />
  </ItemGroup>

</Project>
