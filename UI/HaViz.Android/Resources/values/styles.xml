<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Avalonia's activity is AppCompat-based - the theme MUST descend from Theme.AppCompat.
         Full-bleed dark for the 4-inch dedicated device; Avalonia draws everything. -->
    <style name="MyTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:colorBackground">#101014</item>
    </style>
</resources>
