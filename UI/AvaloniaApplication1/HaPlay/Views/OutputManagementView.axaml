<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:HaPlay.ViewModels"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="520"
             x:Class="HaPlay.Views.OutputManagementView"
             x:DataType="vm:OutputManagementViewModel">
  <DockPanel Margin="16">
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
      <TextBlock Text="Outputs" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,16,0" />
      <Button Content="Add PortAudio…" Command="{Binding AddPortAudioCommand}" />
      <Button Content="Add local video (SDL / Avalonia)…" Command="{Binding AddLocalVideoCommand}" />
      <Button Content="Add NDI…" Command="{Binding AddNdiCommand}" />
    </StackPanel>

    <Border BorderBrush="#33000000" BorderThickness="1" CornerRadius="4" Padding="8">
      <ListBox ItemsSource="{Binding Outputs}" Background="Transparent">
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="vm:OutputLineViewModel">
            <Grid ColumnDefinitions="*,Auto" Margin="0,6">
              <Grid.ContextFlyout>
                <MenuFlyout>
                  <MenuItem Header="No preview actions for this output type."
                            IsVisible="{Binding IsNotLocalVideo}"
                            IsEnabled="False" />
                  <MenuItem Header="Start preview window"
                            Command="{Binding StartPreviewCommand}"
                            IsVisible="{Binding IsLocalVideo}" />
                  <MenuItem Header="Stop preview window"
                            Command="{Binding StopPreviewCommand}"
                            IsVisible="{Binding IsLocalVideo}" />
                  <MenuItem Header="Fullscreen preview"
                            Command="{Binding FullscreenPreviewCommand}"
                            IsVisible="{Binding IsLocalVideo}" />
                  <MenuItem Header="Windowed preview"
                            Command="{Binding WindowedPreviewCommand}"
                            IsVisible="{Binding IsLocalVideo}" />
                </MenuFlyout>
              </Grid.ContextFlyout>
              <StackPanel Grid.Column="0" Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="{Binding KindLabel}" FontWeight="SemiBold" />
                  <TextBlock Text="—" VerticalAlignment="Center" />
                  <TextBlock Text="{Binding Definition.DisplayName}" FontWeight="SemiBold" />
                </StackPanel>
                <TextBlock Text="{Binding Summary}" Opacity="0.75" TextWrapping="Wrap" />
              </StackPanel>
              <Button Grid.Column="1" VerticalAlignment="Top" Content="Remove" Command="{Binding RemoveCommand}" />
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Border>
  </DockPanel>
</UserControl>
