<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:port="using:S.Media.PortAudio"
        xmlns:vm="using:HaPlay.ViewModels.Dialogs"
        x:Class="HaPlay.Views.Dialogs.AddPortAudioOutputDialog"
        x:DataType="vm:AddPortAudioOutputDialogViewModel"
        Title="Add PortAudio output"
        Width="520" Height="560"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
  <DockPanel Margin="16">
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,16,0,0">
      <Button Content="Cancel" Click="CancelClick" IsCancel="True" />
      <Button Content="OK" Click="OkClick" IsDefault="True" />
    </StackPanel>

    <ScrollViewer>
      <StackPanel Spacing="10">
        <TextBlock Text="{Binding ValidationMessage}" Foreground="#C62828" TextWrapping="Wrap" />

        <TextBlock Text="Display name" FontWeight="SemiBold" />
        <TextBox Text="{Binding DisplayName}" />

        <TextBlock Text="Host API" FontWeight="SemiBold" />
        <ComboBox ItemsSource="{Binding HostApis}"
                  SelectedItem="{Binding SelectedHostApi}">
          <ComboBox.ItemTemplate>
            <DataTemplate x:DataType="port:PortAudioHostApiEntry">
              <TextBlock Text="{Binding Name}" />
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>

        <TextBlock Text="Output device" FontWeight="SemiBold" />
        <ComboBox ItemsSource="{Binding Devices}"
                  SelectedItem="{Binding SelectedDevice}">
          <ComboBox.ItemTemplate>
            <DataTemplate x:DataType="port:PortAudioOutputDeviceEntry">
              <TextBlock Text="{Binding Name}" />
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>

        <TextBlock Text="Channel count (must be ≤ device maximum)" FontWeight="SemiBold" />
        <NumericUpDown Minimum="1" Maximum="64" Value="{Binding ChannelCount}" />

        <TextBlock Text="Sample rate (Hz)" FontWeight="SemiBold" />
        <NumericUpDown Minimum="8000" Maximum="192000" Increment="1000" Value="{Binding SampleRate}" />
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</Window>
