<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:HaPlay.ViewModels"
             xmlns:models="using:HaPlay.Models"
             xmlns:res="using:HaPlay.Resources"
             mc:Ignorable="d" d:DesignWidth="720" d:DesignHeight="560"
             x:Class="HaPlay.Views.OSCConnectionsView"
             x:DataType="vm:MainViewModel">
  <DockPanel Margin="16">
    <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,12">
      <TextBlock Text="{x:Static res:Strings.OSCConnectionsHeader}" FontSize="22" FontWeight="SemiBold" />
      <TextBlock Text="{x:Static res:Strings.OSCConnectionsHint}"
                 Opacity="0.7" TextWrapping="Wrap" />
    </StackPanel>

    <Border BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" CornerRadius="0" Padding="8">
      <DockPanel>
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6" Margin="0,0,0,6">
          <TextBlock Grid.Column="0" Text="{x:Static res:Strings.EndpointsHeader}" FontWeight="SemiBold" VerticalAlignment="Center" />
          <Button Grid.Column="1" Content="{x:Static res:Strings.AddOSCButton}" Command="{Binding AddOSCEndpointCommand}" />
          <Button Grid.Column="2" Content="{x:Static res:Strings.RemoveButton}" Command="{Binding RemoveActionEndpointCommand}" />
        </Grid>
        <ListBox ItemsSource="{Binding OSCEndpointRows}"
                 SelectedItem="{Binding SelectedOSCEndpointRow, Mode=TwoWay}">
          <ListBox.ItemTemplate>
            <DataTemplate DataType="vm:ActionEndpointRowViewModel">
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" Margin="0,2">
                <Ellipse Grid.Column="0"
                         Width="10" Height="10"
                         VerticalAlignment="Center"
                         Fill="{Binding HealthColor}"
                         ToolTip.Tip="{Binding HealthToolTip}" />
                <StackPanel Grid.Column="1" Spacing="2">
                  <TextBlock Text="{Binding Endpoint.Name}" FontWeight="SemiBold" />
                  <TextBlock FontSize="12" Opacity="0.65" Text="{Binding Endpoint.Id}" />
                  <TextBlock FontSize="12" Opacity="0.75" Text="{Binding Endpoint.Summary}" />
                </StackPanel>
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
        <Border DockPanel.Dock="Bottom"
                Margin="0,8,0,0"
                Padding="8"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="1"
                CornerRadius="0"
                IsVisible="{Binding IsSelectedOSCEndpoint}">
          <StackPanel Spacing="6">
            <TextBlock Text="{x:Static res:Strings.EndpointEditorHeader}" FontWeight="SemiBold" />
            <Grid ColumnDefinitions="90,*" ColumnSpacing="6">
              <TextBlock Grid.Column="0" Text="{x:Static res:Strings.NameLabel}" VerticalAlignment="Center" />
              <TextBox Grid.Column="1" Text="{Binding EndpointEditName, Mode=TwoWay}" />
            </Grid>
            <Grid ColumnDefinitions="90,*,70,100" ColumnSpacing="6">
              <TextBlock Grid.Column="0" Text="{x:Static res:Strings.HostLabel}" VerticalAlignment="Center" />
              <TextBox Grid.Column="1" Text="{Binding OSCEditHost, Mode=TwoWay}" />
              <TextBlock Grid.Column="2" Text="{x:Static res:Strings.PortLabel}" VerticalAlignment="Center" />
              <NumericUpDown FormatString="0" Grid.Column="3"
                             Minimum="1"
                             Maximum="65535"
                             Value="{Binding OSCEditPort, Mode=TwoWay}" />
            </Grid>
            <Button Content="{x:Static res:Strings.TestConnectionButton}"
                    Command="{Binding TestSelectedOSCEndpointCommand}" />
            <TextBlock Text="{Binding EndpointTestStatus}" Opacity="0.75" FontSize="12" TextWrapping="Wrap" />
            <Button Content="{x:Static res:Strings.SaveEndpointButton}"
                    HorizontalAlignment="Right"
                    Command="{Binding SaveActionEndpointEditsCommand}" />
          </StackPanel>
        </Border>
      </DockPanel>
    </Border>
  </DockPanel>
</UserControl>
