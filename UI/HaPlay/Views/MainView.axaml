<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:HaPlay.ViewModels"
             xmlns:remote="using:HaPlay.Remote"
             xmlns:models="using:HaPlay.Models"
             xmlns:res="using:HaPlay.Resources"
             xmlns:views="using:HaPlay.Views"
             xmlns:common="clr-namespace:Classic.CommonControls;assembly=Classic.CommonControls.Avalonia"
             xmlns:theme="clr-namespace:Classic.Avalonia.Theme;assembly=Classic.Avalonia.Theme"
             xmlns:controls="using:HaPlay.Views.Controls"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
             x:Class="HaPlay.Views.MainView"
             x:DataType="vm:MainViewModel">

  <UserControl.Styles>
    <Style Selector="Button.sidebar">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="Margin" Value="4,2" />
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <!-- Active workspace = the classic pressed-toggle look (sunken bevel + dither), so the sidebar
         clearly shows which view is selected. -->
    <Style Selector="Button.sidebar.selected">
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.sidebar.selected /template/ theme|ClassicBorderDecorator#ContentContainer">
      <Setter Property="BorderStyle" Value="RaiseReversed" />
      <Setter Property="Background" Value="{DynamicResource DiagonalBrushLight}" />
    </Style>
    <!-- Collapsed rail: icon-only buttons center their glyph instead of hugging the left edge. -->
    <Style Selector="Button.sidebar.collapsed">
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="Padding" Value="0,8" />
    </Style>
    <Style Selector="PathIcon.sidebar-glyph">
      <Setter Property="Width" Value="15" />
      <Setter Property="Height" Value="15" />
      <Setter Property="Margin" Value="4,0" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
  </UserControl.Styles>

  <UserControl.KeyBindings>
    <KeyBinding Gesture="F1" Command="{Binding ShowKeyboardShortcutsCommand}" />
    <KeyBinding Gesture="Ctrl+B" Command="{Binding ToggleSidebarCommand}" />
    <KeyBinding Gesture="Ctrl+N" Command="{Binding NewProjectCommand}" />
    <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenProjectCommand}" />
    <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveProjectCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+S" Command="{Binding SaveProjectAsCommand}" />
    <KeyBinding Gesture="Ctrl+1" Command="{Binding SelectWorkspaceCommand}"
                CommandParameter="{x:Static models:WorkspaceItem.Players}" />
    <KeyBinding Gesture="Ctrl+2" Command="{Binding SelectWorkspaceCommand}"
                CommandParameter="{x:Static models:WorkspaceItem.Cues}" />
    <KeyBinding Gesture="Ctrl+3" Command="{Binding SelectWorkspaceCommand}"
                CommandParameter="{x:Static models:WorkspaceItem.Soundboard}" />
    <KeyBinding Gesture="Ctrl+4" Command="{Binding SelectWorkspaceCommand}"
                CommandParameter="{x:Static models:WorkspaceItem.Control}" />
    <KeyBinding Gesture="Ctrl+5" Command="{Binding SelectWorkspaceCommand}"
                CommandParameter="{x:Static models:WorkspaceItem.Io}" />
    <KeyBinding Gesture="Ctrl+6" Command="{Binding SelectWorkspaceCommand}"
                CommandParameter="{x:Static models:WorkspaceItem.Project}" />
  </UserControl.KeyBindings>

  <!-- Root grid so the toast overlay can stack above the shell without touching layout (P1). -->
  <Grid>
  <DockPanel>
    <Menu DockPanel.Dock="Top">
      <MenuItem Header="{x:Static res:Strings.MenuFileHeader}">
        <MenuItem Header="{x:Static res:Strings.MenuNewProjectHeader}" Command="{Binding NewProjectCommand}" InputGesture="Ctrl+N" />
        <MenuItem Header="{x:Static res:Strings.MenuOpenProjectHeader}" Command="{Binding OpenProjectCommand}" InputGesture="Ctrl+O" />
        <Separator />
        <MenuItem Header="{x:Static res:Strings.MenuSaveProjectHeader}" Command="{Binding SaveProjectCommand}" InputGesture="Ctrl+S" />
        <MenuItem Header="{x:Static res:Strings.MenuSaveProjectAsHeader}" Command="{Binding SaveProjectAsCommand}" InputGesture="Ctrl+Shift+S" />
        <MenuItem Header="{x:Static res:Strings.ExportSectionsMenuHeader}" Command="{Binding ExportProjectSectionsCommand}" />
        <Separator />
        <MenuItem Header="{x:Static res:Strings.MenuRecentProjectsHeader}" ItemsSource="{Binding RecentProjects}">
          <MenuItem.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding}" />
            </DataTemplate>
          </MenuItem.ItemTemplate>
          <MenuItem.Styles>
            <Style Selector="MenuItem">
              <Setter Property="Command" Value="{Binding $parent[Menu].((vm:MainViewModel)DataContext)?.OpenRecentCommand}" />
              <Setter Property="CommandParameter" Value="{Binding}" />
            </Style>
          </MenuItem.Styles>
        </MenuItem>
        <Separator />
        <MenuItem Header="{x:Static res:Strings.MenuExitHeader}" Click="MenuItem_OnClick"/>
      </MenuItem>
      <MenuItem Header="{x:Static res:Strings.MenuViewHeader}">
        <!-- Workspace navigation duplicated here so the Ctrl+1…5 shortcuts are discoverable
             (the sidebar gives no hint that they exist). -->
        <MenuItem Header="{Binding Label, Source={x:Static models:WorkspaceItem.Players}}" InputGesture="Ctrl+1"
                  Command="{Binding SelectWorkspaceCommand}" CommandParameter="{x:Static models:WorkspaceItem.Players}" />
        <MenuItem Header="{Binding Label, Source={x:Static models:WorkspaceItem.Cues}}" InputGesture="Ctrl+2"
                  Command="{Binding SelectWorkspaceCommand}" CommandParameter="{x:Static models:WorkspaceItem.Cues}" />
        <MenuItem Header="{Binding Label, Source={x:Static models:WorkspaceItem.Soundboard}}" InputGesture="Ctrl+3"
                  Command="{Binding SelectWorkspaceCommand}" CommandParameter="{x:Static models:WorkspaceItem.Soundboard}" />
        <MenuItem Header="{Binding Label, Source={x:Static models:WorkspaceItem.Control}}" InputGesture="Ctrl+4"
                  Command="{Binding SelectWorkspaceCommand}" CommandParameter="{x:Static models:WorkspaceItem.Control}" />
        <MenuItem Header="{Binding Label, Source={x:Static models:WorkspaceItem.Io}}" InputGesture="Ctrl+5"
                  Command="{Binding SelectWorkspaceCommand}" CommandParameter="{x:Static models:WorkspaceItem.Io}" />
        <MenuItem Header="{Binding Label, Source={x:Static models:WorkspaceItem.Project}}" InputGesture="Ctrl+6"
                  Command="{Binding SelectWorkspaceCommand}" CommandParameter="{x:Static models:WorkspaceItem.Project}" />
        <Separator />
        <MenuItem Header="{x:Static res:Strings.MenuToggleSidebarHeader}" Command="{Binding ToggleSidebarCommand}" InputGesture="Ctrl+B" />
        <MenuItem Header="{x:Static res:Strings.MenuTargetConfigurationHeader}" Command="{Binding OpenTargetConfigurationCommand}" />
      </MenuItem>
      <MenuItem Header="{x:Static res:Strings.MenuHelpHeader}">
        <MenuItem Header="{x:Static res:Strings.KeyboardShortcutsMenuHeader}"
                  Command="{Binding ShowKeyboardShortcutsCommand}" InputGesture="F1" />
      </MenuItem>
    </Menu>

    <!-- P1: fixed-height status line - text changes, layout never does (no banner push-down). -->
    <controls:StatusLineControl DockPanel.Dock="Top"
                                Padding="8,0"
                                Text="{Binding ProjectStatus}" />

    <Border DockPanel.Dock="Left"
            BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,1,0"
            Width="{Binding SidebarWidth}">
      <DockPanel>
        <Button DockPanel.Dock="Top"
                Classes="sidebar"
                Classes.collapsed="{Binding SidebarCollapsed}"
                Command="{Binding ToggleSidebarCommand}"
                ToolTip.Tip="{x:Static res:Strings.TooltipToggleSidebar}"
                AutomationProperties.Name="{x:Static res:Strings.TooltipToggleSidebar}">
          <PathIcon Data="{x:Static views:AppIcons.Menu}" Classes="sidebar-glyph" />
        </Button>

        <ItemsControl ItemsSource="{Binding Workspaces}">
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="models:WorkspaceItem">
              <Button Classes.sidebar="True"
                      Classes.collapsed="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).SidebarCollapsed}"
                      Command="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).SelectWorkspaceCommand}"
                      CommandParameter="{Binding}"
                      ToolTip.Tip="{Binding Label}"
                      AutomationProperties.Name="{Binding Label}">
                <!-- ConverterParameter can't bind, so the old ObjectConverters.Equal approach never
                     matched - the active workspace was never highlighted. Compare via MultiBinding. -->
                <Classes.selected>
                  <MultiBinding Converter="{x:Static views:AllEqualConverter.Instance}">
                    <Binding Path="$parent[ItemsControl].((vm:MainViewModel)DataContext).SelectedWorkspace" />
                    <Binding />
                  </MultiBinding>
                </Classes.selected>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <PathIcon Data="{Binding Icon}" Classes="sidebar-glyph" />
                  <TextBlock Text="{Binding Label}"
                             VerticalAlignment="Center"
                             IsVisible="{Binding !$parent[ItemsControl].((vm:MainViewModel)DataContext).SidebarCollapsed}" />
                </StackPanel>
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </DockPanel>
    </Border>

    <Grid>
      <!-- Players workspace: tabs keep multiple decks manageable while preserving a single selected
           player for quick-play drops, cue defaults, and remote routing. -->
      <DockPanel Margin="8" IsVisible="{Binding IsPlayersWorkspaceSelected}">
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,6">
          <TextBlock Grid.Column="0" VerticalAlignment="Center" Classes="CaptionText"
                     Text="{x:Static res:Strings.PlayersDeckHint}" />
          <Button Grid.Column="1" Content="{x:Static res:Strings.AddPlayerButton}"
                  Command="{Binding AddPlayerCommand}"
                  VerticalAlignment="Center" Margin="6,0,0,0" />
          <Button Grid.Column="2"
                  ToolTip.Tip="{x:Static res:Strings.PopoutButtonTooltip}"
                  AutomationProperties.Name="{x:Static res:Strings.PopoutButtonTooltip}"
                  Click="OnPopOutPlayersClick"
                  VerticalAlignment="Center" Margin="6,0,0,0">
            <PathIcon Data="{x:Static views:AppIcons.Duplicate}" Width="11" Height="11" />
          </Button>
        </Grid>

        <ContentControl x:Name="PlayersPopoutHost">
        <Grid x:Name="PlayersQuickPlayHost"
              ToolTip.Tip="{x:Static res:Strings.PlayersDropAddTooltip}">
          <TabControl ItemsSource="{Binding PlayerTabs}"
                      SelectedItem="{Binding SelectedPlayer, Mode=TwoWay}">
            <TabControl.ItemTemplate>
              <DataTemplate x:DataType="vm:MediaPlayerViewModel">
                <StackPanel Orientation="Horizontal" Spacing="6" MinWidth="96">
                  <TextBlock FontWeight="SemiBold"
                             MaxWidth="180"
                             Text="{Binding Name}"
                             TextTrimming="CharacterEllipsis" />
                  <TextBlock FontSize="11" Opacity="0.65" VerticalAlignment="Center"
                             Text="{Binding PlaybackStateLabel}" />
                </StackPanel>
              </DataTemplate>
            </TabControl.ItemTemplate>
            <TabControl.ContentTemplate>
              <DataTemplate x:DataType="vm:MediaPlayerViewModel">
                <views:MediaPlayerView DataContext="{Binding}" />
              </DataTemplate>
            </TabControl.ContentTemplate>
          </TabControl>
        </Grid>
        </ContentControl>
      </DockPanel>

      <!-- P1 transitional I/O host: existing Outputs + MIDI views under one workspace; replaced by
           the master-detail IoWorkspaceView in P2. -->
      <TabControl Margin="8"
                  IsVisible="{Binding $parent[Grid].((vm:MainViewModel)DataContext).IsIoWorkspaceSelected}">
        <TabItem Header="{x:Static res:Strings.OutputsHeader}">
          <views:OutputManagementView DataContext="{Binding OutputManagement}" />
        </TabItem>
        <TabItem Header="{x:Static res:Strings.MIDIHeader}"
                 IsVisible="{Binding IsMIDIAvailable}">
          <views:MIDIDevicesView />
        </TabItem>
        <TabItem Header="{x:Static res:Strings.IoTabOSC}">
          <views:OSCConnectionsView />
        </TabItem>
      </TabControl>

      <!-- Cues workspace: the cue player. OSC/MIDI action targets open in the Action Targets
           dialog (button below or the app menu) rather than taking permanent space here. -->
      <DockPanel Margin="8"
                 IsVisible="{Binding $parent[Grid].((vm:MainViewModel)DataContext).IsCuesWorkspaceSelected}">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" HorizontalAlignment="Right"
                    Spacing="6" Margin="0,0,0,6">
          <Button Content="{x:Static res:Strings.ActionTargetsButtonLabel}"
                  ToolTip.Tip="{x:Static res:Strings.ActionTargetsButtonTooltip}"
                  Command="{Binding OpenTargetConfigurationCommand}" />
          <Button
                  ToolTip.Tip="{x:Static res:Strings.PopoutButtonTooltip}"
                  AutomationProperties.Name="{x:Static res:Strings.PopoutButtonTooltip}"
                  Click="OnPopOutCuesClick">
            <PathIcon Data="{x:Static views:AppIcons.Duplicate}" Width="11" Height="11" />
          </Button>
        </StackPanel>
        <ContentControl x:Name="CuesPopoutHost">
          <!-- The outer host must contain a Control for PopoutRegion to reparent. The inner ContentControl
               keeps the heavy view deferred until LoadedCueWorkspace becomes non-null. -->
          <ContentControl Content="{Binding LoadedCueWorkspace}">
            <ContentControl.ContentTemplate>
              <DataTemplate x:DataType="vm:CuePlayerViewModel">
                <views:CuePlayerView />
              </DataTemplate>
            </ContentControl.ContentTemplate>
          </ContentControl>
        </ContentControl>
      </DockPanel>

      <!-- Soundboard workspace: touch-friendly sound clip grids in tabs. Pops out like the cue
           player (PopoutRegion moves the single view instance into a floating window). -->
      <DockPanel Margin="8"
                 IsVisible="{Binding $parent[Grid].((vm:MainViewModel)DataContext).IsSoundboardWorkspaceSelected}">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" HorizontalAlignment="Right"
                    Spacing="6" Margin="0,0,0,6">
          <Button
                  ToolTip.Tip="{x:Static res:Strings.PopoutButtonTooltip}"
                  AutomationProperties.Name="{x:Static res:Strings.PopoutButtonTooltip}"
                  Click="OnPopOutSoundboardClick">
            <PathIcon Data="{x:Static views:AppIcons.Duplicate}" Width="11" Height="11" />
          </Button>
        </StackPanel>
        <ContentControl x:Name="SoundboardPopoutHost">
          <ContentControl Content="{Binding LoadedSoundboardWorkspace}">
            <ContentControl.ContentTemplate>
              <DataTemplate x:DataType="vm:SoundboardWorkspaceViewModel">
                <views:SoundboardView />
              </DataTemplate>
            </ContentControl.ContentTemplate>
          </ContentControl>
        </ContentControl>
      </DockPanel>

      <ContentControl Content="{Binding LoadedControlWorkspace}"
                      IsVisible="{Binding IsControlWorkspaceSelected}">
        <ContentControl.ContentTemplate>
          <DataTemplate x:DataType="vm:ControlWorkspaceViewModel">
            <views:ControlWorkspaceView />
          </DataTemplate>
        </ContentControl.ContentTemplate>
      </ContentControl>

      <!-- Scrolls when the window is too short for the display / remote-api / media-cache sections
           (the cache rows at the bottom used to land out of bounds on a small window). -->
      <ScrollViewer Margin="16" IsVisible="{Binding IsProjectWorkspaceSelected}"
                    VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
      <DockPanel>
        <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,0,0,12">
          <TextBlock Text="{x:Static res:Strings.ProjectHeader}" FontSize="22" FontWeight="SemiBold" />
          <TextBlock Text="{Binding ProjectTitle}" Opacity="0.85" />
          <TextBlock Text="{Binding CurrentProjectPath, FallbackValue={x:Static res:Strings.ProjectPathFallback}}"
                     Opacity="0.65" FontSize="12" TextWrapping="Wrap" />
        </StackPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
          <Button Content="{x:Static res:Strings.NewButton}" Command="{Binding NewProjectCommand}" />
          <Button Content="{x:Static res:Strings.OpenButton}" Command="{Binding OpenProjectCommand}" />
          <Button Content="{x:Static res:Strings.SaveButton}" Command="{Binding SaveProjectCommand}" />
          <Button Content="{x:Static res:Strings.SaveAsButton}" Command="{Binding SaveProjectAsCommand}" />
        </StackPanel>
        <StackPanel DockPanel.Dock="Top" Spacing="2" Margin="0,0,0,12">
          <CheckBox Content="{x:Static res:Strings.ProjectAutoSaveLabel}"
                    IsChecked="{Binding AutoSaveEnabled, Mode=TwoWay}"
                    IsEnabled="{Binding HasOpenProject}" />
          <TextBlock Text="{x:Static res:Strings.ProjectAutoSaveHint}"
                     Opacity="0.6" FontSize="12" TextWrapping="Wrap" Margin="24,0,0,0" />
          <TextBlock Text="{x:Static res:Strings.ProjectAutoSaveHintUnsaved}"
                     Opacity="0.6" FontSize="12" TextWrapping="Wrap" Margin="24,0,0,0"
                     IsVisible="{Binding AutoSaveUnavailable}" />
          <TextBlock Text="{Binding AutoSaveStatusText}" Opacity="0.7" FontSize="12"
                     TextWrapping="Wrap" Margin="24,2,0,0"
                     IsVisible="{Binding !AutoSaveStatusIsError}" />
          <TextBlock Text="{Binding AutoSaveStatusText}" Foreground="{StaticResource StatusErrorFg}"
                     FontSize="12" TextWrapping="Wrap" Margin="24,2,0,0"
                     IsVisible="{Binding AutoSaveStatusIsError}" />
          <StackPanel Orientation="Horizontal" Spacing="6" Margin="24,2,0,0">
            <Button Content="{x:Static res:Strings.AutoSaveRetryButton}"
                    Command="{Binding RetryAutoSaveCommand}" IsVisible="{Binding AutoSaveStatusIsError}" />
            <Button Content="{x:Static res:Strings.OpenRecoveryFolderButton}"
                    Command="{Binding OpenRecoveryFolderCommand}" />
          </StackPanel>
        </StackPanel>
        <Grid ColumnDefinitions="1.05*,1.8*" ColumnSpacing="10">
          <Border Grid.Column="0" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" CornerRadius="0" Padding="8">
            <DockPanel>
              <TextBlock DockPanel.Dock="Top" Text="{x:Static res:Strings.RecentProjectsSectionHeader}" FontWeight="SemiBold" Margin="0,0,0,6" />
              <TextBlock DockPanel.Dock="Top"
                         Text="{x:Static res:Strings.RecentProjectsEmptyHint}"
                         Opacity="0.55" FontSize="12"
                         TextWrapping="Wrap"
                         IsVisible="{Binding HasNoRecentProjects}" />
              <ItemsControl ItemsSource="{Binding RecentProjects}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Button Classes="sidebar"
                            Command="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).OpenRecentCommand}"
                            CommandParameter="{Binding}">
                      <TextBlock Text="{Binding}" />
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </DockPanel>
          </Border>

          <StackPanel Grid.Column="1" Spacing="10">
            <!-- §8.6 Display preferences - per-machine, not part of the project file.
                 Style = base control theme (Classic / Simple / Fluent). The Theme (light/dark) and Density
                 controls disable for base themes that don't support them: Classic is light-only, and only
                 Fluent has a density axis. -->
            <Border BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" CornerRadius="0" Padding="8"
                    IsVisible="{Binding ShowAppearanceSettings}">
              <StackPanel Spacing="6">
                <TextBlock Text="{x:Static res:Strings.DisplayHeader}" FontWeight="SemiBold" />
                <TextBlock Opacity="0.65" FontSize="12" TextWrapping="Wrap"
                           Text="{x:Static res:Strings.DisplaySettingsHint}" />
                <Grid ColumnDefinitions="80,*,16,80,*" RowDefinitions="Auto,Auto" Margin="0,4,0,0">
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static res:Strings.StyleLabel}"
                             VerticalAlignment="Center" />
                  <ComboBox Grid.Row="0" Grid.Column="1"
                            ItemsSource="{Binding BaseThemeChoices}"
                            SelectedItem="{Binding BaseTheme}"
                            HorizontalAlignment="Stretch"
                            ToolTip.Tip="{x:Static res:Strings.StyleTooltip}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding Converter={x:Static vm:EnumDisplayConverter.Instance}}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                  <TextBlock Grid.Row="0" Grid.Column="3" Text="{x:Static res:Strings.ThemeLabel}"
                             VerticalAlignment="Center" />
                  <ComboBox Grid.Row="0" Grid.Column="4"
                            ItemsSource="{Binding ThemeChoices}"
                            SelectedItem="{Binding Theme}"
                            IsEnabled="{Binding IsVariantSelectable}"
                            HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding Converter={x:Static vm:EnumDisplayConverter.Instance}}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                  <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static res:Strings.DensityLabel}"
                             VerticalAlignment="Center" Margin="0,6,0,0" />
                  <ComboBox Grid.Row="1" Grid.Column="1"
                            ItemsSource="{Binding DensityChoices}"
                            SelectedItem="{Binding Density}"
                            IsEnabled="{Binding IsDensitySelectable}"
                            HorizontalAlignment="Stretch" Margin="0,6,0,0">
                    <ComboBox.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding Converter={x:Static vm:EnumDisplayConverter.Instance}}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                </Grid>
                <!-- Appearance changes are composed at startup only (a live control-theme swap isn't reliable
                     in Avalonia), so when a setting differs from what's running, ask whether to restart now
                     or later (Later keeps the current look; the choice applies on the next launch). -->
                <Border IsVisible="{Binding ShowAppearanceRestartPrompt}" Margin="0,4,0,0"
                        Background="{StaticResource ChipNeutral}" CornerRadius="0" Padding="8,6">
                  <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8">
                    <PathIcon Grid.Column="0" Data="{x:Static views:AppIcons.Info}" Width="13" Height="13"
                              VerticalAlignment="Center" Foreground="{StaticResource AccentWarn}" />
                    <TextBlock Grid.Column="1" Text="{x:Static res:Strings.AppearanceRestartHint}" FontSize="12"
                               TextWrapping="Wrap" VerticalAlignment="Center" />
                    <Button Grid.Column="2" Classes="Std Go" Content="{x:Static res:Strings.RestartNowButton}"
                            Command="{Binding RestartAppCommand}" />
                    <Button Grid.Column="3" Classes="Std" Content="{x:Static res:Strings.RestartLaterButton}"
                            Command="{Binding DismissAppearanceRestartCommand}" />
                  </Grid>
                </Border>
              </StackPanel>
            </Border>

            <!-- Remote API - per-machine HTTP control surface for show controllers. -->
            <Border BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" CornerRadius="0" Padding="8">
              <StackPanel Spacing="6">
                <TextBlock Text="{x:Static res:Strings.RemoteApiSectionHeader}" FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" Spacing="12">
                  <CheckBox Content="{x:Static res:Strings.RemoteApiEnableLabel}"
                            IsChecked="{Binding RestApiEnabled, Mode=TwoWay}" />
                  <TextBlock Text="{x:Static res:Strings.RemoteApiPortLabel}" VerticalAlignment="Center" />
                  <NumericUpDown Minimum="1024" Maximum="65535" Increment="1" FormatString="0"
                                 Value="{Binding RestApiPort, Mode=TwoWay}" MinWidth="120" />
                  <CheckBox Content="{x:Static res:Strings.RemoteApiAllowLanLabel}"
                            IsChecked="{Binding RestApiAllowLan, Mode=TwoWay}" />
                </StackPanel>
                <SelectableTextBlock Text="{Binding RestApiBaseUrlDisplay}" FontFamily="monospace" FontSize="12" />
                <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto" ColumnSpacing="8">
                  <TextBlock Grid.Column="0" Text="{x:Static res:Strings.RemoteApiTokenLabel}"
                             VerticalAlignment="Center" Opacity="0.75" FontSize="12" />
                  <SelectableTextBlock Grid.Column="1" Text="{Binding RestApiAccessTokenDisplay}"
                                       VerticalAlignment="Center" FontFamily="monospace" FontSize="12" />
                  <!-- API-01: token is masked by default; Reveal/Copy are enabled only when one is set. -->
                  <ToggleButton Grid.Column="2" Content="{x:Static res:Strings.RemoteApiRevealTokenLabel}"
                                IsChecked="{Binding RevealRestApiToken, Mode=TwoWay}"
                                IsEnabled="{Binding HasRestApiAccessToken}" FontSize="12" Padding="8,2"
                                AutomationProperties.Name="{x:Static res:Strings.RemoteApiRevealTokenLabel}" />
                  <Button Grid.Column="3" Content="{x:Static res:Strings.RemoteApiCopyTokenLabel}"
                          Click="OnCopyRestApiTokenClick"
                          IsEnabled="{Binding HasRestApiAccessToken}" FontSize="12" Padding="8,2"
                          AutomationProperties.Name="{x:Static res:Strings.RemoteApiCopyTokenLabel}" />
                  <Button Grid.Column="4" Content="{x:Static res:Strings.RemoteApiGenerateTokenLabel}"
                          Command="{Binding RegenerateRestApiTokenCommand}" FontSize="12" Padding="8,2" />
                  <Button Grid.Column="5" Content="{x:Static res:Strings.RemoteApiClearTokenLabel}"
                          Command="{Binding ClearRestApiTokenCommand}"
                          IsEnabled="{Binding HasRestApiAccessToken}" FontSize="12" Padding="8,2" />
                </Grid>
                <TextBlock Text="{Binding RestApiSecurityStatus}" Opacity="0.75" FontSize="12"
                           TextWrapping="Wrap" />
                <TextBlock Text="{Binding RestApiStatusNote}" Foreground="#DAAA3A" FontSize="12"
                           TextWrapping="Wrap"
                           IsVisible="{Binding RestApiStatusNote, Converter={x:Static ObjectConverters.IsNotNull}}" />
                <TextBlock Opacity="0.65" FontSize="12" TextWrapping="Wrap"
                           Text="{x:Static res:Strings.RemoteApiHint}" />
                <!-- Endpoint cheat-sheet: aligned path column (shared size scope) + description. -->
                <ItemsControl ItemsSource="{Binding RestApiEndpointDocs}"
                              Grid.IsSharedSizeScope="True" Margin="0,2,0,0">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="remote:RemoteApiEndpointDoc">
                      <Grid ColumnSpacing="12" Margin="0,1">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="Auto" SharedSizeGroup="ApiPath" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <SelectableTextBlock Grid.Column="0" Text="{Binding Path}"
                                             FontFamily="monospace" FontSize="11" />
                        <TextBlock Grid.Column="1" Text="{Binding Description}"
                                   Opacity="0.65" FontSize="11" TextWrapping="Wrap"
                                   VerticalAlignment="Center" />
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>

            <!-- Media caches - per-machine prepared media (YouTube downloads, MMD bakes): size, open, clear. -->
            <Border BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" CornerRadius="0" Padding="8">
              <StackPanel Spacing="6">
                <TextBlock Text="{x:Static res:Strings.CacheSectionHeader}" FontWeight="SemiBold" />
                <TextBlock Opacity="0.65" FontSize="12" TextWrapping="Wrap"
                           Text="{x:Static res:Strings.CacheSectionHint}" />
                <ItemsControl ItemsSource="{Binding MediaCaches}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:MediaCacheViewModel">
                      <Grid ColumnDefinitions="*,Auto,Auto,Auto" RowDefinitions="Auto,Auto,Auto"
                            ColumnSpacing="6" Margin="0,4,0,0">
                        <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="8">
                          <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                          <TextBlock Text="{Binding SizeText}" Opacity="0.75" FontSize="12"
                                     VerticalAlignment="Center" />
                        </StackPanel>
                        <Button Grid.Row="0" Grid.Column="1" Padding="8,2" FontSize="12"
                                Content="{x:Static res:Strings.CacheRefreshButton}"
                                Command="{Binding RefreshCommand}" />
                        <Button Grid.Row="0" Grid.Column="2" Padding="8,2" FontSize="12"
                                Content="{x:Static res:Strings.CacheOpenFolderButton}"
                                Command="{Binding OpenFolderCommand}" />
                        <Button Grid.Row="0" Grid.Column="3" Padding="8,2" FontSize="12"
                                Content="{x:Static res:Strings.CacheClearButton}"
                                Command="{Binding ClearCommand}"
                                IsEnabled="{Binding !IsBusy}" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4"
                                   Text="{Binding Hint}" Opacity="0.55" FontSize="11" TextWrapping="Wrap" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4"
                                   Text="{Binding StatusText}" FontSize="11" TextWrapping="Wrap"
                                   IsVisible="{Binding StatusText, Converter={x:Static ObjectConverters.IsNotNull}}" />
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>
          </StackPanel>
        </Grid>
      </DockPanel>
      </ScrollViewer>
    </Grid>
  </DockPanel>

  <!-- P1: toast overlay - top-right, stacked, hit-testable only where toasts are. Body click pins
       (stops auto-dismiss), ✕ closes. Never affects layout below. -->
  <ItemsControl ItemsSource="{Binding Toasts}"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,40,16,0" Width="340"
                IsHitTestVisible="True">
    <ItemsControl.ItemTemplate>
      <DataTemplate DataType="vm:ToastViewModel">
        <!-- Classic balloon look: the theme's Info (tooltip-yellow) surface with a hard 1px border. -->
        <Border CornerRadius="0" Padding="10,8" Margin="0,0,0,6"
                Background="{DynamicResource {x:Static common:SystemColors.InfoBrushKey}}"
                BorderThickness="1"
                BorderBrush="{DynamicResource {x:Static common:SystemColors.WindowFrameBrushKey}}">
          <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
            <Panel Grid.Column="0" VerticalAlignment="Top">
              <PathIcon Data="{x:Static views:AppIcons.Info}" Width="13" Height="13"
                        Foreground="{StaticResource StatusInfoFg}" IsVisible="{Binding IsInfo}" />
              <PathIcon Data="{x:Static views:AppIcons.Warning}" Width="13" Height="13"
                        Foreground="{StaticResource StatusWarnFg}" IsVisible="{Binding IsWarning}" />
              <PathIcon Data="{x:Static views:AppIcons.Blocked}" Width="13" Height="13"
                        Foreground="{StaticResource StatusErrorFg}" IsVisible="{Binding IsError}" />
            </Panel>
            <TextBlock Grid.Column="1" Text="{Binding Message}" TextWrapping="Wrap"
                       Foreground="{DynamicResource {x:Static common:SystemColors.InfoTextBrushKey}}"
                       FontSize="12"
                       PointerPressed="OnToastBodyPressed" />
            <StackPanel Grid.Column="2" Spacing="2">
              <Button Padding="6,2" MinWidth="22" Command="{Binding CloseCommand}"
                      AutomationProperties.Name="{x:Static res:Strings.CloseButton}">
                <PathIcon Data="{x:Static views:AppIcons.Close}" Width="9" Height="9" />
              </Button>
              <PathIcon Data="{x:Static views:AppIcons.Pin}" Width="10" Height="10"
                        Foreground="{DynamicResource {x:Static common:SystemColors.InfoTextBrushKey}}"
                        HorizontalAlignment="Center"
                        IsVisible="{Binding IsPinned}" />
            </StackPanel>
          </Grid>
        </Border>
      </DataTemplate>
    </ItemsControl.ItemTemplate>
  </ItemsControl>
  </Grid>
</UserControl>
