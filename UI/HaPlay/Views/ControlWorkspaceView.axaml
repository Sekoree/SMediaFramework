<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ae="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
             xmlns:vm="using:HaPlay.ViewModels"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="680"
             x:Class="HaPlay.Views.ControlWorkspaceView"
             x:DataType="vm:ControlWorkspaceViewModel">
  <UserControl.Styles>
    <Style Selector="Grid.error TextBlock">
      <Setter Property="Foreground" Value="#FF6B6B" />
    </Style>
    <Style Selector="TextBlock.col">
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="FontFamily" Value="Cascadia Code, Consolas, monospace" />
      <Setter Property="FontSize" Value="12" />
    </Style>
  </UserControl.Styles>

  <DockPanel Margin="16">
    <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,12">
      <TextBlock Text="Control" FontSize="22" FontWeight="SemiBold" />
      <TextBlock Text="Script-centric MIDI/OSC control. Arm the system to open OSC listeners and run scripts."
                 Opacity="0.7" TextWrapping="Wrap" />
    </StackPanel>

    <!-- Arm + summary -->
    <Border DockPanel.Dock="Top" BorderBrush="#22808080" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
      <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="6">
        <Button Grid.Row="0" Grid.Column="0" Width="100"
                Content="{Binding ArmButtonText}" Command="{Binding ToggleArmCommand}" />
        <TextBlock Grid.Row="0" Grid.Column="1" VerticalAlignment="Center"
                   Text="{Binding StatusMessage}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" Spacing="16" Opacity="0.85">
          <TextBlock Text="{Binding DeviceCount, StringFormat='Devices: {0}'}" />
          <TextBlock Text="{Binding ListenerCount, StringFormat='Listeners: {0}'}" />
          <TextBlock Text="{Binding LayerCount, StringFormat='Layers: {0}'}" />
          <TextBlock Text="{Binding ScriptCount, StringFormat='Scripts: {0}'}" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- Project structure -->
    <Border DockPanel.Dock="Top" BorderBrush="#22808080" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
      <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="Project structure" FontWeight="SemiBold" Margin="0,0,0,8" />
        <ItemsControl DockPanel.Dock="Bottom" ItemsSource="{Binding ProfileWarnings}" Margin="0,8,0,0">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding}" Foreground="#D7A300" TextWrapping="Wrap" />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
        <ListBox ItemsSource="{Binding StructureRows}"
                 MinHeight="120"
                 MaxHeight="170"
                 Background="Transparent">
          <ListBox.ItemTemplate>
            <DataTemplate DataType="vm:ControlStructureRowViewModel">
              <Grid ColumnDefinitions="Auto,84,180,*,120" ColumnSpacing="8" Margin="0,2">
                <Border Grid.Column="0" Width="{Binding IndentWidth}" />
                <TextBlock Grid.Column="1"
                           Text="{Binding Kind}"
                           Opacity="0.7"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="2"
                           Text="{Binding Name}"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="3"
                           Text="{Binding Detail}"
                           Opacity="0.72"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="4"
                           Text="{Binding State}"
                           Opacity="0.7"
                           TextTrimming="CharacterEllipsis" />
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>

    <!-- Test send -->
    <Border DockPanel.Dock="Top" BorderBrush="#22808080" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
      <StackPanel Spacing="6">
        <TextBlock Text="Test send" FontWeight="SemiBold" />
        <Grid ColumnDefinitions="Auto,140,Auto,80,Auto,*" ColumnSpacing="6">
          <TextBlock Grid.Column="0" Text="Host" VerticalAlignment="Center" />
          <TextBox Grid.Column="1" Text="{Binding TestOscHost}" />
          <TextBlock Grid.Column="2" Text="Port" VerticalAlignment="Center" />
          <TextBox Grid.Column="3" Text="{Binding TestOscPort}" />
          <TextBlock Grid.Column="4" Text="Address" VerticalAlignment="Center" />
          <TextBox Grid.Column="5" Text="{Binding TestOscAddress}" />
        </Grid>
        <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="6">
          <TextBlock Grid.Column="0" Text="Args" VerticalAlignment="Center" />
          <TextBox Grid.Column="1" Text="{Binding TestOscArgs}" PlaceholderText="comma-separated, e.g. 0.5, 1, true, name" />
          <Button Grid.Column="2" Content="Send OSC" Command="{Binding SendTestOscCommand}" />
          <Button Grid.Column="3" Content="Run manual scripts" Command="{Binding RunManualScriptsCommand}" />
        </Grid>
      </StackPanel>
    </Border>

    <!-- Script editor -->
    <Border DockPanel.Dock="Top" BorderBrush="#22808080" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
      <Grid ColumnDefinitions="240,*" RowDefinitions="Auto,220,Auto,90,Auto" ColumnSpacing="10" RowSpacing="6">
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Scripts" FontWeight="SemiBold" />
        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ScriptEditorStatus}" Opacity="0.75" TextTrimming="CharacterEllipsis" />
        <ListBox Grid.Row="1"
                 Grid.RowSpan="4"
                 Grid.Column="0"
                 ItemsSource="{Binding ScriptRows}"
                 SelectedItem="{Binding SelectedScriptRow, Mode=TwoWay}">
          <ListBox.ItemTemplate>
            <DataTemplate DataType="vm:ControlScriptRowViewModel">
              <StackPanel Spacing="1">
                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                <TextBlock Text="{Binding DisplayScriptPath}" FontSize="12" Opacity="0.72" TextTrimming="CharacterEllipsis" />
                <TextBlock Text="{Binding ScopeText}" FontSize="12" Opacity="0.6" />
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
        <ae:TextEditor x:Name="ScriptEditor"
                       Grid.Row="1"
                       Grid.Column="1"
                       ShowLineNumbers="True"
                       FontFamily="Cascadia Code, Consolas, monospace"
                       FontSize="13"
                       Background="#101010"
                       Foreground="#EEEEEE" />
        <Grid Grid.Row="2"
              Grid.Column="1"
              ColumnDefinitions="Auto,*,Auto,140,Auto,120"
              RowDefinitions="Auto,Auto,Auto,Auto"
              ColumnSpacing="8"
              RowSpacing="6">
          <CheckBox Grid.Row="0"
                    Grid.Column="0"
                    Content="Enabled"
                    IsChecked="{Binding SelectedScriptRow.IsEnabled, Mode=TwoWay}" />
          <TextBox Grid.Row="0"
                   Grid.Column="1"
                   Text="{Binding SelectedScriptRow.Name, Mode=TwoWay}"
                   PlaceholderText="script name" />
          <TextBlock Grid.Row="0" Grid.Column="2" Text="Scope" VerticalAlignment="Center" />
          <ComboBox Grid.Row="0"
                    Grid.Column="3"
                    ItemsSource="{Binding ScriptScopeOptions}"
                    SelectedItem="{Binding SelectedScriptRow.Scope, Mode=TwoWay}" />
          <TextBlock Grid.Row="0" Grid.Column="4" Text="Failures" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="0"
                         Grid.Column="5"
                         Value="{Binding SelectedScriptRow.MaxConsecutiveFailures, Mode=TwoWay}"
                         Minimum="1"
                         Maximum="99"
                         Increment="1"
                         FormatString="0" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Path" VerticalAlignment="Center" />
          <TextBox Grid.Row="1"
                   Grid.Column="1"
                   Grid.ColumnSpan="3"
                   Text="{Binding SelectedScriptRow.ScriptPath, Mode=TwoWay}"
                   PlaceholderText="Scripts/control.mnd" />
          <ComboBox Grid.Row="1"
                    Grid.Column="4"
                    Grid.ColumnSpan="2"
                    ItemsSource="{Binding ScriptFailureModeOptions}"
                    SelectedItem="{Binding SelectedScriptRow.FailureMode, Mode=TwoWay}" />

          <TextBlock Grid.Row="2"
                     Grid.Column="0"
                     Text="Triggers"
                     VerticalAlignment="Center" />
          <TextBlock Grid.Row="2"
                     Grid.Column="1"
                     Grid.ColumnSpan="5"
                     Text="{Binding SelectedScriptRow.TriggerSummary}"
                     Opacity="0.75"
                     TextTrimming="CharacterEllipsis" />
          <TextBlock Grid.Row="3"
                     Grid.Column="0"
                     Text="Exports"
                     VerticalAlignment="Center" />
          <TextBlock Grid.Row="3"
                     Grid.Column="1"
                     Grid.ColumnSpan="5"
                     Text="{Binding ExportedFunctionsSummary}"
                     Opacity="0.75"
                     TextTrimming="CharacterEllipsis" />
        </Grid>
        <Border Grid.Row="3"
                Grid.Column="1"
                BorderBrush="#22808080"
                BorderThickness="1"
                CornerRadius="4"
                Padding="6">
          <DockPanel>
            <TextBlock DockPanel.Dock="Top" Text="Diagnostics" FontWeight="SemiBold" Margin="0,0,0,4" />
            <ListBox ItemsSource="{Binding ScriptDiagnostics}" Background="Transparent">
              <ListBox.ItemTemplate>
                <DataTemplate DataType="vm:ControlScriptDiagnosticRowViewModel">
                  <Grid ColumnDefinitions="80,*" ColumnSpacing="8" Classes.error="{Binding IsError}">
                    <TextBlock Grid.Column="0" Text="{Binding Stage}" Opacity="0.7" TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="1" Text="{Binding Message}" TextTrimming="CharacterEllipsis" />
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </DockPanel>
        </Border>
        <Button Grid.Row="4"
                Grid.Column="1"
                Content="Save Script"
                HorizontalAlignment="Right"
                Command="{Binding SaveSelectedScriptCommand}" />
      </Grid>
    </Border>

    <!-- Monitor toolbar -->
    <Grid DockPanel.Dock="Top"
          ColumnDefinitions="*,130,130,160,Auto,Auto,Auto"
          RowDefinitions="Auto,Auto"
          ColumnSpacing="8"
          RowSpacing="6"
          Margin="0,0,0,6">
      <TextBlock Grid.Row="0" Grid.Column="0" Text="Live monitor" FontWeight="SemiBold" VerticalAlignment="Center" />
      <CheckBox Grid.Row="0" Grid.Column="4" Content="Errors only" IsChecked="{Binding ErrorsOnly}" />
      <CheckBox Grid.Row="0" Grid.Column="5" Content="Pause" IsChecked="{Binding IsPaused}" />
      <Button Grid.Row="0" Grid.Column="6" Content="Clear" Command="{Binding ClearMonitorCommand}" />
      <TextBox Grid.Row="1"
               Grid.Column="0"
               Text="{Binding FilterText}"
               PlaceholderText="filter: address, message…" />
      <ComboBox Grid.Row="1"
                Grid.Column="1"
                ItemsSource="{Binding MonitorDirectionOptions}"
                SelectedItem="{Binding SelectedMonitorDirection, Mode=TwoWay}" />
      <ComboBox Grid.Row="1"
                Grid.Column="2"
                ItemsSource="{Binding MonitorProtocolOptions}"
                SelectedItem="{Binding SelectedMonitorProtocol, Mode=TwoWay}" />
      <TextBox Grid.Row="1"
               Grid.Column="3"
               Text="{Binding DeviceFilterText}"
               PlaceholderText="device" />
    </Grid>

    <!-- Monitor list -->
    <Border BorderBrush="#22808080" BorderThickness="1" CornerRadius="6">
      <ListBox ItemsSource="{Binding MonitorEntries}" Background="Transparent">
        <ListBox.ItemTemplate>
          <DataTemplate DataType="vm:ControlMonitorEntryViewModel">
            <Grid ColumnDefinitions="90,70,70,70,*" ColumnSpacing="8" Classes.error="{Binding IsError}">
              <TextBlock Grid.Column="0" Classes="col" Opacity="0.7" Text="{Binding Time}" />
              <TextBlock Grid.Column="1" Classes="col" Text="{Binding Protocol}" />
              <TextBlock Grid.Column="2" Classes="col" Opacity="0.85" Text="{Binding Direction}" />
              <TextBlock Grid.Column="3" Classes="col" Opacity="0.85" Text="{Binding Result}" />
              <TextBlock Grid.Column="4" Classes="col" Text="{Binding Summary}" TextTrimming="CharacterEllipsis" />
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Border>
  </DockPanel>
</UserControl>
