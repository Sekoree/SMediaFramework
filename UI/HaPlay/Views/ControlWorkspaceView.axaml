<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:HaPlay.ViewModels"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="680"
             x:Class="HaPlay.Views.ControlWorkspaceView"
             x:DataType="vm:ControlWorkspaceViewModel">
  <UserControl.Styles>
    <Style Selector="Grid.error TextBlock">
      <Setter Property="Foreground" Value="#FF6B6B" />
    </Style>
    <Style Selector="TextBlock.col">
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="FontFamily" Value="Cascadia Code, Consolas, monospace" />
      <Setter Property="FontSize" Value="12" />
    </Style>
  </UserControl.Styles>

  <Grid Margin="16" RowDefinitions="Auto,2*,Auto,*">
    <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,12">
      <TextBlock Text="Control" FontSize="22" FontWeight="SemiBold" />
      <TextBlock Text="Script-centric MIDI/OSC control. Arm the system to open OSC listeners and run scripts."
                 Opacity="0.7" TextWrapping="Wrap" />
    </StackPanel>

    <!-- Scrollable configuration form -->
    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
      <StackPanel>

    <!-- Arm + summary -->
    <Border BorderBrush="#22808080" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
      <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="6">
        <Button Grid.Row="0" Grid.Column="0" Width="100"
                Content="{Binding ArmButtonText}" Command="{Binding ToggleArmCommand}" />
        <TextBlock Grid.Row="0" Grid.Column="1" VerticalAlignment="Center"
                   Text="{Binding StatusMessage}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" Spacing="16" Opacity="0.85">
          <TextBlock Text="{Binding DeviceCount, StringFormat='Devices: {0}'}" />
          <TextBlock Text="{Binding ListenerCount, StringFormat='Listeners: {0}'}" />
          <TextBlock Text="{Binding LayerCount, StringFormat='Layers: {0}'}" />
          <TextBlock Text="{Binding ScriptCount, StringFormat='Scripts: {0}'}" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- Project structure -->
    <Border BorderBrush="#22808080" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
      <DockPanel>
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="6" Margin="0,0,0,8">
          <TextBlock Grid.Column="0" Text="Project structure" FontWeight="SemiBold" VerticalAlignment="Center" />
          <Button Grid.Column="1" Content="Add layer…"
                  ToolTip.Tip="Add a control layer (mutually-exclusive set of layer-scoped scripts)"
                  Command="{Binding AddLayerCommand}" />
          <Button Grid.Column="2" Content="Add OSC device…"
                  ToolTip.Tip="Add an OSC device such as an X32 or X-Air"
                  Command="{Binding AddOscDeviceCommand}" />
          <Button Grid.Column="3" Content="Add OSC listener…"
                  ToolTip.Tip="Add an inbound OSC listener port for external control sources"
                  Command="{Binding AddOscListenerCommand}" />
          <Button Grid.Column="4" Content="Resolve MIDI…"
                  ToolTip.Tip="Pick current ports for ambiguous or missing MIDI devices"
                  Command="{Binding ResolveMidiDevicesCommand}" />
        </Grid>
        <ItemsControl DockPanel.Dock="Bottom" ItemsSource="{Binding ProfileWarnings}" Margin="0,8,0,0">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding}" Foreground="#D7A300" TextWrapping="Wrap" />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
        <ListBox ItemsSource="{Binding StructureRows}"
                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                 Background="Transparent">
          <ListBox.ItemTemplate>
            <DataTemplate DataType="vm:ControlStructureRowViewModel">
              <Grid ColumnDefinitions="Auto,72,150,*,76,Auto" ColumnSpacing="8" Margin="0,2">
                <Grid.ContextMenu>
                  <ContextMenu x:DataType="vm:ControlStructureRowViewModel">
                    <MenuItem Header="Add project script" Command="{Binding AddProjectScriptCommand}" />
                    <MenuItem Header="Add imported helper file" Command="{Binding AddHelperFileCommand}" />
                    <MenuItem Header="Add device script" Command="{Binding AddDeviceScriptCommand}" IsVisible="{Binding CanAddDeviceScript}" />
                    <MenuItem Header="Add endpoint script" Command="{Binding AddEndpointScriptCommand}" IsVisible="{Binding CanAddEndpointScript}" />
                    <MenuItem Header="Add OSC listener…" Command="{Binding AddOscListenerCommand}" />
                    <MenuItem Header="Edit OSC listener…" Command="{Binding EditOscListenerCommand}" IsVisible="{Binding CanEditOscListener}" />
                    <MenuItem Header="Remove OSC listener" Command="{Binding RemoveOscListenerCommand}" IsVisible="{Binding CanEditOscListener}" />
                    <MenuItem Header="Add layer script" Command="{Binding AddLayerScriptCommand}" IsVisible="{Binding CanAddLayerScript}" />
                    <MenuItem Header="Add layer…" Command="{Binding AddLayerCommand}" />
                    <MenuItem Header="Activate layer" Command="{Binding ActivateLayerCommand}" IsVisible="{Binding CanActivateLayer}" />
                    <MenuItem Header="Edit layer…" Command="{Binding EditLayerCommand}" IsVisible="{Binding CanEditLayer}" />
                    <MenuItem Header="Remove layer" Command="{Binding RemoveLayerCommand}" IsVisible="{Binding CanEditLayer}" />
                    <MenuItem Header="Add periodic OSC send…" Command="{Binding AddPeriodicSendCommand}" IsVisible="{Binding CanAddPeriodicSend}" />
                    <MenuItem Header="Edit periodic send…" Command="{Binding EditPeriodicSendCommand}" IsVisible="{Binding CanEditPeriodicSend}" />
                    <MenuItem Header="Remove periodic send" Command="{Binding RemovePeriodicSendCommand}" IsVisible="{Binding CanEditPeriodicSend}" />
                    <Separator IsVisible="{Binding CanAddDeviceScript}" />
                    <MenuItem Header="Edit OSC device…" Command="{Binding EditOscDeviceCommand}" IsVisible="{Binding CanEditOscDevice}" />
                    <MenuItem Header="Remove OSC device" Command="{Binding RemoveOscDeviceCommand}" IsVisible="{Binding CanEditOscDevice}" />
                    <MenuItem Header="Test OSC send" Command="{Binding TestOscCommand}" IsVisible="{Binding CanTestOsc}" />
                    <MenuItem Header="Test MIDI send" Command="{Binding TestMidiCommand}" IsVisible="{Binding CanTestMidi}" />
                  </ContextMenu>
                </Grid.ContextMenu>
                <Border Grid.Column="0" Width="{Binding IndentWidth}" />
                <TextBlock Grid.Column="1"
                           Text="{Binding Kind}"
                           Opacity="0.7"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="2"
                           Text="{Binding Name}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="3"
                           Text="{Binding Detail}"
                           Opacity="0.72"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="4"
                           Text="{Binding State}"
                           Opacity="0.7"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
                <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                  <Button Content="Activate" Padding="8,1" FontSize="11" ToolTip.Tip="Activate this layer (mutually exclusive)"
                          IsVisible="{Binding CanActivateLayer}" Command="{Binding ActivateLayerCommand}" />
                  <Button Content="Edit" Padding="8,1" FontSize="11" ToolTip.Tip="Edit layer"
                          IsVisible="{Binding CanEditLayer}" Command="{Binding EditLayerCommand}" />
                  <Button Content="Remove" Padding="8,1" FontSize="11" ToolTip.Tip="Remove layer"
                          IsVisible="{Binding CanEditLayer}" Command="{Binding RemoveLayerCommand}" />
                  <Button Content="Edit" Padding="8,1" FontSize="11" ToolTip.Tip="Edit OSC device"
                          IsVisible="{Binding CanEditOscDevice}" Command="{Binding EditOscDeviceCommand}" />
                  <Button Content="Remove" Padding="8,1" FontSize="11" ToolTip.Tip="Remove OSC device"
                          IsVisible="{Binding CanEditOscDevice}" Command="{Binding RemoveOscDeviceCommand}" />
                  <Button Content="Edit" Padding="8,1" FontSize="11" ToolTip.Tip="Edit OSC listener"
                          IsVisible="{Binding CanEditOscListener}" Command="{Binding EditOscListenerCommand}" />
                  <Button Content="Remove" Padding="8,1" FontSize="11" ToolTip.Tip="Remove OSC listener"
                          IsVisible="{Binding CanEditOscListener}" Command="{Binding RemoveOscListenerCommand}" />
                  <Button Content="Edit" Padding="8,1" FontSize="11" ToolTip.Tip="Edit periodic send"
                          IsVisible="{Binding CanEditPeriodicSend}" Command="{Binding EditPeriodicSendCommand}" />
                  <Button Content="Remove" Padding="8,1" FontSize="11" ToolTip.Tip="Remove periodic send"
                          IsVisible="{Binding CanEditPeriodicSend}" Command="{Binding RemovePeriodicSendCommand}" />
                </StackPanel>
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>

    <!-- Profiles -->
    <Expander Header="Profiles" IsExpanded="False" Classes="dense" Margin="0,0,0,10">
      <StackPanel Spacing="4" Margin="0,6,0,0">
        <StackPanel Orientation="Horizontal" Spacing="4">
          <Button Content="Import" Padding="8,2" Command="{Binding ImportProfileCommand}" />
          <Button Content="Export selected" Padding="8,2" Command="{Binding ExportSelectedProfileCommand}" />
          <Button Content="Export built-ins" Padding="8,2" Command="{Binding ExportBuiltInProfilesCommand}" />
          <Button Content="Remove project" Padding="8,2" Command="{Binding RemoveSelectedProjectProfileCommand}" />
        </StackPanel>
        <ListBox ItemsSource="{Binding ProfileRows}"
                 SelectedItem="{Binding SelectedProfileRow}"
                 MaxHeight="180"
                 Background="Transparent">
          <ListBox.ItemTemplate>
            <DataTemplate DataType="vm:ControlProfileRowViewModel">
              <Grid ColumnDefinitions="180,90,90,*" ColumnSpacing="8" Margin="0,2">
                <TextBlock Grid.Column="0" Text="{Binding DisplayName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="1" Text="{Binding Protocol}" Opacity="0.75" TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="2" Text="{Binding Source}" Opacity="0.75" TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="3" Text="{Binding Summary}" Opacity="0.75" TextTrimming="CharacterEllipsis" />
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </StackPanel>
    </Expander>

    <!-- X32 command/cache browser (collapsed by default to save space) -->
    <Expander Header="X32 command/cache browser" IsExpanded="False" Classes="dense" Margin="0,0,0,10">
      <StackPanel Spacing="4" Margin="0,6,0,0">
        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
          <TextBox Grid.Column="0" Text="{Binding X32CommandFilterText}" PlaceholderText="Filter device, group, address, cache" />
          <Button Grid.Column="1" Content="Use as test" Padding="8,2" Command="{Binding UseSelectedX32CommandForTestSendCommand}" />
          <Button Grid.Column="2" Content="Request" Padding="8,2" Command="{Binding RequestSelectedX32CommandCommand}" />
        </Grid>
        <Grid ColumnDefinitions="120,110,180,*,90,80,130" ColumnSpacing="8" Opacity="0.65" Margin="0,2,0,2">
          <TextBlock Grid.Column="0" Text="Device" />
          <TextBlock Grid.Column="1" Text="Group" />
          <TextBlock Grid.Column="2" Text="Command" />
          <TextBlock Grid.Column="3" Text="Address" />
          <TextBlock Grid.Column="4" Text="Value" />
          <TextBlock Grid.Column="5" Text="Access" />
          <TextBlock Grid.Column="6" Text="Cache" />
        </Grid>
        <ListBox ItemsSource="{Binding X32CommandRows}"
                 SelectedItem="{Binding SelectedX32CommandRow}"
                 MaxHeight="240"
                 Background="Transparent">
          <ListBox.ItemTemplate>
            <DataTemplate DataType="vm:ControlX32CommandRowViewModel">
              <Grid ColumnDefinitions="120,110,180,*,90,80,130" ColumnSpacing="8" Margin="0,2">
                <TextBlock Grid.Column="0" Text="{Binding DeviceName}" TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="1" Text="{Binding Group}" Opacity="0.75" TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="2" Text="{Binding CommandName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="3" Text="{Binding Address}" FontFamily="Cascadia Code, Consolas, monospace" TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="4" Text="{Binding ValueKind}" Opacity="0.75" TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="5" Text="{Binding Access}" Opacity="0.75" TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="6" Text="{Binding CacheValue}" Opacity="0.75" TextTrimming="CharacterEllipsis" />
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </StackPanel>
    </Expander>

    <!-- Diagnostics / test send -->
    <Expander Header="Diagnostics and manual sends" IsExpanded="False" Classes="dense" Margin="0,0,0,10">
      <StackPanel Spacing="6" Margin="0,6,0,0">
        <TextBlock Text="Test send" FontWeight="SemiBold" />
        <Grid ColumnDefinitions="Auto,140,Auto,80,Auto,*" ColumnSpacing="6">
          <TextBlock Grid.Column="0" Text="Host" VerticalAlignment="Center" />
          <TextBox Grid.Column="1" Text="{Binding TestOscHost}" />
          <TextBlock Grid.Column="2" Text="Port" VerticalAlignment="Center" />
          <TextBox Grid.Column="3" Text="{Binding TestOscPort}" />
          <TextBlock Grid.Column="4" Text="Address" VerticalAlignment="Center" />
          <TextBox Grid.Column="5" Text="{Binding TestOscAddress}" />
        </Grid>
        <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="6">
          <TextBlock Grid.Column="0" Text="Args" VerticalAlignment="Center" />
          <TextBox Grid.Column="1" Text="{Binding TestOscArgs}" PlaceholderText="comma-separated, e.g. 0.5, 1, true, name" />
          <Button Grid.Column="2" Content="Send OSC" Command="{Binding SendTestOscCommand}" />
          <Button Grid.Column="3" Content="Run all manual triggers" Command="{Binding RunManualScriptsCommand}" />
        </Grid>
      </StackPanel>
    </Expander>

    <!-- Scripts -->
    <Border BorderBrush="#22808080" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
      <DockPanel>
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="4" Margin="0,0,0,8">
          <TextBlock Grid.Column="0" Text="Scripts" FontWeight="SemiBold" VerticalAlignment="Center" />
          <Button Grid.Column="1" Content="+" Padding="8,2" ToolTip.Tip="Add script" Command="{Binding AddScriptCommand}" />
          <Button Grid.Column="2" Content="–" Padding="8,2" ToolTip.Tip="Remove selected script" Command="{Binding RemoveSelectedScriptCommand}" />
          <Button Grid.Column="3" Content="Edit…" Padding="8,2" Click="OnEditScriptClick"
                  ToolTip.Tip="Open the selected script in a separate editor window" />
        </Grid>
        <TextBlock DockPanel.Dock="Bottom" Margin="0,8,0,0" Opacity="0.6" FontSize="12" TextWrapping="Wrap"
                   Text="Double-click a script (or use Edit…) to open it in a separate editor window with the code editor, triggers, and learn mode." />
        <ListBox x:Name="ScriptList"
                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                 ItemsSource="{Binding ScriptRows}"
                 SelectedItem="{Binding SelectedScriptRow, Mode=TwoWay}"
                 DoubleTapped="OnScriptListDoubleTapped">
          <ListBox.ItemTemplate>
            <DataTemplate DataType="vm:ControlScriptRowViewModel">
              <StackPanel Spacing="1">
                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                <TextBlock Text="{Binding DisplayScriptPath}" FontSize="12" Opacity="0.72" TextTrimming="CharacterEllipsis" />
                <TextBlock Text="{Binding ScopeText}" FontSize="12" Opacity="0.6" />
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>
      </StackPanel>
    </ScrollViewer>

    <!-- Monitor toolbar -->
    <Grid Grid.Row="2"
          ColumnDefinitions="*,130,130,160,Auto,Auto,Auto"
          RowDefinitions="Auto,Auto"
          ColumnSpacing="8"
          RowSpacing="6"
          Margin="0,10,0,6">
      <TextBlock Grid.Row="0" Grid.Column="0" Text="Live monitor" FontWeight="SemiBold" VerticalAlignment="Center" />
      <CheckBox Grid.Row="0" Grid.Column="4" Content="Errors only" IsChecked="{Binding ErrorsOnly}" />
      <CheckBox Grid.Row="0" Grid.Column="5" Content="Pause" IsChecked="{Binding IsPaused}" />
      <Button Grid.Row="0" Grid.Column="6" Content="Clear" Command="{Binding ClearMonitorCommand}" />
      <TextBox Grid.Row="1"
               Grid.Column="0"
               Text="{Binding FilterText}"
               PlaceholderText="filter: address, message…" />
      <ComboBox Grid.Row="1"
                Grid.Column="1"
                ItemsSource="{Binding MonitorDirectionOptions}"
                SelectedItem="{Binding SelectedMonitorDirection, Mode=TwoWay}" />
      <ComboBox Grid.Row="1"
                Grid.Column="2"
                ItemsSource="{Binding MonitorProtocolOptions}"
                SelectedItem="{Binding SelectedMonitorProtocol, Mode=TwoWay}" />
      <TextBox Grid.Row="1"
               Grid.Column="3"
               Text="{Binding DeviceFilterText}"
               PlaceholderText="device" />
    </Grid>

    <!-- Monitor list -->
    <Border Grid.Row="3" MinHeight="120" BorderBrush="#22808080" BorderThickness="1" CornerRadius="6">
      <ListBox ItemsSource="{Binding MonitorEntries}" Background="Transparent">
        <ListBox.ItemTemplate>
          <DataTemplate DataType="vm:ControlMonitorEntryViewModel">
            <Grid ColumnDefinitions="90,70,70,70,*" ColumnSpacing="8" Classes.error="{Binding IsError}">
              <TextBlock Grid.Column="0" Classes="col" Opacity="0.7" Text="{Binding Time}" />
              <TextBlock Grid.Column="1" Classes="col" Text="{Binding Protocol}" />
              <TextBlock Grid.Column="2" Classes="col" Opacity="0.85" Text="{Binding Direction}" />
              <TextBlock Grid.Column="3" Classes="col" Opacity="0.85" Text="{Binding Result}" />
              <TextBlock Grid.Column="4" Classes="col" Text="{Binding Summary}" TextTrimming="CharacterEllipsis" />
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Border>
  </Grid>
</UserControl>
