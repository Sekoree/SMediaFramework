<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="using:HaPlay.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:HaPlay.ViewModels"
             xmlns:res="using:HaPlay.Resources"
             xmlns:dock="using:Dock.Avalonia.Controls"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="680"
             x:Class="HaPlay.Views.ControlWorkspaceView"
             x:DataType="vm:ControlWorkspaceViewModel">
  <!-- The four dock panes' document VMs are mapped to their views in App.axaml's Application.DataTemplates
       (app-wide so Dock's recycling presenter and floated windows always resolve the right view). -->

  <!-- UI rewrite: the four tabs (Surfaces / Scripts / Monitor / Tools) became a Dock.Avalonia docking
       layout so they can be split, floated, or re-docked — watch the Monitor while editing Scripts. The
       arm bar + counts stay above the dock: global state must be visible from every pane. -->
  <Grid Margin="16" RowDefinitions="Auto,Auto,*">

    <!-- Arm + summary (global, always visible) -->
    <Border Grid.Row="0" Classes="Card" Margin="0,0,0,8">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="6">
        <Button Grid.Row="0" Grid.Column="0" Width="100"
                Content="{Binding ArmButtonText}" Command="{Binding ToggleArmCommand}" />
        <TextBlock Grid.Row="0" Grid.Column="1" VerticalAlignment="Center"
                   Text="{Binding StatusMessage}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
        <Button Grid.Row="0" Grid.Column="2"
                Content="Load…"
                ToolTip.Tip="{x:Static res:Strings.LoadControlConfigTooltip}"
                Command="{Binding LoadControlConfigCommand}" />
        <Button Grid.Row="0" Grid.Column="3"
                Content="Save"
                ToolTip.Tip="{x:Static res:Strings.SaveControlConfigTooltip}"
                Command="{Binding SaveControlConfigCommand}" />
        <Menu Grid.Row="0" Grid.Column="4" VerticalAlignment="Center" Padding="0">
          <MenuItem Header="{x:Static res:Strings.FilesMenuLabel}"
                    ToolTip.Tip="{x:Static res:Strings.ControlFilesMenuTooltip}">
            <MenuItem Header="{x:Static res:Strings.LoadControlConfigMenuHeader}"
                      Command="{Binding LoadControlConfigCommand}" />
            <MenuItem Header="{x:Static res:Strings.SaveControlConfigMenuHeader}"
                      Command="{Binding SaveControlConfigCommand}" />
            <MenuItem Header="{x:Static res:Strings.SaveControlConfigAsMenuHeader}"
                      Command="{Binding SaveControlConfigAsCommand}" />
            <MenuItem Header="{x:Static res:Strings.ImportLayerMenuHeader}"
                      Command="{Binding ImportLayerCommand}" />
          </MenuItem>
        </Menu>
        <!-- Add-script lives only on the Scripts tab now (next to the list). Tab pop-out is gone too — the
             Dock.Avalonia layout below floats/splits panes natively (drag a tab out of the dock). Reset layout
             brings every pane back to the default tabbed arrangement (the way back from a closed/floated pane). -->
        <Button Grid.Row="0" Grid.Column="6"
                Content="{x:Static res:Strings.ControlResetLayoutButton}"
                ToolTip.Tip="{x:Static res:Strings.ControlResetLayoutTooltip}"
                Command="{Binding ResetDockLayoutCommand}" />
        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal" Spacing="16" Opacity="0.85">
          <TextBlock Text="{Binding DeviceCount, StringFormat='Devices: {0}'}" />
          <TextBlock Text="{Binding ListenerCount, StringFormat='Listeners: {0}'}" />
          <TextBlock Text="{Binding LayerCount, StringFormat='Layers: {0}'}" />
          <TextBlock Text="{Binding ScriptCount, StringFormat='Scripts: {0}'}" />
        </StackPanel>
        <TextBlock Grid.Row="1" Grid.Column="4" Grid.ColumnSpan="2"
                   Text="{Binding ConfigFilePath}"
                   VerticalAlignment="Center"
                   Foreground="{StaticResource TextSecondary}"
                   TextTrimming="CharacterEllipsis"
                   ToolTip.Tip="{Binding ConfigFilePath}"
                   IsVisible="{Binding ConfigFilePath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
      </Grid>
    </Border>

    <!-- The four Control panes as a dockable layout (ControlDockFactory builds it on the VM). Drag a
         tab to split the pane or float it into its own window. ControlRecycling keys the pane views by
         dockable Id — without it the shared content presenter reuses one recycled view for every tab, so
         every pane rendered as Surfaces. -->
    <dock:DockControl Grid.Row="2" Layout="{Binding DockLayout}" />
  </Grid>
</UserControl>
