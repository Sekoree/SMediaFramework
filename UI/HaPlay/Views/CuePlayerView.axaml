<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:HaPlay.ViewModels"
             mc:Ignorable="d" d:DesignWidth="980" d:DesignHeight="760"
             x:Class="HaPlay.Views.CuePlayerView"
             x:DataType="vm:CuePlayerViewModel">
  <DockPanel LastChildFill="True">
    <Border DockPanel.Dock="Top"
            IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
            Background="#33C00000" BorderBrush="#88C00000" BorderThickness="1"
            CornerRadius="4" Padding="10,6" Margin="0,0,0,10">
      <TextBlock Text="{Binding StatusMessage}" Foreground="#FFE6E6" TextWrapping="Wrap" />
    </Border>

    <Grid DockPanel.Dock="Top" Margin="0,0,0,8" ColumnDefinitions="Auto,220,Auto,Auto,Auto,Auto,Auto,*" ColumnSpacing="6">
      <TextBlock Grid.Column="0" Text="Cue list" VerticalAlignment="Center" />
      <ComboBox Grid.Column="1"
                ItemsSource="{Binding CueLists}"
                SelectedItem="{Binding SelectedCueList, Mode=TwoWay}"
                MinWidth="180">
        <ComboBox.ItemTemplate>
          <DataTemplate DataType="vm:CueListEditorViewModel">
            <TextBlock Text="{Binding Name}" />
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
      <Button Grid.Column="2" Content="+ List" Command="{Binding AddCueListCommand}" />
      <Button Grid.Column="3" Content="Remove List" Command="{Binding RemoveCueListCommand}" />
      <Button Grid.Column="4" Content="Load…" Command="{Binding LoadCueListCommand}" />
      <Button Grid.Column="5" Content="Save" Command="{Binding SaveCueListCommand}" />
      <Button Grid.Column="6" Content="Save As…" Command="{Binding SaveCueListAsCommand}" />
    </Grid>

    <Grid DockPanel.Dock="Top" Margin="0,0,0,8" ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,*" ColumnSpacing="6">
      <Button Grid.Column="0" Content="+ Group" Command="{Binding AddGroupCommand}" />
      <Button Grid.Column="1" Content="+ Media" Command="{Binding AddMediaCueCommand}" />
      <Button Grid.Column="2" Content="+ Action" Command="{Binding AddActionCueCommand}" />
      <Button Grid.Column="3" Content="+ Comment" Command="{Binding AddCommentCueCommand}" />
      <Button Grid.Column="4" Content="Browse media…" Command="{Binding BrowseMediaSourceCommand}" />
      <Button Grid.Column="5" Content="Edit action…" Command="{Binding EditActionCueCommand}" />
      <Button Grid.Column="6" Content="Remove Node" Command="{Binding RemoveNodeCommand}" />
    </Grid>

    <Grid DockPanel.Dock="Top" Margin="0,0,0,8" ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,*" ColumnSpacing="6">
      <Button Grid.Column="0" Content="Standby Selected" Command="{Binding StandbySelectedCommand}" />
      <Button Grid.Column="1" Content="GO" Command="{Binding GoCommand}" />
      <Button Grid.Column="2" Content="Back" Command="{Binding BackCommand}" />
      <Button Grid.Column="3" Content="Pause" Command="{Binding PauseCommand}" />
      <Button Grid.Column="4" Content="Stop" Command="{Binding StopCommand}" />
      <Button Grid.Column="5" Content="Panic" Command="{Binding PanicCommand}" />
      <TextBlock Grid.Column="6" Text="{Binding TransportState}" VerticalAlignment="Center" Margin="8,0,0,0" />
    </Grid>

    <Grid ColumnDefinitions="3*,2*" ColumnSpacing="8">
      <TreeDataGrid Name="CueTreeGrid" Grid.Column="0" MinHeight="360" />

      <Grid Grid.Column="1" RowDefinitions="*,*" RowSpacing="8">
        <DockPanel Grid.Row="0">
          <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6" Margin="0,0,0,6">
            <TextBlock Grid.Column="0" Text="Virtual Outputs (VOut)" FontWeight="SemiBold" VerticalAlignment="Center" />
            <Button Grid.Column="1" Content="+ VOut" Command="{Binding AddVirtualOutputCommand}" />
            <Button Grid.Column="2" Content="Remove" Command="{Binding RemoveVirtualOutputCommand}" />
          </Grid>
          <TreeDataGrid Name="VirtualOutputsTreeGrid" MinHeight="140" />
        </DockPanel>

        <DockPanel Grid.Row="1">
          <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6" Margin="0,0,0,6">
            <TextBlock Grid.Column="0" Text="Cue Route Connections" FontWeight="SemiBold" VerticalAlignment="Center" />
            <Button Grid.Column="1" Content="+ Route" Command="{Binding AddRouteConnectionCommand}" />
            <Button Grid.Column="2" Content="Remove" Command="{Binding RemoveRouteConnectionCommand}" />
          </Grid>
          <TextBlock DockPanel.Dock="Top"
                     Margin="0,0,0,6"
                     FontSize="11"
                     Opacity="0.65"
                     TextWrapping="Wrap"
                     IsVisible="{Binding !HasSelectedMediaCue}"
                     Text="Select a media cue to edit per-cue route overrides." />
          <TreeDataGrid Name="CueRoutesTreeGrid"
                        MinHeight="140"
                        IsEnabled="{Binding HasSelectedMediaCue}" />
        </DockPanel>
      </Grid>
    </Grid>
  </DockPanel>
</UserControl>
