<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:HaPlay.ViewModels"
             xmlns:res="using:HaPlay.Resources"
             mc:Ignorable="d" d:DesignWidth="980" d:DesignHeight="760"
             x:Class="HaPlay.Views.CuePlayerView"
             x:DataType="vm:CuePlayerViewModel">
  <DockPanel LastChildFill="True">
    <Border DockPanel.Dock="Top"
            IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
            Background="#33C00000" BorderBrush="#88C00000" BorderThickness="1"
            CornerRadius="4" Padding="10,6" Margin="0,0,0,10">
      <TextBlock Text="{Binding StatusMessage}" Foreground="#FFE6E6" TextWrapping="Wrap" />
    </Border>

    <Grid DockPanel.Dock="Top" Margin="0,0,0,8" ColumnDefinitions="Auto,220,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*" ColumnSpacing="6">
      <TextBlock Grid.Column="0" Text="{x:Static res:Strings.CueListLabel}" VerticalAlignment="Center" />
      <ComboBox Grid.Column="1"
                ItemsSource="{Binding CueLists}"
                SelectedItem="{Binding SelectedCueList, Mode=TwoWay}"
                MinWidth="180">
        <ComboBox.ItemTemplate>
          <DataTemplate DataType="vm:CueListEditorViewModel">
            <TextBlock Text="{Binding Name}" />
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
      <Button Grid.Column="2" Content="{x:Static res:Strings.AddListButton}" Command="{Binding AddCueListCommand}" />
      <Button Grid.Column="3" Content="{x:Static res:Strings.RemoveListButton}" Command="{Binding RemoveCueListCommand}" />
      <Button Grid.Column="4" Content="{x:Static res:Strings.LoadButton}" Command="{Binding LoadCueListCommand}" />
      <Button Grid.Column="5" Content="{x:Static res:Strings.SaveButton}" Command="{Binding SaveCueListCommand}" />
      <Button Grid.Column="6" Content="{x:Static res:Strings.SaveAsButton}" Command="{Binding SaveCueListAsCommand}" />
      <TextBlock Grid.Column="7" Text="{x:Static res:Strings.PreRollNLabel}" VerticalAlignment="Center" ToolTip.Tip="{x:Static res:Strings.PreRollTooltip}" />
      <NumericUpDown Grid.Column="8"
                       Minimum="0"
                       Maximum="16"
                       Width="72"
                       IsEnabled="{Binding SelectedCueList, Converter={x:Static ObjectConverters.IsNotNull}}"
                       Value="{Binding SelectedCueList.PreRollCount, Mode=TwoWay}" />
    </Grid>

    <Grid DockPanel.Dock="Top" Margin="0,0,0,8" ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,*" ColumnSpacing="6">
      <Button Grid.Column="0" Content="{x:Static res:Strings.AddGroupButton}" Command="{Binding AddGroupCommand}" />
      <Button Grid.Column="1" Content="{x:Static res:Strings.AddMediaButton}" Command="{Binding AddMediaCueCommand}" />
      <Button Grid.Column="2" Content="{x:Static res:Strings.AddActionButton}" Command="{Binding AddActionCueCommand}" />
      <Button Grid.Column="3" Content="{x:Static res:Strings.AddCommentButton}" Command="{Binding AddCommentCueCommand}" />
      <Button Grid.Column="4" Content="{x:Static res:Strings.BrowseMediaButton}" Command="{Binding BrowseMediaSourceCommand}" />
      <Button Grid.Column="5" Content="{x:Static res:Strings.EditActionButton}" Command="{Binding EditActionCueCommand}" />
      <Button Grid.Column="6" Content="{x:Static res:Strings.RemoveNodeButton}" Command="{Binding RemoveNodeCommand}" />
    </Grid>

    <Grid DockPanel.Dock="Top" Margin="0,0,0,8" ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,*" ColumnSpacing="6">
      <Button Grid.Column="0" Content="{x:Static res:Strings.StandbySelectedButton}" Command="{Binding StandbySelectedCommand}" />
      <Button Grid.Column="1" Content="{x:Static res:Strings.GoButton}" Command="{Binding GoCommand}" />
      <Button Grid.Column="2" Content="{x:Static res:Strings.BackButton}" Command="{Binding BackCommand}" />
      <Button Grid.Column="3" Content="{x:Static res:Strings.PauseButton}" Command="{Binding PauseCommand}" />
      <Button Grid.Column="4" Content="{x:Static res:Strings.StopButton}" Command="{Binding StopCommand}" />
      <Button Grid.Column="5" Content="{x:Static res:Strings.PanicButton}" Command="{Binding PanicCommand}" />
      <TextBlock Grid.Column="6" Text="{Binding TransportState}" VerticalAlignment="Center" Margin="8,0,0,0" />
    </Grid>

    <Grid ColumnDefinitions="3*,2*" ColumnSpacing="8">
      <TreeDataGrid Name="CueTreeGrid" Grid.Column="0" MinHeight="360" />

      <Grid Grid.Column="1" RowDefinitions="Auto,Auto,*,*" RowSpacing="8">
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,*,Auto,*"
              ColumnSpacing="8"
              Margin="0,0,0,4"
              IsVisible="{Binding HasSelectedMediaCue}">
          <TextBlock Grid.Column="0" Text="{x:Static res:Strings.FadeInMsLabel}" VerticalAlignment="Center" />
          <NumericUpDown Grid.Column="1"
                         Minimum="0"
                         Maximum="120000"
                         Width="100"
                         Value="{Binding SelectedCueNode.FadeInMs, Mode=TwoWay}" />
          <TextBlock Grid.Column="2" Text="{x:Static res:Strings.FadeOutMsLabel}" VerticalAlignment="Center" />
          <NumericUpDown Grid.Column="3"
                         Minimum="0"
                         Maximum="120000"
                         Width="100"
                         Value="{Binding SelectedCueNode.FadeOutMs, Mode=TwoWay}" />
        </Grid>
        <Grid Grid.Row="1"
              ColumnDefinitions="Auto,*,Auto,Auto,*"
              ColumnSpacing="8"
              Margin="0,0,0,4"
              IsVisible="{Binding HasSelectedMediaCue}">
          <TextBlock Grid.Column="0" Text="{x:Static res:Strings.StartMsLabel}" VerticalAlignment="Center" />
          <NumericUpDown Grid.Column="1"
                         Minimum="0"
                         Maximum="86400000"
                         Width="100"
                         Value="{Binding SelectedCueNode.StartOffsetMs, Mode=TwoWay}" />
          <CheckBox Grid.Column="2" Content="{x:Static res:Strings.LoopLabel}" VerticalAlignment="Center"
                    IsChecked="{Binding SelectedCueNode.Loop, Mode=TwoWay}" />
          <TextBlock Grid.Column="3" Text="{x:Static res:Strings.EndLabel}" VerticalAlignment="Center" />
          <ComboBox Grid.Column="4"
                    MinWidth="140"
                    ItemsSource="{Binding CueEndBehaviors}"
                    SelectedItem="{Binding SelectedCueNode.EndBehavior, Mode=TwoWay}" />
        </Grid>
        <DockPanel Grid.Row="2">
          <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6" Margin="0,0,0,6">
            <TextBlock Grid.Column="0" Text="{x:Static res:Strings.VirtualOutputsHeader}" FontWeight="SemiBold" VerticalAlignment="Center" />
            <Button Grid.Column="1" Content="{x:Static res:Strings.AddVoutButton}" Command="{Binding AddVirtualOutputCommand}" />
            <Button Grid.Column="2" Content="{x:Static res:Strings.RemoveButton}" Command="{Binding RemoveVirtualOutputCommand}" />
          </Grid>
          <TreeDataGrid Name="VirtualOutputsTreeGrid" MinHeight="140" />
        </DockPanel>

        <DockPanel Grid.Row="3">
          <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6" Margin="0,0,0,6">
            <TextBlock Grid.Column="0" Text="{x:Static res:Strings.CueRouteConnectionsHeader}" FontWeight="SemiBold" VerticalAlignment="Center" />
            <Button Grid.Column="1" Content="{x:Static res:Strings.AddRouteButton}" Command="{Binding AddRouteConnectionCommand}" />
            <Button Grid.Column="2" Content="{x:Static res:Strings.RemoveButton}" Command="{Binding RemoveRouteConnectionCommand}" />
          </Grid>
          <TextBlock DockPanel.Dock="Top"
                     Margin="0,0,0,6"
                     FontSize="11"
                     Opacity="0.65"
                     TextWrapping="Wrap"
                     IsVisible="{Binding !HasSelectedMediaCue}"
                     Text="{x:Static res:Strings.SelectMediaCueHint}" />
          <TreeDataGrid Name="CueRoutesTreeGrid"
                        MinHeight="140"
                        IsEnabled="{Binding HasSelectedMediaCue}" />
        </DockPanel>
      </Grid>
    </Grid>
  </DockPanel>
</UserControl>
