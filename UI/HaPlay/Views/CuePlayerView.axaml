<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="using:HaPlay.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:HaPlay.ViewModels"
             xmlns:res="using:HaPlay.Resources"
             xmlns:models="using:HaPlay.Models"
             xmlns:controls="using:HaPlay.Views.Controls"
             mc:Ignorable="d" d:DesignWidth="980" d:DesignHeight="760"
             x:Class="HaPlay.Views.CuePlayerView"
             x:DataType="vm:CuePlayerViewModel">
  <UserControl.Styles>
    <!-- Now Playing position readout + its low-time warning (same look as the deck clock's
         warning). Styled via classes so the warning can override the dimmed idle opacity. -->
    <Style Selector="TextBlock.postime">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Opacity" Value="0.7" />
    </Style>
    <Style Selector="TextBlock.postime.lowtime">
      <Setter Property="Foreground" Value="#E53935" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Opacity" Value="1" />
    </Style>
  </UserControl.Styles>
  <DockPanel LastChildFill="True">
    <!-- Status messages surface via the MainView toast overlay (ToastCenter) - the old inline
         banner here resized the whole panel on every message and caused misclicks. -->

    <!-- Cue-list header: everything LIST-scoped lives on this row (name, add/remove, files,
         output setup, settings). Load/Save live only in the Files flyout (they used to ALSO be
         standalone buttons here - the duplication just widened an already busy row). The flyout is
         a Button like its neighbours, not a Menu - a menu bar item has its own chrome and its
         label never lined up with the buttons beside it. -->
    <Grid DockPanel.Dock="Top" Margin="0,0,0,8" ColumnDefinitions="Auto,160,*,Auto,Auto,Auto,Auto,Auto,*" ColumnSpacing="6">
      <TextBlock Grid.Column="0" Text="{x:Static res:Strings.CueListLabel}" VerticalAlignment="Center" />
      <ComboBox Grid.Column="1"
                ItemsSource="{Binding CueLists}"
                SelectedItem="{Binding SelectedCueList, Mode=TwoWay}"
                MinWidth="140">
        <ComboBox.ItemTemplate>
          <DataTemplate DataType="vm:CueListEditorViewModel">
            <TextBlock Text="{Binding Name}" />
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
      <TextBox Grid.Column="2"
               MinWidth="120"
               Text="{Binding SelectedCueList.Name, Mode=TwoWay}"
               PlaceholderText="{x:Static res:Strings.CueListNameWatermark}"
               ToolTip.Tip="{x:Static res:Strings.CueListNameTooltip}"
               IsEnabled="{Binding SelectedCueList, Converter={x:Static ObjectConverters.IsNotNull}}" />
      <Button Grid.Column="3" Content="{x:Static res:Strings.AddListButton}" Command="{Binding AddCueListCommand}" />
      <Button Grid.Column="4" Content="{x:Static res:Strings.RemoveListButton}" Command="{Binding RemoveCueListCommand}" />
      <Button Grid.Column="5" ToolTip.Tip="{x:Static res:Strings.CueListFilesMenuTooltip}">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <TextBlock Text="{x:Static res:Strings.FilesMenuLabel}" VerticalAlignment="Center" />
          <TextBlock Text="&#x25BE;" FontSize="10" Opacity="0.7" VerticalAlignment="Center" />
        </StackPanel>
        <Button.Flyout>
          <MenuFlyout>
            <MenuItem Header="{x:Static res:Strings.LoadButton}" Command="{Binding LoadCueListCommand}" />
            <MenuItem Header="{x:Static res:Strings.SaveButton}" Command="{Binding SaveCueListCommand}" />
            <MenuItem Header="{x:Static res:Strings.SaveAsButton}" Command="{Binding SaveCueListAsCommand}" />
            <Separator />
            <MenuItem Header="{x:Static res:Strings.LoadAllCueListsMenuHeader}"
                      Command="{Binding LoadAllCueListsCommand}" />
            <MenuItem Header="{x:Static res:Strings.SaveAllCueListsMenuHeader}"
                      Command="{Binding SaveAllCueListsCommand}" />
            <MenuItem Header="{x:Static res:Strings.SaveAllCueListsAsMenuHeader}"
                      Command="{Binding SaveAllCueListsAsCommand}" />
            <Separator />
            <MenuItem Header="{x:Static res:Strings.ExportCompositionsMenuHeader}"
                      Command="{Binding ExportCompositionsCommand}" />
            <MenuItem Header="{x:Static res:Strings.ImportCompositionsMenuHeader}"
                      Command="{Binding ImportCompositionsCommand}" />
          </MenuFlyout>
        </Button.Flyout>
      </Button>
      <!-- List-level output routing - lives here with the other list-scoped controls (it needs a
           selected list), not in the cue-authoring row below. -->
      <Button Grid.Column="6"
              Content="{x:Static res:Strings.CueOutputSetupButton}"
              Command="{Binding OpenCueOutputSetupCommand}" />
      <Button Grid.Column="7"
              ToolTip.Tip="{x:Static res:Strings.CueListSettingsTooltip}"
              AutomationProperties.Name="{x:Static res:Strings.CueListSettingsTooltip}"
              Command="{Binding OpenCueListSettingsCommand}">
        <PathIcon Data="{x:Static views:AppIcons.Gear}" Width="13" Height="13" />
      </Button>
      <TextBlock Grid.Column="8"
                 Text="{Binding DisplayedCueFilePath}"
                 VerticalAlignment="Center"
                 Foreground="{DynamicResource TextSecondary}"
                 TextTrimming="CharacterEllipsis"
                 ToolTip.Tip="{Binding DisplayedCueFilePath}"
                 IsVisible="{Binding DisplayedCueFilePath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
    </Grid>

    <!-- Cue-authoring row: everything that EDITS the list, with the edit-mode gate on the same
         row (it used to sit among the transport buttons, where a mid-show mode flip is one
         mis-tap from GO). The whole row disables when Edit cues is off, so nothing can modify
         the list mid-show. The visible Remove button is the single remove surface - it was also
         duplicated inside the "Selected cue…" flyout two buttons away. -->
    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8" LastChildFill="False">
      <Button DockPanel.Dock="Left" Content="{x:Static res:Strings.AddCueMenuButton}"
              IsEnabled="{Binding IsCueEditMode}">
        <Button.Flyout>
          <MenuFlyout>
            <MenuItem Header="{x:Static res:Strings.AddGroupButton}" Command="{Binding AddGroupCommand}" />
            <MenuItem Header="{x:Static res:Strings.AddMediaButton}" Command="{Binding AddMediaCueCommand}" />
            <MenuItem Header="{x:Static res:Strings.AddImageButton}" Command="{Binding AddImageCueCommand}" />
            <MenuItem Header="{x:Static res:Strings.AddTextButton}" Command="{Binding AddTextCueCommand}" />
            <MenuItem Header="{x:Static res:Strings.AddSubtitleCueButton}" Command="{Binding AddSubtitleCueCommand}" />
            <Separator />
            <MenuItem Header="{x:Static res:Strings.AddNDIInputCueButton}"
                      Command="{Binding AddNDIInputCueCommand}"
                      IsVisible="{Binding IsNDIAvailable}" />
            <MenuItem Header="{x:Static res:Strings.AddPortAudioInputCueButton}" Command="{Binding AddPortAudioInputCueCommand}" />
            <MenuItem Header="{x:Static res:Strings.AddYouTubeMenuItem}" Command="{Binding AddYouTubeCueCommand}" />
            <MenuItem Header="{x:Static res:Strings.AddMMDMenuItem}" Command="{Binding AddMMDCueCommand}" />
            <Separator />
            <MenuItem Header="{x:Static res:Strings.AddActionButton}" Command="{Binding AddActionCueCommand}" />
            <MenuItem Header="{x:Static res:Strings.AddCommentButton}" Command="{Binding AddCommentCueCommand}" />
            <MenuItem Header="{x:Static res:Strings.AddVisualizerCueButton}" Command="{Binding AddVisualizerCueCommand}"
                      ToolTip.Tip="Starts (or stops) the projectM visualizer as a placeable layer on a composition - position/size and audio-feed routing in the drawer. It keeps running across later cues until a Stop visualizer cue." />
            <MenuItem Header="{x:Static res:Strings.AddJumpCueButton}" Command="{Binding AddJumpCueCommand}"
                      ToolTip.Tip="Adds a control-flow cue that jumps the playhead to its target cue(s) - select the loop-back target first. Random mode picks one of several targets." />
          </MenuFlyout>
        </Button.Flyout>
      </Button>
      <Button DockPanel.Dock="Left" Margin="6,0,0,0" Content="{x:Static res:Strings.CueSelectionMenuButton}"
              IsEnabled="{Binding IsCueEditMode}">
        <Button.Flyout>
          <MenuFlyout>
            <MenuItem Header="{x:Static res:Strings.BrowseMediaButton}" Command="{Binding BrowseMediaSourceCommand}" />
            <MenuItem Header="{x:Static res:Strings.EditActionButton}" Command="{Binding EditActionCueCommand}" />
            <Separator />
            <MenuItem Header="{x:Static res:Strings.ReorganizeCueListButton}"
                      Command="{Binding ReorganizeCueListCommand}"
                      ToolTip.Tip="{x:Static res:Strings.ReorganizeCueListTooltip}" />
            <MenuItem Header="{x:Static res:Strings.RenumberButton}" Command="{Binding RenumberCommand}" />
          </MenuFlyout>
        </Button.Flyout>
      </Button>
      <Button DockPanel.Dock="Left"
              Margin="6,0,0,0"
              Content="{x:Static res:Strings.RemoveNodeButton}"
              Command="{Binding RemoveNodeCommand}"
              IsEnabled="{Binding IsCueEditMode}" />
      <ToggleSwitch DockPanel.Dock="Right"
                    Content="{x:Static res:Strings.EditCuesToggleLabel}"
                    ToolTip.Tip="{x:Static res:Strings.EditCuesToggleTooltip}"
                    IsChecked="{Binding IsCueEditMode, Mode=TwoWay}" />
    </DockPanel>

    <!-- Transport. GO is the show's primary action - keep it visually dominant; the tooltips double
         as the keyboard-shortcut reference for the code-behind transport bindings. Panic is the
         panic-path exit and wears Danger red, same as the media deck's Stop. -->
    <Grid DockPanel.Dock="Top" Margin="0,0,0,8" ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*" ColumnSpacing="6">
      <Button Grid.Column="0" Content="{x:Static res:Strings.StandbySelectedButton}"
              Command="{Binding StandbySelectedCommand}"
              ToolTip.Tip="{x:Static res:Strings.CueTransportStandbyTooltip}" />
      <Button Grid.Column="1" Content="{x:Static res:Strings.GoButton}"
              Classes="Touch Go" MinWidth="96"
              Command="{Binding GoCommand}"
              ToolTip.Tip="{x:Static res:Strings.CueTransportGoTooltip}" />
      <Button Grid.Column="2" Content="{x:Static res:Strings.BackButton}"
              Command="{Binding BackCommand}"
              ToolTip.Tip="{x:Static res:Strings.CueTransportBackTooltip}" />
      <Button Grid.Column="3" Content="{x:Static res:Strings.PauseButton}"
              Command="{Binding PauseCommand}"
              ToolTip.Tip="{x:Static res:Strings.CueTransportPauseTooltip}" />
      <Button Grid.Column="4" Content="{x:Static res:Strings.StopButton}"
              Command="{Binding StopCommand}"
              ToolTip.Tip="{x:Static res:Strings.CueTransportStopTooltip}" />
      <Button Grid.Column="5" Content="{x:Static res:Strings.PanicButton}"
              Classes="Touch Danger"
              Command="{Binding PanicCommand}"
              ToolTip.Tip="{x:Static res:Strings.CueTransportPanicTooltip}" />
      <!-- State chip, same palette as the deck's state pill: green running, amber paused or
           standby-armed, gray idle - readable across a booth without parsing the text. -->
      <Border Grid.Column="6" Classes="Chip" Margin="8,0,0,0" HorizontalAlignment="Left"
              Background="{Binding TransportStateColor}">
        <TextBlock FontSize="11" FontWeight="SemiBold" Text="{Binding TransportState}"
                   TextTrimming="CharacterEllipsis" />
      </Border>
    </Grid>

    <DockPanel LastChildFill="True">
      <Expander DockPanel.Dock="Bottom"
                Classes="dense"
                Margin="0,4,0,0"
                IsExpanded="True"
                Header="{Binding SelectedCueDrawerTitle}"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch">
        <StackPanel>
        <TextBlock Margin="6,4,6,8"
                   Text="{x:Static res:Strings.CueDetailsEmptyHint}"
                   TextWrapping="Wrap"
                   Opacity="0.65"
                   IsVisible="{Binding !HasSelectedCue}" />
        <!-- MaxHeight caps the bottom drawer so a tall tab (e.g. several video placements) can't push it
             out of the window; each tab's content is in a ScrollViewer, which then scrolls within the cap. -->
        <TabControl x:Name="CueDrawerTabs" Classes="Segmented" Margin="0,4,0,0" MinHeight="220" MaxHeight="440"
                    IsVisible="{Binding HasSelectedCue}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch">
          <TabItem Header="{x:Static res:Strings.GeneralTabLabel}"
                   IsVisible="{Binding HasSelectedCue}">
            <ScrollViewer>
              <StackPanel Spacing="8" Margin="6">
                <!-- ONE shared grid for the whole settings form: the old per-row grids each
                     auto-sized their own label column, so labels and editors never lined up
                     between rows. A row collapses to zero height when its cue-kind hides all
                     its children. -->
                <Grid ColumnDefinitions="Auto,170,Auto,170"
                      RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                      ColumnSpacing="8" RowSpacing="8">
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static res:Strings.CueTreeNumberColumnHeader}" VerticalAlignment="Center" />
                  <TextBox Grid.Row="0" Grid.Column="1"
                           Text="{Binding SelectedCueNumber, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                  <TextBlock Grid.Row="0" Grid.Column="2" Text="{x:Static res:Strings.CueTreeNameColumnHeader}" VerticalAlignment="Center" />
                  <TextBox Grid.Row="0" Grid.Column="3"
                           Text="{Binding SelectedCueLabel, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />

                  <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static res:Strings.StartTriggerLabel}" VerticalAlignment="Center" />
                  <ComboBox Grid.Row="1" Grid.Column="1"
                            ItemsSource="{Binding CueTriggerModes}"
                            SelectedItem="{Binding SelectedCueNode.TriggerMode, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding Converter={x:Static vm:EnumDisplayConverter.Instance}}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                  <TextBlock Grid.Row="1" Grid.Column="2" Text="{x:Static res:Strings.PreWaitLabel}" VerticalAlignment="Center" />
                  <NumericUpDown FormatString="0" Grid.Row="1" Grid.Column="3"
                                 Minimum="0"
                                 Maximum="120000"
                                 Value="{Binding SelectedCueNode.PreWaitMs, Mode=TwoWay}" />

                  <TextBlock Grid.Row="2" Grid.Column="0" Text="{x:Static res:Strings.FadeInMsLabel}" VerticalAlignment="Center"
                             IsVisible="{Binding HasSelectedMediaCue}" />
                  <NumericUpDown FormatString="0" Grid.Row="2" Grid.Column="1"
                                 Minimum="0"
                                 Maximum="120000"
                                 IsVisible="{Binding HasSelectedMediaCue}"
                                 Value="{Binding SelectedMediaCue.FadeInMs, Mode=TwoWay}" />
                  <TextBlock Grid.Row="2" Grid.Column="2" Text="{x:Static res:Strings.FadeOutMsLabel}" VerticalAlignment="Center"
                             IsVisible="{Binding HasSelectedMediaCue}" />
                  <NumericUpDown FormatString="0" Grid.Row="2" Grid.Column="3"
                                 Minimum="0"
                                 Maximum="120000"
                                 IsVisible="{Binding HasSelectedMediaCue}"
                                 Value="{Binding SelectedMediaCue.FadeOutMs, Mode=TwoWay}" />

                  <TextBlock Grid.Row="3" Grid.Column="0" Text="{x:Static res:Strings.StartMsLabel}" VerticalAlignment="Center"
                             IsVisible="{Binding HasSelectedMediaCue}" />
                  <TextBox Grid.Row="3" Grid.Column="1"
                           Text="{Binding SelectedMediaCue.StartOffsetTimeText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                           PlaceholderText="00:00:00.000"
                           TextAlignment="Right"
                           IsVisible="{Binding HasSelectedMediaCue}" />
                  <TextBlock Grid.Row="3" Grid.Column="2" Text="{x:Static res:Strings.EndTrimMsLabel}" VerticalAlignment="Center"
                             IsVisible="{Binding HasSelectedMediaCue}" />
                  <TextBox Grid.Row="3" Grid.Column="3"
                           Text="{Binding SelectedMediaCue.EndOffsetTimeText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                           PlaceholderText="00:00:00.000"
                           TextAlignment="Right"
                           IsVisible="{Binding HasSelectedMediaCue}" />

                  <TextBlock Grid.Row="4" Grid.Column="0" Text="{x:Static res:Strings.HoldDurationLabel}" VerticalAlignment="Center"
                             IsVisible="{Binding HasSelectedStaticCue}" />
                  <TextBox Grid.Row="4" Grid.Column="1"
                           Text="{Binding SelectedStaticCue.DurationTimeText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                           PlaceholderText="00:00:05.000"
                           TextAlignment="Right"
                           IsVisible="{Binding HasSelectedStaticCue}" />
                  <TextBlock Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="2"
                             VerticalAlignment="Center" Opacity="0.55" FontSize="11"
                             IsVisible="{Binding HasSelectedStaticCue}"
                             Text="{x:Static res:Strings.DurationFormatHint}" />

                  <CheckBox Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                            Content="{x:Static res:Strings.LoopLabel}" VerticalAlignment="Center"
                            IsVisible="{Binding HasSelectedMediaCue}"
                            IsChecked="{Binding SelectedMediaCue.Loop, Mode=TwoWay}" />
                  <TextBlock Grid.Row="5" Grid.Column="2" Text="{x:Static res:Strings.EndLabel}" VerticalAlignment="Center"
                             IsVisible="{Binding HasSelectedMediaCue}" />
                  <ComboBox Grid.Row="5" Grid.Column="3"
                            IsVisible="{Binding HasSelectedMediaCue}"
                            ItemsSource="{Binding CueEndBehaviors}"
                            SelectedItem="{Binding SelectedMediaCue.EndBehavior, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding Converter={x:Static vm:EnumDisplayConverter.Instance}}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                </Grid>

                <!-- Custom natural-end trigger. The target can itself be a random Jump cue, keeping
                     large random-song pools compact. Empty uses the normal Auto Follow chain. -->
                <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding HasSelectedMediaCue}"
                            ToolTip.Tip="{x:Static res:Strings.EndTriggerTargetTooltip}">
                  <TextBlock Text="{x:Static res:Strings.EndTriggerTargetLabel}" VerticalAlignment="Center" />
                  <TextBox Width="90" Text="{Binding SelectedEndTargetText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                           PlaceholderText="Cue no. (default)" />
                </StackPanel>

                <!-- Preview + scrubbing live ONLY on the Preview tab now - this tab used to carry
                     a second Preview button and a bare scrubber, and the duplicate was the one
                     whose seeks actually committed (the Preview tab's copy silently didn't). -->
                <!-- Media FX send (#26): this cue's audio also drives a selective-feed visualizer. -->
                <CheckBox Content="FX: send audio to visualizer (when a visualizer cue with selective feed is running)"
                          IsVisible="{Binding SelectedAudioCue, Converter={x:Static ObjectConverters.IsNotNull}}"
                          IsChecked="{Binding SelectedAudioCue.SendToVisualizer, Mode=TwoWay}" />

                <!-- Jump-cue editor (#27): targets entered as cue NUMBERS (stored as stable IDs, so
                     renumber/reorder never retargets), plus random-pick and fire/standby. -->
                <StackPanel Spacing="6" IsVisible="{Binding IsJumpCueSelected}">
                  <TextBlock Text="{x:Static res:Strings.CueJumpTargetsLabel}" FontWeight="SemiBold" />
                  <TextBox Text="{Binding SelectedJumpTargetsText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                           PlaceholderText="e.g. 3, 7, 12" />
                  <CheckBox Content="{x:Static res:Strings.CueJumpRandomLabel}"
                            IsChecked="{Binding SelectedJumpRandom, Mode=TwoWay}" />
                  <CheckBox Content="{x:Static res:Strings.CueJumpAvoidRepeatLabel}"
                            IsEnabled="{Binding SelectedJumpRandom}"
                            IsChecked="{Binding SelectedJumpAvoidImmediateRepeat, Mode=TwoWay}" />
                  <CheckBox Content="{x:Static res:Strings.CueJumpFireLabel}"
                            IsChecked="{Binding SelectedJumpFiresTarget, Mode=TwoWay}" />
                </StackPanel>

                                <TextBlock Text="{x:Static res:Strings.NotesLabel}" />
                <TextBox AcceptsReturn="True"
                         MinHeight="60"
                         TextWrapping="Wrap"
                         Text="{Binding SelectedCueNode.Notes, Mode=TwoWay}" />
                <TextBlock Text="{x:Static res:Strings.ColorTagLabel}" Margin="0,6,0,0" />
                <ItemsControl ItemsSource="{Binding ColorTagSwatches}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel Orientation="Horizontal" Spacing="4" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:CueColorSwatchViewModel">
                      <Button Command="{Binding $parent[UserControl].((vm:CuePlayerViewModel)DataContext).SetSelectedCueColorTagCommand}"
                              CommandParameter="{Binding Index}"
                              Width="22" Height="22" Padding="0" BorderThickness="1"
                              BorderBrush="{Binding BorderBrush}"
                              ToolTip.Tip="{Binding Name}">
                        <Rectangle Width="14" Height="14" Fill="{Binding FillBrush}" />
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </ScrollViewer>
          </TabItem>

          <TabItem Header="{x:Static res:Strings.CuePreviewTabLabel}"
                   IsVisible="{Binding HasSelectedMediaCue}">
            <DockPanel Margin="6">
              <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,Auto,Auto,*" ColumnSpacing="8" Margin="0,0,0,8">
                <Button Grid.Column="0" Content="{Binding PreviewButtonLabel}"
                        Command="{Binding TogglePreviewCommand}" />
                <TextBlock Grid.Column="1" Text="{x:Static res:Strings.PreviewOutputLabel}"
                           VerticalAlignment="Center" Opacity="0.7" />
                <ComboBox Grid.Column="2" MinWidth="200"
                          ItemsSource="{Binding PreviewAudioDevices}"
                          SelectedItem="{Binding SelectedPreviewAudioDevice}" />
                <TextBlock Grid.Column="3" Opacity="0.5" FontSize="12" VerticalAlignment="Center"
                           Text="{x:Static res:Strings.CuePreviewWaveformHint}" />
              </Grid>
              <!-- The single preview/scrub surface: waveform when the cue has audio, the no-audio
                   hint in the same box otherwise - the scrubber stays available either way (it
                   used to vanish with the waveform, leaving video-only cues unseekable here). -->
              <Border DockPanel.Dock="Top" Height="80" Margin="0,0,0,8">
                <Grid>
                  <controls:WaveformControl
                      IsVisible="{Binding HasSelectedCueWaveform}"
                      Peaks="{Binding SelectedCueWaveform}"
                      Revision="{Binding SelectedCueWaveformRevision}" />
                  <TextBlock Opacity="0.55" FontSize="12"
                             HorizontalAlignment="Center" VerticalAlignment="Center"
                             IsVisible="{Binding !HasSelectedCueWaveform}"
                             Text="{x:Static res:Strings.CuePreviewNoAudioHint}" />
                  <Slider Name="CuePreviewScrubber"
                          Minimum="0" Maximum="1000"
                          Value="{Binding CueScrubberValue, Mode=TwoWay}"
                          IsVisible="{Binding IsCueScrubberVisible}"
                          ToolTip.Tip="{x:Static res:Strings.SeekSliderTooltip}"
                          Opacity="0.6" />
                </Grid>
              </Border>
            </DockPanel>
          </TabItem>

          <TabItem Header="{x:Static res:Strings.AudioTabLabel}"
                   IsVisible="{Binding HasSelectedMediaCueWithAudio}">
            <ScrollViewer>
              <StackPanel Margin="6" Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="{x:Static res:Strings.AudioTabSourceLabel}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding SelectedAudioCue.SourceAudioChannels, StringFormat={x:Static res:Strings.AudioChannelCountFormat}}"
                             IsVisible="{Binding SelectedAudioCue.SourceHasAudio}" />
                  <TextBlock Text="{x:Static res:Strings.AudioSourceHasNoneLabel}"
                             Opacity="0.65"
                             IsVisible="{Binding !SelectedAudioCue.SourceHasAudio}" />
                </StackPanel>
                <!-- Multi-track sources (MKV with several languages): pick which audio track the cue
                     plays. Hidden for single-track files - most cues never see this row. -->
                <StackPanel Orientation="Horizontal" Spacing="6"
                            IsVisible="{Binding SelectedAudioCue.HasMultipleAudioTracks, FallbackValue=False}"
                            ToolTip.Tip="{x:Static res:Strings.AudioTrackTooltip}">
                  <TextBlock Text="{x:Static res:Strings.AudioTrackLabel}" FontWeight="SemiBold"
                             VerticalAlignment="Center" />
                  <ComboBox MinWidth="260"
                            ItemsSource="{Binding SelectedAudioCue.AudioTrackChoices}"
                            SelectedItem="{Binding SelectedAudioCue.SelectedAudioTrackChoice, Mode=TwoWay}" />
                </StackPanel>
                <Border Background="{DynamicResource ChipNeutral}" BorderBrush="#44808080" BorderThickness="1"
                        CornerRadius="0" Padding="6,3"
                        IsVisible="{Binding IsMultiSelected}">
                  <TextBlock TextWrapping="Wrap"
                             Text="{Binding SelectedCueCount, StringFormat={x:Static res:Strings.MultiSelectAudioBannerFormat}}" />
                </Border>
                <WrapPanel ItemSpacing="6">
                  <Button Content="{x:Static res:Strings.AddAudioRouteButton}" Command="{Binding AddAudioRouteCommand}" />
                  <Button Content="{x:Static res:Strings.RemoveButton}" Command="{Binding RemoveAudioRouteCommand}" />
                </WrapPanel>
                <!-- Downmix quick-apply: replaces the target line's routes; ignored if the preset
                     doesn't fit the source/output channel count. -->
                <WrapPanel ItemSpacing="6" IsVisible="{Binding HasSelectedMediaCue}"
                           ToolTip.Tip="{x:Static res:Strings.DownmixPresetsTooltip}">
                  <TextBlock Text="{x:Static res:Strings.DownmixPresetsLabel}" Opacity="0.6"
                             FontSize="11" VerticalAlignment="Center" />
                  <Button Content="{x:Static res:Strings.DownmixPassThroughButton}" Padding="6,2" FontSize="11"
                          Command="{Binding ApplyCueDownmixPresetCommand}"
                          CommandParameter="{x:Static models:AudioDownmixPreset.PassThrough}" />
                  <Button Content="{x:Static res:Strings.DownmixMonoToStereoButton}" Padding="6,2" FontSize="11"
                          Command="{Binding ApplyCueDownmixPresetCommand}"
                          CommandParameter="{x:Static models:AudioDownmixPreset.MonoToStereo}" />
                  <Button Content="{x:Static res:Strings.DownmixSurround51ToStereoButton}" Padding="6,2" FontSize="11"
                          Command="{Binding ApplyCueDownmixPresetCommand}"
                          CommandParameter="{x:Static models:AudioDownmixPreset.Surround51ToStereo}" />
                  <Button Content="{x:Static res:Strings.DownmixDropLfeButton}" Padding="6,2" FontSize="11"
                          Command="{Binding ApplyCueDownmixPresetCommand}"
                          CommandParameter="{x:Static models:AudioDownmixPreset.DropLfe}" />
                  <Button Content="{x:Static res:Strings.MatrixPresetLoadButton}" Padding="6,2" FontSize="11"
                          Command="{Binding LoadCueMixPresetCommand}"
                          ToolTip.Tip="{x:Static res:Strings.MatrixPresetLoadTitle}" />
                </WrapPanel>
                <TextBlock Opacity="0.65"
                           TextWrapping="Wrap"
                           Text="{x:Static res:Strings.NoAudioRoutesHint}"
                           IsVisible="{Binding VisibleAudioRoutes.Count, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=0}" />
                <ListBox ItemsSource="{Binding VisibleAudioRoutes}"
                         SelectedItem="{Binding SelectedAudioRoute, Mode=TwoWay}">
                  <ListBox.ItemTemplate>
                    <DataTemplate DataType="vm:CueAudioRouteViewModel">
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <Ellipse Width="9" Height="9" VerticalAlignment="Center"
                                 Fill="{Binding LineRef.HealthColor, FallbackValue=#666666}"
                                 ToolTip.Tip="{Binding LineRef.HealthToolTip}" />
                        <TextBlock Text="{x:Static res:Strings.SrcChLabel}" VerticalAlignment="Center" />
                        <NumericUpDown FormatString="0" Value="{Binding SourceChannel, Mode=TwoWay}" Minimum="0" Maximum="63" />
                        <TextBlock Text="{x:Static res:Strings.RouteOutputLabel}" VerticalAlignment="Center" />
                        <ComboBox SelectedValue="{Binding OutputLineId, Mode=TwoWay}"
                                  SelectedValueBinding="{Binding Definition.Id}"
                                  ItemsSource="{Binding $parent[UserControl].((vm:CuePlayerViewModel)DataContext).AvailableAudioOutputs}"
                                  MinWidth="200">
                          <ComboBox.ItemTemplate>
                            <DataTemplate DataType="vm:OutputLineViewModel">
                              <StackPanel Orientation="Horizontal" Spacing="6">
                                <Ellipse Width="9" Height="9" VerticalAlignment="Center"
                                         Fill="{Binding HealthColor}"
                                         ToolTip.Tip="{Binding HealthToolTip}" />
                                <TextBlock Text="{Binding Definition.EffectiveName}" VerticalAlignment="Center" />
                              </StackPanel>
                            </DataTemplate>
                          </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock Text="{x:Static res:Strings.OutChLabel}" VerticalAlignment="Center" />
                        <NumericUpDown FormatString="0" Value="{Binding OutputChannel, Mode=TwoWay}" Minimum="1" Maximum="64" />
                        <TextBlock Text="{x:Static res:Strings.GainDbLabel}" VerticalAlignment="Center" />
                        <NumericUpDown Value="{Binding GainDb, Mode=TwoWay}" Minimum="-60" Maximum="12" Increment="0.5" FormatString="0.#" />
                        <CheckBox Content="{x:Static res:Strings.CueRouteMuteShortLabel}" IsChecked="{Binding Muted, Mode=TwoWay}" VerticalAlignment="Center" />
                      </StackPanel>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </StackPanel>
            </ScrollViewer>
          </TabItem>

          <TabItem Header="{x:Static res:Strings.VideoTabLabel}"
                   IsVisible="{Binding HasSelectedMediaCueWithVideo}">
            <ScrollViewer>
              <StackPanel Spacing="8" Margin="6">
                <Border Background="#22FFA500" BorderBrush="#44FFA500" BorderThickness="1"
                        CornerRadius="0" Padding="6,3"
                        IsVisible="{Binding HasSelectedMediaCueWithAttachedPictureOnly}">
                  <TextBlock TextWrapping="Wrap"
                             Text="{x:Static res:Strings.VideoTabAttachedPictureHint}" />
                </Border>
                <Border Background="#22FF8080" BorderBrush="#44FF8080" BorderThickness="1"
                        CornerRadius="0" Padding="6,3"
                        IsVisible="{Binding HasVideoFrameRateMismatchWarning}">
                  <TextBlock TextWrapping="Wrap"
                             Text="{Binding VideoFrameRateMismatchWarning}" />
                </Border>
                <Border Background="{DynamicResource ChipNeutral}" BorderBrush="#44808080" BorderThickness="1"
                        CornerRadius="0" Padding="6,3"
                        IsVisible="{Binding IsMultiSelected}">
                  <TextBlock TextWrapping="Wrap"
                             Text="{Binding SelectedCueCount, StringFormat={x:Static res:Strings.MultiSelectVideoBannerFormat}}" />
                </Border>
                <!-- Multi-stream sources: pick which video stream the cue shows (mirrors the Audio
                     tab's track picker). Hidden for single-stream files; an embedded thumbnail /
                     cover-art stream is explicitly selectable here. -->
                <StackPanel Orientation="Horizontal" Spacing="6"
                            IsVisible="{Binding SelectedVideoCue.HasMultipleVideoTracks, FallbackValue=False}"
                            ToolTip.Tip="{x:Static res:Strings.VideoTrackTooltip}">
                  <TextBlock Text="{x:Static res:Strings.VideoTrackLabel}" FontWeight="SemiBold"
                             VerticalAlignment="Center" />
                  <ComboBox MinWidth="260"
                            ItemsSource="{Binding SelectedVideoCue.VideoTrackChoices}"
                            SelectedItem="{Binding SelectedVideoCue.SelectedVideoTrackChoice, Mode=TwoWay}" />
                </StackPanel>
                <WrapPanel ItemSpacing="6">
                  <Button Content="{x:Static res:Strings.AddVideoPlacementButton}" Command="{Binding AddVideoPlacementCommand}" />
                  <Button Content="{x:Static res:Strings.RemoveButton}" Command="{Binding RemoveVideoPlacementCommand}" />
                  <Button Content="{x:Static res:Strings.EditVideoFxButton}" Command="{Binding EditSelectedPlacementVideoFxCommand}" />
                </WrapPanel>
                <TextBlock Opacity="0.65"
                           TextWrapping="Wrap"
                           Text="{x:Static res:Strings.NoVideoPlacementsHint}"
                           IsVisible="{Binding VisibleVideoPlacements.Count, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=0}" />

                <!-- The placement LIST comes before the editors that act on its selection (it used
                     to sit below all of them, at the very bottom of the tab). -->
                <ListBox ItemsSource="{Binding VisibleVideoPlacements}"
                         SelectedItem="{Binding SelectedVideoPlacement, Mode=TwoWay}">
                  <ListBox.ItemTemplate>
                    <DataTemplate DataType="vm:CueVideoPlacementViewModel">
                      <!-- Keep each label/editor pair together when the drawer narrows. Using a grid
                           inside each group also gives every item the same vertical centre; the former
                           horizontal StackPanel aligned controls by their differing desired heights. -->
                      <WrapPanel ItemSpacing="12" LineSpacing="6">
                        <Grid ColumnDefinitions="Auto,8,220">
                          <TextBlock Grid.Column="0" Text="{x:Static res:Strings.CompositionLabel}" VerticalAlignment="Center" />
                          <ComboBox Grid.Column="2"
                                    SelectedValue="{Binding CompositionId, Mode=TwoWay}"
                                    SelectedValueBinding="{Binding Id}"
                                    DisplayMemberBinding="{Binding DisplayName}"
                                    ItemsSource="{Binding $parent[UserControl].((vm:CuePlayerViewModel)DataContext).VisibleCompositions}"
                                    VerticalAlignment="Center" />
                        </Grid>
                        <Grid ColumnDefinitions="Auto,8,110">
                          <TextBlock Grid.Column="0" Text="{x:Static res:Strings.LayerIndexLabel}" VerticalAlignment="Center" />
                          <NumericUpDown Grid.Column="2" Width="110"
                                         FormatString="0"
                                         Value="{Binding LayerIndex, Mode=TwoWay}"
                                         VerticalAlignment="Center"
                                         Minimum="-100" Maximum="100" />
                        </Grid>
                        <Grid ColumnDefinitions="Auto,8,140">
                          <TextBlock Grid.Column="0" Text="{x:Static res:Strings.LayerPositionLabel}" VerticalAlignment="Center" />
                          <ComboBox Grid.Column="2"
                                    SelectedItem="{Binding Position, Mode=TwoWay}"
                                    ItemsSource="{Binding $parent[UserControl].((vm:CuePlayerViewModel)DataContext).LayerPositions}"
                                    VerticalAlignment="Center">
                            <ComboBox.ItemTemplate>
                              <DataTemplate>
                                <TextBlock Text="{Binding Converter={x:Static vm:EnumDisplayConverter.Instance}}" />
                              </DataTemplate>
                            </ComboBox.ItemTemplate>
                          </ComboBox>
                        </Grid>
                        <Grid ColumnDefinitions="Auto,8,105,6,130">
                          <TextBlock Grid.Column="0" Text="{x:Static res:Strings.OpacityLabel}" VerticalAlignment="Center" />
                          <Slider Grid.Column="2" Width="105"
                                  Minimum="0" Maximum="1" SmallChange="0.05"
                                  VerticalAlignment="Center"
                                  Value="{Binding Opacity, Mode=TwoWay}" />
                          <NumericUpDown Grid.Column="4" Width="130"
                                         Minimum="0" Maximum="1" Increment="0.01" FormatString="0.00"
                                         VerticalAlignment="Center"
                                         ToolTip.Tip="Exact layer opacity (0.00–1.00)"
                                         Value="{Binding Opacity, Mode=TwoWay}" />
                        </Grid>
                      </WrapPanel>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>

                <!-- Layout presets for the selected placement -->
                <WrapPanel ItemSpacing="4" LineSpacing="4">
                  <TextBlock Text="{x:Static res:Strings.PlacementPresetsLabel}" VerticalAlignment="Center" Opacity="0.7" Margin="0,0,4,0" />
                  <Button Content="{x:Static res:Strings.PlacementPresetFitButton}" ToolTip.Tip="{x:Static res:Strings.PlacementPresetFitTooltip}"
                          Command="{Binding ApplyPlacementLayoutCommand}" CommandParameter="fit" />
                  <Button Content="{x:Static res:Strings.PlacementPresetFullButton}" Command="{Binding ApplyPlacementLayoutCommand}" CommandParameter="full" />
                  <Button Content="{x:Static res:Strings.PlacementPresetLeftHalfButton}" Command="{Binding ApplyPlacementLayoutCommand}" CommandParameter="left" />
                  <Button Content="{x:Static res:Strings.PlacementPresetRightHalfButton}" Command="{Binding ApplyPlacementLayoutCommand}" CommandParameter="right" />
                  <Button Content="{x:Static res:Strings.PlacementPresetTopHalfButton}" Command="{Binding ApplyPlacementLayoutCommand}" CommandParameter="top" />
                  <Button Content="{x:Static res:Strings.PlacementPresetBottomHalfButton}" Command="{Binding ApplyPlacementLayoutCommand}" CommandParameter="bottom" />
                  <Button Content="{x:Static res:Strings.PlacementPresetTopLeftButton}" Command="{Binding ApplyPlacementLayoutCommand}" CommandParameter="tl" />
                  <Button Content="{x:Static res:Strings.PlacementPresetTopRightButton}" Command="{Binding ApplyPlacementLayoutCommand}" CommandParameter="tr" />
                  <Button Content="{x:Static res:Strings.PlacementPresetBottomLeftButton}" Command="{Binding ApplyPlacementLayoutCommand}" CommandParameter="bl" />
                  <Button Content="{x:Static res:Strings.PlacementPresetBottomRightButton}" Command="{Binding ApplyPlacementLayoutCommand}" CommandParameter="br" />
                </WrapPanel>

                <!-- Visual placement canvas: drag to move, bottom-right handle to resize, click to select -->
                <Border BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="1" CornerRadius="0" MinHeight="220">
                  <controls:CompositionPlacementCanvas
                      Placements="{Binding VisibleVideoPlacements}"
                      SelectedPlacement="{Binding SelectedVideoPlacement, Mode=TwoWay}"
                      AspectRatio="{Binding PlacementCanvasAspect}"
                      TextBounds="{Binding SelectedVideoCue.TextBounds}" />
                </Border>
                <TextBlock Opacity="0.55" FontSize="11" TextWrapping="Wrap"
                           Text="{x:Static res:Strings.PlacementCanvasDragHint}" />

                <WrapPanel ItemSpacing="6" LineSpacing="4"
                           IsVisible="{Binding SelectedVideoPlacement, Converter={x:Static ObjectConverters.IsNotNull}}">
                  <TextBlock Text="{x:Static res:Strings.PlacementPositionLabel}" VerticalAlignment="Center" Opacity="0.7" />
                  <TextBlock Text="{x:Static res:Strings.PlacementXLabel}" VerticalAlignment="Center" Opacity="0.7" />
                  <NumericUpDown Width="92" Minimum="0" Maximum="1" Increment="0.01" FormatString="0.00"
                                 Value="{Binding SelectedVideoPlacement.DestX, Mode=TwoWay}" />
                  <TextBlock Text="{x:Static res:Strings.PlacementYLabel}" VerticalAlignment="Center" Opacity="0.7" />
                  <NumericUpDown Width="92" Minimum="0" Maximum="1" Increment="0.01" FormatString="0.00"
                                 Value="{Binding SelectedVideoPlacement.DestY, Mode=TwoWay}" />
                  <TextBlock Text="{x:Static res:Strings.PlacementWidthLabel}" VerticalAlignment="Center" Opacity="0.7" />
                  <NumericUpDown Width="92" Minimum="0.02" Maximum="1" Increment="0.01" FormatString="0.00"
                                 Value="{Binding SelectedVideoPlacement.DestWidth, Mode=TwoWay}" />
                  <TextBlock Text="{x:Static res:Strings.PlacementHeightLabel}" VerticalAlignment="Center" Opacity="0.7" />
                  <NumericUpDown Width="92" Minimum="0.02" Maximum="1" Increment="0.01" FormatString="0.00"
                                 Value="{Binding SelectedVideoPlacement.DestHeight, Mode=TwoWay}" />
                  <TextBlock Text="{x:Static res:Strings.PlacementRotationLabel}" VerticalAlignment="Center" Opacity="0.7" />
                  <NumericUpDown Width="92" Minimum="-180" Maximum="180" Increment="1" FormatString="0"
                                 Value="{Binding SelectedVideoPlacement.RotationDegrees, Mode=TwoWay}" />
                </WrapPanel>

                <!-- Crop presets + fine crop / fit for the selected placement -->
                <WrapPanel ItemSpacing="4" LineSpacing="4">
                  <TextBlock Text="{x:Static res:Strings.CropPresetsLabel}" VerticalAlignment="Center" Opacity="0.7" Margin="0,0,4,0" />
                  <Button Content="{x:Static res:Strings.CropPresetNoneButton}" Command="{Binding ApplyCropPresetCommand}" CommandParameter="none" />
                  <Button Content="{x:Static res:Strings.CropPresetCenterWideButton}" Command="{Binding ApplyCropPresetCommand}" CommandParameter="centerH" />
                  <Button Content="{x:Static res:Strings.CropPresetCenterTallButton}" Command="{Binding ApplyCropPresetCommand}" CommandParameter="centerV" />
                  <Button Content="{x:Static res:Strings.CropPresetCenterBoxButton}" Command="{Binding ApplyCropPresetCommand}" CommandParameter="center" />
                </WrapPanel>
                <WrapPanel ItemSpacing="6" LineSpacing="4"
                           IsVisible="{Binding SelectedVideoPlacement, Converter={x:Static ObjectConverters.IsNotNull}}">
                  <TextBlock Text="{x:Static res:Strings.CropLeftLabel}" VerticalAlignment="Center" Opacity="0.7" />
                  <NumericUpDown Width="92" Minimum="0" Maximum="0.99" Increment="0.05" FormatString="0.00"
                                 Value="{Binding SelectedVideoPlacement.CropLeft, Mode=TwoWay}" />
                  <TextBlock Text="{x:Static res:Strings.CropTopLabel}" VerticalAlignment="Center" Opacity="0.7" />
                  <NumericUpDown Width="92" Minimum="0" Maximum="0.99" Increment="0.05" FormatString="0.00"
                                 Value="{Binding SelectedVideoPlacement.CropTop, Mode=TwoWay}" />
                  <TextBlock Text="{x:Static res:Strings.CropRightLabel}" VerticalAlignment="Center" Opacity="0.7" />
                  <NumericUpDown Width="92" Minimum="0" Maximum="0.99" Increment="0.05" FormatString="0.00"
                                 Value="{Binding SelectedVideoPlacement.CropRight, Mode=TwoWay}" />
                  <TextBlock Text="{x:Static res:Strings.CropBottomLabel}" VerticalAlignment="Center" Opacity="0.7" />
                  <NumericUpDown Width="92" Minimum="0" Maximum="0.99" Increment="0.05" FormatString="0.00"
                                 Value="{Binding SelectedVideoPlacement.CropBottom, Mode=TwoWay}" />
                  <TextBlock Text="{x:Static res:Strings.PlacementFitModeLabel}" VerticalAlignment="Center" Opacity="0.7" Margin="6,0,0,0" />
                  <ComboBox MinWidth="120"
                            SelectedItem="{Binding SelectedVideoPlacement.Position, Mode=TwoWay}"
                            ItemsSource="{Binding LayerPositions}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding Converter={x:Static vm:EnumDisplayConverter.Instance}}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                </WrapPanel>
              </StackPanel>
            </ScrollViewer>
          </TabItem>

          <TabItem Header="{x:Static res:Strings.CueKindVisualizerLabel}"
                   IsVisible="{Binding IsVisualizerCueSelected}">
            <ScrollViewer>
              <StackPanel Spacing="8" Margin="6">
                <WrapPanel ItemSpacing="8" LineSpacing="4">
                  <CheckBox Content="Start visualizer (off = stop the visualizer on this composition)"
                            IsChecked="{Binding SelectedVisualizerStarts, Mode=TwoWay}" />
                  <Button Content="Fire selected cue now"
                          Command="{Binding FireSelectedVisualizerCommand}"
                          ToolTip.Tip="Applies this visualizer Start/Stop cue without firing or replacing the main transport standby." />
                  <Button Content="{x:Static res:Strings.VisualizerNextPresetMenuHeader}"
                          Command="{Binding NextVisualizerPresetCommand}"
                          ToolTip.Tip="Advances the currently running visualizer without restarting it." />
                </WrapPanel>

                <StackPanel Spacing="8" IsEnabled="{Binding SelectedVisualizerStarts}">
                  <TextBlock Text="Playback" FontWeight="SemiBold" />
                  <Grid ColumnDefinitions="Auto,170,Auto,170"
                        RowDefinitions="Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Cue duration (seconds)" VerticalAlignment="Center"
                               ToolTip.Tip="0 is non-blocking: the layer keeps running until a Stop cue." />
                    <NumericUpDown Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="86400" Increment="1" FormatString="0.#"
                                   Value="{Binding SelectedVisualizerDurationSeconds, Mode=TwoWay}" />
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Preset duration (seconds)" VerticalAlignment="Center" />
                    <NumericUpDown Grid.Row="0" Grid.Column="3" Minimum="0" Maximum="3600" Increment="1" FormatString="0.#"
                                   ToolTip.Tip="0 uses the default: 30 seconds. Positive values have a 5-second minimum."
                                   Value="{Binding SelectedVisualizerCue.VisualizerPresetDurationSeconds, Mode=TwoWay}" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Transition (seconds)" VerticalAlignment="Center"
                               ToolTip.Tip="Default: 2 seconds. 0 is an immediate preset switch." />
                    <NumericUpDown Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="30" Increment="0.25" FormatString="0.##"
                                   Value="{Binding SelectedVisualizerCue.VisualizerTransitionSeconds, Mode=TwoWay}" />
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Beat sensitivity" VerticalAlignment="Center"
                               ToolTip.Tip="Default: 1.0. 0 disables beat response." />
                    <NumericUpDown Grid.Row="1" Grid.Column="3" Minimum="0" Maximum="5" Increment="0.1" FormatString="0.0"
                                   Value="{Binding SelectedVisualizerCue.VisualizerBeatSensitivity, Mode=TwoWay}" />

                    <CheckBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                              Content="Shuffle presets"
                              IsChecked="{Binding SelectedVisualizerCue.VisualizerShufflePresets, Mode=TwoWay}" />
                  </Grid>
                  <TextBlock Opacity="0.65" FontSize="11" TextWrapping="Wrap"
                             Text="Defaults: preset duration 30 s, transition 2 s, beat sensitivity 1.0. Zero means: cue duration runs until a Stop cue; preset duration uses 30 s; transition is immediate; beat response is disabled." />

                  <TextBlock Text="Rendering" FontWeight="SemiBold" Margin="0,4,0,0" />
                  <Grid ColumnDefinitions="Auto,150,Auto,150,Auto,120" ColumnSpacing="8">
                    <TextBlock Grid.Column="0" Text="Width" VerticalAlignment="Center" />
                    <NumericUpDown Grid.Column="1" Minimum="0" Maximum="7680" Increment="2" FormatString="0"
                                   Value="{Binding SelectedVisualizerCue.VisualizerRenderWidth, Mode=TwoWay}" />
                    <TextBlock Grid.Column="2" Text="Height" VerticalAlignment="Center" />
                    <NumericUpDown Grid.Column="3" Minimum="0" Maximum="4320" Increment="2" FormatString="0"
                                   Value="{Binding SelectedVisualizerCue.VisualizerRenderHeight, Mode=TwoWay}" />
                    <TextBlock Grid.Column="4" Text="FPS" VerticalAlignment="Center" />
                    <NumericUpDown Grid.Column="5" Minimum="0" Maximum="240" Increment="1" FormatString="0"
                                   Value="{Binding SelectedVisualizerCue.VisualizerRenderFps, Mode=TwoWay}" />
                  </Grid>
                  <TextBlock Opacity="0.65" FontSize="11" TextWrapping="Wrap"
                             Text="0 for width, height, or FPS means use the target composition's current value." />
                  <WrapPanel ItemSpacing="6" LineSpacing="4">
                    <Button Content="Match composition" Command="{Binding SetVisualizerCueResolutionCommand}" CommandParameter="0x0@0" />
                    <Button Content="720p60" Command="{Binding SetVisualizerCueResolutionCommand}" CommandParameter="1280x720@60" />
                    <Button Content="1080p60" Command="{Binding SetVisualizerCueResolutionCommand}" CommandParameter="1920x1080@60" />
                    <Button Content="1440p60" Command="{Binding SetVisualizerCueResolutionCommand}" CommandParameter="2560x1440@60" />
                    <Button Content="4K60" Command="{Binding SetVisualizerCueResolutionCommand}" CommandParameter="3840x2160@60" />
                  </WrapPanel>

                  <TextBlock Text="Preset folder" FontWeight="SemiBold" Margin="0,4,0,0" />
                  <TextBox Text="{Binding SelectedVisualizerCue.SourceOrAction, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                           PlaceholderText="Folder containing *.milk presets (searched recursively)" />

                  <TextBlock Text="Audio feed" FontWeight="SemiBold" Margin="0,4,0,0" />
                  <CheckBox Content="Feed audio from all playing media"
                            IsChecked="{Binding SelectedVisualizerFeedAll, Mode=TwoWay}" />
                  <Grid ColumnDefinitions="Auto,220" ColumnSpacing="8"
                        IsVisible="{Binding !SelectedVisualizerFeedAll}">
                    <TextBlock Grid.Column="0" Text="Cue numbers"
                               VerticalAlignment="Center"
                               ToolTip.Tip="Also includes media cues whose 'send audio to visualizer' option is enabled." />
                    <TextBox Grid.Column="1"
                             Text="{Binding SelectedVisualizerFeedText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                             PlaceholderText="e.g. 2, 4" />
                  </Grid>
                </StackPanel>

                <TextBlock Opacity="0.65" FontSize="11" TextWrapping="Wrap"
                           Text="Composition placement uses the Video tab. Position, fit, crop, opacity, rotation, and effects update the running visualizer live." />
              </StackPanel>
            </ScrollViewer>
          </TabItem>

          <TabItem Header="{x:Static res:Strings.SubtitlesTabLabel}" IsVisible="{Binding HasSelectedSubtitleCue}">
            <ScrollViewer>
              <StackPanel Spacing="8" Margin="6">
                <TextBlock Text="{x:Static res:Strings.SubtitleTracksHeader}" FontWeight="SemiBold" />
                <TextBlock Opacity="0.65" TextWrapping="Wrap"
                           Text="{x:Static res:Strings.SubtitleTracksHint}" />
                <ItemsControl ItemsSource="{Binding SelectedSubtitleCue.SubtitleTrackChoices}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:CueSubtitleTrackChoice">
                      <CheckBox Margin="0,1"
                                IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                Content="{Binding Label}" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="{x:Static res:Strings.SubtitleFontHeader}" FontWeight="SemiBold" Margin="0,6,0,0" />
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock VerticalAlignment="Center" Text="{x:Static res:Strings.SubtitleFontFamilyLabel}" />
                  <TextBox Width="180" PlaceholderText="{x:Static res:Strings.SubtitleFontFamilyPlaceholder}"
                           Text="{Binding SelectedSubtitleCue.SubtitleFontFamily, Mode=TwoWay}" />
                  <TextBlock VerticalAlignment="Center" Text="{x:Static res:Strings.SubtitleFontScaleLabel}" />
                  <NumericUpDown Width="120" Minimum="0.25" Maximum="5" Increment="0.1" PlaceholderText="1.0"
                                 Value="{Binding SelectedSubtitleCue.SubtitleFontScaleValue, Mode=TwoWay}" />
                  <TextBlock VerticalAlignment="Center" Text="{x:Static res:Strings.SubtitleAlignLabel}" />
                  <ComboBox MinWidth="150"
                            ItemsSource="{Binding SelectedSubtitleCue.SubtitleAlignmentChoices}"
                            SelectedItem="{Binding SelectedSubtitleCue.SelectedSubtitleAlignment, Mode=TwoWay}" />
                </StackPanel>
                <TextBlock Opacity="0.6" FontSize="11" TextWrapping="Wrap"
                           Text="{x:Static res:Strings.SubtitleFontOverridesHint}" />
              </StackPanel>
            </ScrollViewer>
          </TabItem>

          <TabItem Header="{x:Static res:Strings.TextCueTabLabel}" IsVisible="{Binding HasSelectedTextCue}">
            <ScrollViewer>
              <StackPanel Spacing="8" Margin="6">
                <TextBlock Text="{x:Static res:Strings.TextContentLabel}" Opacity="0.7" />
                <TextBox AcceptsReturn="True" MinHeight="80" TextWrapping="Wrap"
                         Text="{Binding SelectedTextCue.TextContent, Mode=TwoWay}" />
                <Grid ColumnDefinitions="Auto,*,Auto,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="6">
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static res:Strings.TextFontFamilyLabel}" VerticalAlignment="Center" Opacity="0.7" />
                  <ComboBox Grid.Row="0" Grid.Column="1" HorizontalAlignment="Stretch"
                            ItemsSource="{Binding SelectedTextCue.FontFamilyOptions}"
                            SelectedItem="{Binding SelectedTextCue.TextFontFamily, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding}" FontFamily="{Binding}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                  <CheckBox Grid.Row="0" Grid.Column="2" Content="{x:Static res:Strings.TextBoldLabel}" IsChecked="{Binding SelectedTextCue.TextBold, Mode=TwoWay}" />
                  <CheckBox Grid.Row="0" Grid.Column="3" Content="{x:Static res:Strings.TextItalicLabel}" IsChecked="{Binding SelectedTextCue.TextItalic, Mode=TwoWay}" />
                  <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static res:Strings.TextFontSizeLabel}" VerticalAlignment="Center" Opacity="0.7" />
                  <NumericUpDown Grid.Row="1" Grid.Column="1" HorizontalAlignment="Left" Width="130"
                                 Minimum="4" Maximum="2000" Increment="4" FormatString="0"
                                 Value="{Binding SelectedTextCue.TextFontSizePx, Mode=TwoWay}" />
                </Grid>
                <WrapPanel ItemSpacing="8" LineSpacing="6">
                  <TextBlock Text="{x:Static res:Strings.TextColorLabel}" VerticalAlignment="Center" Opacity="0.7" />
                  <ColorPicker Color="{Binding SelectedTextCue.TextColor, Mode=TwoWay}" />
                  <TextBlock Text="{x:Static res:Strings.TextBackgroundColorLabel}" VerticalAlignment="Center" Opacity="0.7" />
                  <ColorPicker Color="{Binding SelectedTextCue.TextBackgroundColor, Mode=TwoWay}" />
                  <TextBlock Text="{x:Static res:Strings.TextOutlineColorLabel}" VerticalAlignment="Center" Opacity="0.7" />
                  <ColorPicker Color="{Binding SelectedTextCue.TextOutlineColor, Mode=TwoWay}" />
                  <NumericUpDown Width="92" Minimum="0" Maximum="40" Increment="1" FormatString="0"
                                 Value="{Binding SelectedTextCue.TextOutlineWidthPx, Mode=TwoWay}" />
                </WrapPanel>
                <WrapPanel ItemSpacing="8" LineSpacing="6">
                  <TextBlock Text="{x:Static res:Strings.TextHAlignLabel}" VerticalAlignment="Center" Opacity="0.7" />
                  <ComboBox MinWidth="92" ItemsSource="{Binding TextHAlignOptions}"
                            SelectedItem="{Binding SelectedTextCue.TextHAlign, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding Converter={x:Static vm:EnumDisplayConverter.Instance}}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                  <TextBlock Text="{x:Static res:Strings.TextVAlignLabel}" VerticalAlignment="Center" Opacity="0.7" />
                  <ComboBox MinWidth="92" ItemsSource="{Binding TextVAlignOptions}"
                            SelectedItem="{Binding SelectedTextCue.TextVAlign, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding Converter={x:Static vm:EnumDisplayConverter.Instance}}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                  <TextBlock Text="{x:Static res:Strings.TextWrapWidthLabel}" VerticalAlignment="Center" Opacity="0.7" />
                  <Slider Width="120" Minimum="0" Maximum="1" SmallChange="0.05"
                          Value="{Binding SelectedTextCue.TextWrapWidthFraction, Mode=TwoWay}" />
                </WrapPanel>
                <TextBlock Opacity="0.5" FontSize="11" TextWrapping="Wrap"
                           Text="{x:Static res:Strings.TextCueFooterHint}" />
              </StackPanel>
            </ScrollViewer>
          </TabItem>

          <TabItem Header="{x:Static res:Strings.ActionTabLabel}"
                   IsVisible="{Binding HasSelectedActionCue}">
            <StackPanel Spacing="8" Margin="6">
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                <TextBlock Grid.Column="0" Text="{x:Static res:Strings.ActionTargetLabel}" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           Text="{Binding SelectedActionEndpointSummary}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Opacity="0.8" />
              </Grid>
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                <TextBlock Grid.Column="0" Text="{x:Static res:Strings.ActionKindLabel}" VerticalAlignment="Center" />
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding ActionKinds}"
                          SelectedItem="{Binding SelectedActionCue.ActionKind, Mode=TwoWay}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Converter={x:Static vm:EnumDisplayConverter.Instance}}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </Grid>
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                <TextBlock Grid.Column="0" Text="{x:Static res:Strings.ActionCommandLabel}" VerticalAlignment="Center" />
                <TextBox Grid.Column="1" Text="{Binding SelectedActionCue.SourceOrAction, Mode=TwoWay}" />
              </Grid>
              <Button Content="{x:Static res:Strings.EditActionButton}"
                      Command="{Binding EditActionCueCommand}"
                      HorizontalAlignment="Left" />
            </StackPanel>
          </TabItem>

          <TabItem Header="{x:Static res:Strings.CommentTabLabel}"
                   IsVisible="{Binding HasSelectedCommentCue}">
            <StackPanel Spacing="6" Margin="6">
              <TextBlock Text="{x:Static res:Strings.CommentTextLabel}" />
              <TextBox AcceptsReturn="True"
                       MinHeight="120"
                       TextWrapping="Wrap"
                       Text="{Binding SelectedCommentCue.SourceOrAction, Mode=TwoWay}" />
            </StackPanel>
          </TabItem>

          <TabItem Header="{x:Static res:Strings.GroupTabLabel}"
                   IsVisible="{Binding HasSelectedGroupCue}">
            <StackPanel Spacing="8" Margin="6">
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                <TextBlock Grid.Column="0" Text="{x:Static res:Strings.GroupFireModeLabel}" VerticalAlignment="Center" />
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding GroupFireModes}"
                          SelectedItem="{Binding SelectedGroupCue.GroupFireMode, Mode=TwoWay}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Converter={x:Static vm:EnumDisplayConverter.Instance}}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </Grid>
            </StackPanel>
          </TabItem>
        </TabControl>
        </StackPanel>
      </Expander>

      <Grid ColumnDefinitions="*,Auto,260">
        <Grid Grid.Column="0" RowDefinitions="Auto,*">
          <!-- Ctrl+F jump-to-cue search. Not a filter: the full list stays visible (transport
               context), matches are selected/expanded/scrolled. Enter = next, Shift+Enter =
               previous, Esc = clear + back to the tree. -->
          <DockPanel Grid.Row="0" Margin="0,0,0,4">
            <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" Margin="8,0,2,0"
                       FontSize="11" Opacity="0.7"
                       Text="{Binding CueSearchStatus}"
                       IsVisible="{Binding HasCueSearchText}" />
            <TextBox Name="CueSearchBox"
                     PlaceholderText="Search cues (Ctrl+F) — Enter: next match"
                     Text="{Binding CueSearchText, Mode=TwoWay}"
                     KeyDown="OnCueSearchBoxKeyDown" />
          </DockPanel>
          <Panel Grid.Row="1">
          <TreeDataGrid Name="CueTreeGrid" DragDrop.AllowDrop="True">
            <TreeDataGrid.ContextMenu>
              <ContextMenu>
                <MenuItem Header="GO / start selected" Command="{Binding FireSelectedCueNowCommand}" />
                <MenuItem Header="Standby selected cue" Command="{Binding StandbySelectedCommand}" />
                <MenuItem Header="Stop selected" Command="{Binding StopSelectedCueCommand}" />
                <MenuItem Header="Next visualizer preset" Command="{Binding NextVisualizerPresetCommand}" />
                <Separator />
                <MenuItem Header="Rename…" Command="{Binding RenameSelectedCueCommand}" />
                <MenuItem Header="Duplicate" Command="{Binding DuplicateSelectedCueCommand}" />
                <MenuItem Header="Copy" Command="{Binding CopySelectedCuesCommand}" InputGesture="Ctrl+C" />
                <MenuItem Header="Paste" Command="{Binding PasteCuesCommand}" InputGesture="Ctrl+V" />
                <MenuItem Header="Remove" Command="{Binding RemoveNodeCommand}" />
              </ContextMenu>
            </TreeDataGrid.ContextMenu>
          </TreeDataGrid>
          <!-- UX-10: empty-list call-to-action (icon + one line + primary action), matching the I/O
               workspace's empty state instead of a bare grid. -->
          <StackPanel Spacing="10" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="360"
                      IsVisible="{Binding HasNoCues}">
            <PathIcon Data="{x:Static views:AppIcons.CueList}" Width="34" Height="34" Opacity="0.3"
                      HorizontalAlignment="Center" />
            <TextBlock Text="{x:Static res:Strings.CueEmptyHint}" Opacity="0.65"
                       TextWrapping="Wrap" TextAlignment="Center" />
            <Button Content="{x:Static res:Strings.CueEmptyAction}"
                    Command="{Binding AddMediaCueCommand}" HorizontalAlignment="Center" />
          </StackPanel>
          </Panel>
        </Grid>
        <GridSplitter Grid.Column="1" Width="3" Background="{DynamicResource BorderSubtle}" ResizeDirection="Columns" />

        <!-- Phase 5.3 - Now Playing panel: active cues (with progress + per-cue ✕); expanded groups
             list the rest of their automatic chain with time-until-start countdowns (#29 - replaced
             the old panel-wide "Upcoming" preview). Width set generously so the operator can shrink
             via the splitter; multi-cue groups need room. -->
        <HeaderedContentControl Grid.Column="2" Margin="4,0,0,0" Padding="6,4"
                                Header="{x:Static res:Strings.NowPlayingHeader}">
          <DockPanel LastChildFill="True">
            <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,6">
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                <ToggleButton Classes="Dense"
                              IsChecked="{Binding NowPlayingSeekUnlocked}"
                              ToolTip.Tip="{x:Static res:Strings.NowPlayingSeekLockTooltip}"
                              AutomationProperties.Name="{x:Static res:Strings.NowPlayingSeekLockTooltip}">
                  <PathIcon Data="{x:Static views:AppIcons.Lock}" Width="11" Height="11" />
                </ToggleButton>
                <Button Content="{x:Static res:Strings.StopAllNowPlayingButton}"
                        Command="{Binding StopCommand}"
                        IsEnabled="{Binding ActiveCues.Count, Converter={x:Static ObjectConverters.NotEqual}, ConverterParameter=0}" />
              </StackPanel>
            </Grid>

            <TextBlock DockPanel.Dock="Top"
                       Text="{x:Static res:Strings.NowPlayingNoneHint}"
                       Opacity="0.55"
                       TextWrapping="Wrap"
                       Margin="0,0,0,8"
                       IsVisible="{Binding ActiveCues.Count, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=0}" />

            <ScrollViewer>
            <!-- P4 (plan §3.2): rows are singles OR group aggregates. The implicit per-type
                 templates below also apply to the group's nested children + upcoming lists. -->
            <ItemsControl ItemsSource="{Binding NowPlayingRows}">
              <ItemsControl.DataTemplates>
                <DataTemplate DataType="vm:ActiveCueViewModel">
                  <Border BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="1" CornerRadius="0"
                          Padding="6,4" Margin="0,0,0,4">
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                      <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="{Binding CueNumberDisplay}" FontWeight="SemiBold" Opacity="0.7" />
                        <TextBlock Text="{Binding CueLabel}" TextTrimming="CharacterEllipsis" />
                      </StackPanel>
                      <Button Grid.Row="0" Grid.Column="1" Padding="6,0" MinWidth="22"
                              Command="{Binding CancelCommand}"
                              ToolTip.Tip="{x:Static res:Strings.NowPlayingCancelTooltip}"
                              AutomationProperties.Name="{x:Static res:Strings.NowPlayingCancelTooltip}">
                        <PathIcon Data="{x:Static views:AppIcons.Close}" Width="9" Height="9" />
                      </Button>
                      <ProgressBar Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                   Margin="0,4,0,2" Height="10"
                                   Minimum="0" Maximum="100"
                                   Value="{Binding ProgressPercent}"
                                   Background="#28808080"
                                   Cursor="Hand"
                                   PointerPressed="OnNowPlayingProgressPressed"
                                   ToolTip.Tip="{x:Static res:Strings.NowPlayingSeekTooltip}" />
                      <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                 Classes="postime" Classes.lowtime="{Binding IsNearEnd}"
                                 Text="{Binding PositionDisplay}" />
                    </Grid>
                  </Border>
                </DataTemplate>

                <DataTemplate DataType="vm:ActiveGroupViewModel">
                  <Border BorderBrush="#33808080" BorderThickness="1" CornerRadius="0"
                          Padding="6,4" Margin="0,0,0,4" Background="#0A808080">
                    <StackPanel Spacing="2">
                      <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="6">
                        <ToggleButton Grid.Column="0" Classes="Dense" MinWidth="24" Padding="4,0"
                                      IsChecked="{Binding IsExpanded}"
                                      Content="▸"
                                      ToolTip.Tip="{x:Static res:Strings.NowPlayingGroupExpandTooltip}" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                          <TextBlock Text="{Binding GroupNode.Number}" FontWeight="SemiBold" Opacity="0.7" />
                          <TextBlock Text="{Binding GroupNode.Label}" FontWeight="SemiBold"
                                     TextTrimming="CharacterEllipsis" />
                          <TextBlock Text="{Binding Children.Count, StringFormat='({0})'}" Opacity="0.6" FontSize="11"
                                     VerticalAlignment="Center" />
                        </StackPanel>
                        <Button Grid.Column="2" Padding="6,0" MinWidth="22"
                                Command="{Binding CancelAllCommand}"
                                ToolTip.Tip="{x:Static res:Strings.NowPlayingGroupCancelTooltip}"
                                AutomationProperties.Name="{x:Static res:Strings.NowPlayingGroupCancelTooltip}">
                          <PathIcon Data="{x:Static views:AppIcons.Close}" Width="9" Height="9" />
                        </Button>
                      </Grid>
                      <ProgressBar Margin="0,2,0,2" Height="10"
                                   Minimum="0" Maximum="100"
                                   Value="{Binding ProgressPercent}"
                                   Background="#28808080"
                                   Cursor="Hand"
                                   PointerPressed="OnNowPlayingGroupProgressPressed"
                                   ToolTip.Tip="{x:Static res:Strings.NowPlayingSeekTooltip}" />
                      <TextBlock Classes="postime" Classes.lowtime="{Binding IsNearEnd}"
                                 Text="{Binding PositionDisplay}" />
                      <StackPanel Margin="16,2,0,0" IsVisible="{Binding IsExpanded}">
                        <ItemsControl ItemsSource="{Binding Children}" />
                        <!-- #29: the rest of the automatic chain, each with a ticking time-until-start
                             (replaces the panel-wide "Upcoming" section). -->
                        <ItemsControl ItemsSource="{Binding UpcomingItems}" />
                      </StackPanel>
                    </StackPanel>
                  </Border>
                </DataTemplate>

                <DataTemplate DataType="vm:UpcomingChainItemViewModel">
                  <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="6" Margin="6,1,6,3" Opacity="0.6">
                    <TextBlock Grid.Column="0" Text="{Binding Node.Number}" FontWeight="SemiBold" Opacity="0.8" />
                    <TextBlock Grid.Column="1" Text="{Binding Node.Label}" TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="2" Classes="postime" Text="{Binding CountdownDisplay}" />
                  </Grid>
                </DataTemplate>
              </ItemsControl.DataTemplates>
            </ItemsControl>
            </ScrollViewer>
          </DockPanel>
        </HeaderedContentControl>
      </Grid>
    </DockPanel>
  </DockPanel>
</UserControl>
