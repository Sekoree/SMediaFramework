<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:HaPlay.ViewModels"
             xmlns:res="using:HaPlay.Resources"
             mc:Ignorable="d" d:DesignWidth="980" d:DesignHeight="760"
             x:Class="HaPlay.Views.CuePlayerView"
             x:DataType="vm:CuePlayerViewModel">
  <DockPanel LastChildFill="True">
    <Border DockPanel.Dock="Top"
            IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
            Background="#33C00000" BorderBrush="#88C00000" BorderThickness="1"
            CornerRadius="4" Padding="10,6" Margin="0,0,0,10">
      <TextBlock Text="{Binding StatusMessage}" Foreground="#FFE6E6" TextWrapping="Wrap" />
    </Border>

    <Grid DockPanel.Dock="Top" Margin="0,0,0,8" ColumnDefinitions="Auto,220,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*" ColumnSpacing="6">
      <TextBlock Grid.Column="0" Text="{x:Static res:Strings.CueListLabel}" VerticalAlignment="Center" />
      <ComboBox Grid.Column="1"
                ItemsSource="{Binding CueLists}"
                SelectedItem="{Binding SelectedCueList, Mode=TwoWay}"
                MinWidth="180">
        <ComboBox.ItemTemplate>
          <DataTemplate DataType="vm:CueListEditorViewModel">
            <TextBlock Text="{Binding Name}" />
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
      <Button Grid.Column="2" Content="{x:Static res:Strings.AddListButton}" Command="{Binding AddCueListCommand}" />
      <Button Grid.Column="3" Content="{x:Static res:Strings.RemoveListButton}" Command="{Binding RemoveCueListCommand}" />
      <Button Grid.Column="4" Content="{x:Static res:Strings.LoadButton}" Command="{Binding LoadCueListCommand}" />
      <Button Grid.Column="5" Content="{x:Static res:Strings.SaveButton}" Command="{Binding SaveCueListCommand}" />
      <Button Grid.Column="6" Content="{x:Static res:Strings.SaveAsButton}" Command="{Binding SaveCueListAsCommand}" />
      <TextBlock Grid.Column="7" Text="{x:Static res:Strings.PreRollNLabel}" VerticalAlignment="Center" ToolTip.Tip="{x:Static res:Strings.PreRollTooltip}" />
      <NumericUpDown Grid.Column="8"
                       Minimum="0"
                       Maximum="16"
                       Width="72"
                       IsEnabled="{Binding SelectedCueList, Converter={x:Static ObjectConverters.IsNotNull}}"
                       Value="{Binding SelectedCueList.PreRollCount, Mode=TwoWay}" />
    </Grid>

    <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,8" ItemSpacing="6" LineSpacing="6">
      <Button Content="{x:Static res:Strings.AddGroupButton}" Command="{Binding AddGroupCommand}" />
      <Button Content="{x:Static res:Strings.AddMediaButton}" Command="{Binding AddMediaCueCommand}" />
      <Button Content="{x:Static res:Strings.AddNdiInputCueButton}" Command="{Binding AddNdiInputCueCommand}" />
      <Button Content="{x:Static res:Strings.AddPortAudioInputCueButton}" Command="{Binding AddPortAudioInputCueCommand}" />
      <Button Content="{x:Static res:Strings.AddActionButton}" Command="{Binding AddActionCueCommand}" />
      <Button Content="{x:Static res:Strings.AddCommentButton}" Command="{Binding AddCommentCueCommand}" />
      <Button Content="{x:Static res:Strings.BrowseMediaButton}" Command="{Binding BrowseMediaSourceCommand}" />
      <Button Content="{x:Static res:Strings.EditActionButton}" Command="{Binding EditActionCueCommand}" />
      <Button Content="{x:Static res:Strings.RemoveNodeButton}" Command="{Binding RemoveNodeCommand}" />
    </WrapPanel>

    <Grid DockPanel.Dock="Top" Margin="0,0,0,8" ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,*" ColumnSpacing="6">
      <Button Grid.Column="0" Content="{x:Static res:Strings.StandbySelectedButton}" Command="{Binding StandbySelectedCommand}" />
      <Button Grid.Column="1" Content="{x:Static res:Strings.GoButton}" Command="{Binding GoCommand}" />
      <Button Grid.Column="2" Content="{x:Static res:Strings.BackButton}" Command="{Binding BackCommand}" />
      <Button Grid.Column="3" Content="{x:Static res:Strings.PauseButton}" Command="{Binding PauseCommand}" />
      <Button Grid.Column="4" Content="{x:Static res:Strings.StopButton}" Command="{Binding StopCommand}" />
      <Button Grid.Column="5" Content="{x:Static res:Strings.PanicButton}" Command="{Binding PanicCommand}" />
      <TextBlock Grid.Column="6" Text="{Binding TransportState}" VerticalAlignment="Center" Margin="8,0,0,0" />
    </Grid>

    <DockPanel LastChildFill="True">
      <Expander DockPanel.Dock="Top"
                Classes="dense"
                Margin="0,0,0,4"
                IsExpanded="False"
                Header="{x:Static res:Strings.CompositionsHeader}"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch">
        <StackPanel Margin="4" Spacing="4">
          <WrapPanel ItemSpacing="6">
            <Button Content="{x:Static res:Strings.AddCompositionButton}" Command="{Binding AddCompositionCommand}" />
            <Button Content="{x:Static res:Strings.RemoveButton}" Command="{Binding RemoveCompositionCommand}" />
          </WrapPanel>
          <ListBox ItemsSource="{Binding VisibleCompositions}"
                   SelectedItem="{Binding SelectedComposition, Mode=TwoWay}"
                   MaxHeight="180">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="vm:CueCompositionViewModel">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBox Text="{Binding Name, Mode=TwoWay}" MinWidth="160" />
                  <TextBlock Text="{x:Static res:Strings.WidthLabel}" VerticalAlignment="Center" />
                  <NumericUpDown Value="{Binding Width, Mode=TwoWay}" Minimum="16" Maximum="7680" />
                  <TextBlock Text="{x:Static res:Strings.HeightLabel}" VerticalAlignment="Center" />
                  <NumericUpDown Value="{Binding Height, Mode=TwoWay}" Minimum="16" Maximum="4320" />
                  <TextBlock Text="{x:Static res:Strings.FrameRateLabel}" VerticalAlignment="Center" />
                  <NumericUpDown Value="{Binding FrameRateNum, Mode=TwoWay}" Minimum="1" Maximum="240" />
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </StackPanel>
      </Expander>

      <Expander DockPanel.Dock="Top"
                Classes="dense"
                Margin="0,0,0,4"
                IsExpanded="False"
                Header="{x:Static res:Strings.VideoOutputsHeader}"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch">
        <StackPanel Margin="4" Spacing="4">
          <WrapPanel ItemSpacing="6">
            <Button Content="{x:Static res:Strings.AddVideoOutputButton}" Command="{Binding AddVideoOutputCommand}" />
            <Button Content="{x:Static res:Strings.RemoveButton}" Command="{Binding RemoveVideoOutputCommand}" />
          </WrapPanel>
          <TextBlock Opacity="0.65"
                     TextWrapping="Wrap"
                     Text="{x:Static res:Strings.NoVideoOutputLinesHint}"
                     IsVisible="{Binding AvailableVideoOutputs.Count, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=0}" />
          <ListBox ItemsSource="{Binding VisibleVideoOutputs}"
                   SelectedItem="{Binding SelectedVideoOutput, Mode=TwoWay}"
                   MaxHeight="180">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="vm:CueVideoOutputBindingViewModel">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="{x:Static res:Strings.RouteOutputLabel}" VerticalAlignment="Center" />
                  <ComboBox SelectedValue="{Binding OutputLineId, Mode=TwoWay}"
                            SelectedValueBinding="{Binding Definition.Id}"
                            DisplayMemberBinding="{Binding Definition.DisplayName}"
                            ItemsSource="{Binding $parent[UserControl].((vm:CuePlayerViewModel)DataContext).AvailableVideoOutputs}"
                            MinWidth="220" />
                  <TextBlock Text="{x:Static res:Strings.CompositionLabel}" VerticalAlignment="Center" />
                  <ComboBox SelectedValue="{Binding CompositionId, Mode=TwoWay}"
                            SelectedValueBinding="{Binding Id}"
                            DisplayMemberBinding="{Binding DisplayName}"
                            ItemsSource="{Binding $parent[UserControl].((vm:CuePlayerViewModel)DataContext).VisibleCompositions}"
                            MinWidth="220" />
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </StackPanel>
      </Expander>

      <Expander DockPanel.Dock="Bottom"
                Classes="dense"
                Margin="0,4,0,0"
                IsExpanded="True"
                Header="{Binding SelectedCueDrawerTitle}"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch">
        <TabControl Margin="0,4,0,0" MinHeight="220"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch">
          <TabItem Header="{x:Static res:Strings.GeneralTabLabel}"
                   IsVisible="{Binding HasSelectedCue}">
            <ScrollViewer>
              <StackPanel Spacing="8" Margin="6">
                <Grid ColumnDefinitions="Auto,160,Auto,120" ColumnSpacing="8">
                  <TextBlock Grid.Column="0" Text="{x:Static res:Strings.TriggerLabel}" VerticalAlignment="Center" />
                  <ComboBox Grid.Column="1"
                            ItemsSource="{Binding CueTriggerModes}"
                            SelectedItem="{Binding SelectedCueNode.TriggerMode, Mode=TwoWay}" />
                  <TextBlock Grid.Column="2" Text="{x:Static res:Strings.PreWaitLabel}" VerticalAlignment="Center" />
                  <NumericUpDown Grid.Column="3"
                                 Minimum="0"
                                 Maximum="120000"
                                 Value="{Binding SelectedCueNode.PreWaitMs, Mode=TwoWay}" />
                </Grid>
                <Grid ColumnDefinitions="Auto,*,Auto,*"
                      ColumnSpacing="8"
                      IsVisible="{Binding HasSelectedMediaCue}">
                  <TextBlock Grid.Column="0" Text="{x:Static res:Strings.FadeInMsLabel}" VerticalAlignment="Center" />
                  <NumericUpDown Grid.Column="1"
                                 Minimum="0"
                                 Maximum="120000"
                                 Value="{Binding SelectedCueNode.FadeInMs, Mode=TwoWay}" />
                  <TextBlock Grid.Column="2" Text="{x:Static res:Strings.FadeOutMsLabel}" VerticalAlignment="Center" />
                  <NumericUpDown Grid.Column="3"
                                 Minimum="0"
                                 Maximum="120000"
                                 Value="{Binding SelectedCueNode.FadeOutMs, Mode=TwoWay}" />
                </Grid>
                <Grid ColumnDefinitions="Auto,*,Auto,Auto,*"
                      ColumnSpacing="8"
                      IsVisible="{Binding HasSelectedMediaCue}">
                  <TextBlock Grid.Column="0" Text="{x:Static res:Strings.StartMsLabel}" VerticalAlignment="Center" />
                  <NumericUpDown Grid.Column="1"
                                 Minimum="0"
                                 Maximum="86400000"
                                 Value="{Binding SelectedCueNode.StartOffsetMs, Mode=TwoWay}" />
                  <CheckBox Grid.Column="2" Content="{x:Static res:Strings.LoopLabel}" VerticalAlignment="Center"
                            IsChecked="{Binding SelectedCueNode.Loop, Mode=TwoWay}" />
                  <TextBlock Grid.Column="3" Text="{x:Static res:Strings.EndLabel}" VerticalAlignment="Center" />
                  <ComboBox Grid.Column="4"
                            MinWidth="140"
                            ItemsSource="{Binding CueEndBehaviors}"
                            SelectedItem="{Binding SelectedCueNode.EndBehavior, Mode=TwoWay}" />
                </Grid>
                <TextBlock Text="{x:Static res:Strings.NotesLabel}" />
                <TextBox AcceptsReturn="True"
                         MinHeight="60"
                         TextWrapping="Wrap"
                         Text="{Binding SelectedCueNode.Notes, Mode=TwoWay}" />
              </StackPanel>
            </ScrollViewer>
          </TabItem>

          <TabItem Header="{x:Static res:Strings.AudioTabLabel}"
                   IsVisible="{Binding HasSelectedMediaCue}">
            <ScrollViewer>
              <StackPanel Margin="6" Spacing="8">
                <WrapPanel ItemSpacing="6">
                  <Button Content="{x:Static res:Strings.AddAudioRouteButton}" Command="{Binding AddAudioRouteCommand}" />
                  <Button Content="{x:Static res:Strings.RemoveButton}" Command="{Binding RemoveAudioRouteCommand}" />
                </WrapPanel>
                <TextBlock Opacity="0.65"
                           TextWrapping="Wrap"
                           Text="{x:Static res:Strings.NoAudioRoutesHint}"
                           IsVisible="{Binding VisibleAudioRoutes.Count, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=0}" />
                <ListBox ItemsSource="{Binding VisibleAudioRoutes}"
                         SelectedItem="{Binding SelectedAudioRoute, Mode=TwoWay}">
                  <ListBox.ItemTemplate>
                    <DataTemplate DataType="vm:CueAudioRouteViewModel">
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{x:Static res:Strings.SrcChLabel}" VerticalAlignment="Center" />
                        <NumericUpDown Value="{Binding SourceChannel, Mode=TwoWay}" Minimum="0" Maximum="63" />
                        <TextBlock Text="{x:Static res:Strings.RouteOutputLabel}" VerticalAlignment="Center" />
                        <ComboBox SelectedValue="{Binding OutputLineId, Mode=TwoWay}"
                                  SelectedValueBinding="{Binding Definition.Id}"
                                  DisplayMemberBinding="{Binding Definition.DisplayName}"
                                  ItemsSource="{Binding $parent[UserControl].((vm:CuePlayerViewModel)DataContext).AvailableAudioOutputs}"
                                  MinWidth="200" />
                        <TextBlock Text="{x:Static res:Strings.OutChLabel}" VerticalAlignment="Center" />
                        <NumericUpDown Value="{Binding OutputChannel, Mode=TwoWay}" Minimum="1" Maximum="64" />
                        <TextBlock Text="{x:Static res:Strings.GainDbLabel}" VerticalAlignment="Center" />
                        <NumericUpDown Value="{Binding GainDb, Mode=TwoWay}" Minimum="-60" Maximum="12" Increment="0.5" FormatString="0.#" />
                        <CheckBox Content="{x:Static res:Strings.CueRouteMuteShortLabel}" IsChecked="{Binding Muted, Mode=TwoWay}" VerticalAlignment="Center" />
                      </StackPanel>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </StackPanel>
            </ScrollViewer>
          </TabItem>

          <TabItem Header="{x:Static res:Strings.VideoTabLabel}"
                   IsVisible="{Binding HasSelectedMediaCue}">
            <ScrollViewer>
              <StackPanel Spacing="8" Margin="6">
                <WrapPanel ItemSpacing="6">
                  <Button Content="{x:Static res:Strings.AddVideoPlacementButton}" Command="{Binding AddVideoPlacementCommand}" />
                  <Button Content="{x:Static res:Strings.RemoveButton}" Command="{Binding RemoveVideoPlacementCommand}" />
                </WrapPanel>
                <TextBlock Opacity="0.65"
                           TextWrapping="Wrap"
                           Text="{x:Static res:Strings.NoVideoPlacementsHint}"
                           IsVisible="{Binding VisibleVideoPlacements.Count, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=0}" />
                <ListBox ItemsSource="{Binding VisibleVideoPlacements}"
                         SelectedItem="{Binding SelectedVideoPlacement, Mode=TwoWay}">
                  <ListBox.ItemTemplate>
                    <DataTemplate DataType="vm:CueVideoPlacementViewModel">
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{x:Static res:Strings.CompositionLabel}" VerticalAlignment="Center" />
                        <ComboBox SelectedValue="{Binding CompositionId, Mode=TwoWay}"
                                  SelectedValueBinding="{Binding Id}"
                                  DisplayMemberBinding="{Binding DisplayName}"
                                  ItemsSource="{Binding $parent[UserControl].((vm:CuePlayerViewModel)DataContext).VisibleCompositions}"
                                  MinWidth="220" />
                        <TextBlock Text="{x:Static res:Strings.LayerIndexLabel}" VerticalAlignment="Center" />
                        <NumericUpDown Value="{Binding LayerIndex, Mode=TwoWay}" VerticalAlignment="Center" Minimum="-100" Maximum="100" />
                        <TextBlock Text="{x:Static res:Strings.LayerPositionLabel}" VerticalAlignment="Center" />
                        <ComboBox SelectedItem="{Binding Position, Mode=TwoWay}"
                                  ItemsSource="{Binding $parent[UserControl].((vm:CuePlayerViewModel)DataContext).LayerPositions}"
                                  MinWidth="120" />
                        <TextBlock Text="{x:Static res:Strings.OpacityLabel}" VerticalAlignment="Center" />
                        <Slider Minimum="0" Maximum="1" SmallChange="0.05"
                                Value="{Binding Opacity, Mode=TwoWay}" Width="120" />
                      </StackPanel>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </StackPanel>
            </ScrollViewer>
          </TabItem>

          <TabItem Header="{x:Static res:Strings.ActionTabLabel}"
                   IsVisible="{Binding HasSelectedActionCue}">
            <StackPanel Spacing="8" Margin="6">
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                <TextBlock Grid.Column="0" Text="{x:Static res:Strings.ActionKindLabel}" VerticalAlignment="Center" />
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding BuilderActionKinds}"
                          SelectedItem="{Binding SelectedCueNode.ActionKind, Mode=TwoWay}" />
              </Grid>
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                <TextBlock Grid.Column="0" Text="{x:Static res:Strings.ActionCommandLabel}" VerticalAlignment="Center" />
                <TextBox Grid.Column="1" Text="{Binding SelectedCueNode.SourceOrAction, Mode=TwoWay}" />
              </Grid>
              <Button Content="{x:Static res:Strings.EditActionButton}"
                      Command="{Binding EditActionCueCommand}"
                      HorizontalAlignment="Left" />
            </StackPanel>
          </TabItem>

          <TabItem Header="{x:Static res:Strings.CommentTabLabel}"
                   IsVisible="{Binding HasSelectedCommentCue}">
            <StackPanel Spacing="6" Margin="6">
              <TextBlock Text="{x:Static res:Strings.CommentTextLabel}" />
              <TextBox AcceptsReturn="True"
                       MinHeight="120"
                       TextWrapping="Wrap"
                       Text="{Binding SelectedCueNode.SourceOrAction, Mode=TwoWay}" />
            </StackPanel>
          </TabItem>

          <TabItem Header="{x:Static res:Strings.GroupTabLabel}"
                   IsVisible="{Binding HasSelectedGroupCue}">
            <StackPanel Spacing="8" Margin="6">
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                <TextBlock Grid.Column="0" Text="{x:Static res:Strings.GroupFireModeLabel}" VerticalAlignment="Center" />
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding GroupFireModes}"
                          SelectedItem="{Binding SelectedCueNode.GroupFireMode, Mode=TwoWay}" />
              </Grid>
            </StackPanel>
          </TabItem>
        </TabControl>
      </Expander>

      <TreeDataGrid Name="CueTreeGrid" />
    </DockPanel>
  </DockPanel>
</UserControl>
