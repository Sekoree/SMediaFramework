<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:common="clr-namespace:Classic.CommonControls;assembly=Classic.CommonControls.Avalonia"
             xmlns:views="using:HaPlay.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:HaPlay.ViewModels"
             xmlns:res="using:HaPlay.Resources"
             mc:Ignorable="d" d:DesignWidth="980" d:DesignHeight="700"
             x:Class="HaPlay.Views.SoundboardView"
             x:DataType="vm:SoundboardWorkspaceViewModel">

  <UserControl.Styles>
    <!-- A11Y-02: tiles are Buttons, not bare Borders - focusable, keyboard-activatable (Space/Enter),
         and exposed to screen readers with a Button role + name. A minimal flat template keeps the exact
         pre-existing chrome (state classes recolour PART_Chrome) while the base Button supplies focus,
         keyboard activation, and a visible focus ring. An unbound tile outside edit mode stays fully blank
         but KEEPS its grid cell (UniformGrid arranges by child order), so bound tiles never shift under a
         touch operator's fingers. -->
    <Style Selector="Button.tile">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Stretch" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border Name="PART_Chrome"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="{TemplateBinding CornerRadius}">
            <ContentPresenter Content="{TemplateBinding Content}"
                              HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="Button.tile.editing /template/ Border#PART_Chrome">
      <Setter Property="Background" Value="#0D808080" />
      <Setter Property="BorderBrush" Value="#33808080" />
    </Style>
    <Style Selector="Button.tile.bound /template/ Border#PART_Chrome">
      <Setter Property="Background" Value="#1E808080" />
      <Setter Property="BorderBrush" Value="#55808080" />
    </Style>
    <Style Selector="Button.tile.playing /template/ Border#PART_Chrome">
      <Setter Property="Background" Value="#2A4A9A4A" />
      <Setter Property="BorderBrush" Value="#7F4ACA4A" />
    </Style>
    <Style Selector="Button.tile.fading /template/ Border#PART_Chrome">
      <Setter Property="Background" Value="#2ABA8A2A" />
      <Setter Property="BorderBrush" Value="#7FDAAA3A" />
    </Style>
    <Style Selector="Button.tile.selected /template/ Border#PART_Chrome">
      <!-- Classic Highlight - the old SystemAccentColor was a Fluent resource that no longer resolves. -->
      <Setter Property="BorderBrush" Value="{DynamicResource {x:Static common:SystemColors.HighlightBrushKey}}" />
      <Setter Property="BorderThickness" Value="2" />
    </Style>
    <!-- Keyboard focus ring (defined last so it wins over the state border while focused). -->
    <Style Selector="Button.tile:focus-visible /template/ Border#PART_Chrome">
      <Setter Property="BorderBrush" Value="{DynamicResource {x:Static common:SystemColors.HighlightBrushKey}}" />
      <Setter Property="BorderThickness" Value="2" />
    </Style>
  </UserControl.Styles>

  <DockPanel Margin="8" LastChildFill="True">

    <!-- Top bar: board tabs, add board (edit), stop all, edit toggle. -->
    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="6" Margin="0,0,0,8">
      <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
        <StackPanel Orientation="Horizontal" Spacing="4">
          <ListBox ItemsSource="{Binding Boards}"
                   SelectedItem="{Binding SelectedBoard, Mode=TwoWay}">
            <ListBox.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" Spacing="4" />
              </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
              <DataTemplate DataType="vm:SoundboardViewModel">
                <TextBlock Text="{Binding Name}" Padding="10,6" MinWidth="48" TextAlignment="Center" />
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
          <Button Content="{x:Static res:Strings.SoundboardAddBoardButton}"
                  Command="{Binding AddBoardCommand}"
                  VerticalAlignment="Center"
                  IsVisible="{Binding IsEditMode}" />
        </StackPanel>
      </ScrollViewer>
      <Button Grid.Column="2"
              Content="{x:Static res:Strings.SoundboardStopAllButton}"
              Command="{Binding StopAllCommand}"
              MinHeight="36" VerticalAlignment="Center" />
      <ToggleButton Grid.Column="3"
                    Content="{x:Static res:Strings.SoundboardEditModeToggle}"
                    ToolTip.Tip="{x:Static res:Strings.SoundboardEditModeTooltip}"
                    IsChecked="{Binding IsEditMode, Mode=TwoWay}"
                    MinHeight="36" VerticalAlignment="Center" />
    </Grid>

    <!-- Edit panel (right). -->
    <Border DockPanel.Dock="Right" Width="280" Margin="8,0,0,0"
            BorderBrush="#33808080" BorderThickness="1" CornerRadius="0" Padding="10"
            IsVisible="{Binding IsEditMode}">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="8">

          <!-- Selected tile (classic group box) -->
          <HeaderedContentControl Header="{x:Static res:Strings.SoundboardTileSettingsHeader}">
           <StackPanel Spacing="6">
          <TextBlock Text="{x:Static res:Strings.SoundboardNoTileSelectedHint}"
                     TextWrapping="Wrap" Opacity="0.6"
                     IsVisible="{Binding SelectedTile, Converter={x:Static ObjectConverters.IsNull}}" />
          <StackPanel Spacing="6"
                      IsVisible="{Binding SelectedTile, Converter={x:Static ObjectConverters.IsNotNull}}">
            <TextBlock Text="{x:Static res:Strings.SoundboardTileFileLabel}" Opacity="0.7" FontSize="11" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
              <TextBlock Grid.Column="0"
                         Text="{Binding SelectedTile.FileNameDisplay}"
                         VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                         ToolTip.Tip="{Binding SelectedTile.FilePath}" />
              <Button Grid.Column="1" Content="{x:Static res:Strings.SoundboardBrowseButton}"
                      Click="OnBrowseTileFileClick" />
            </Grid>

            <TextBlock Text="{x:Static res:Strings.SoundboardTileNameLabel}" Opacity="0.7" FontSize="11" />
            <TextBox Text="{Binding SelectedTile.Label, Mode=TwoWay}"
                     PlaceholderText="{Binding SelectedTile.FileNameDisplay}"
                     ToolTip.Tip="{x:Static res:Strings.SoundboardTileNameTooltip}" />

            <TextBlock Text="{x:Static res:Strings.SoundboardTileOutputLabel}" Opacity="0.7" FontSize="11" />
            <ComboBox ItemsSource="{Binding TileOutputOptions}"
                      SelectedValue="{Binding SelectedTile.OutputLineId, Mode=TwoWay}"
                      SelectedValueBinding="{Binding Id}"
                      HorizontalAlignment="Stretch">
              <ComboBox.ItemTemplate>
                <DataTemplate DataType="vm:SoundboardOutputOption">
                  <TextBlock Text="{Binding Name}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock Text="{x:Static res:Strings.SoundboardTileVolumeLabel}" Opacity="0.7" FontSize="11" />
            <Grid ColumnDefinitions="*,44" ColumnSpacing="6">
              <Slider Grid.Column="0" Minimum="0" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True"
                      Value="{Binding SelectedTile.VolumePercent, Mode=TwoWay}" />
              <TextBlock Grid.Column="1" VerticalAlignment="Center"
                         Text="{Binding SelectedTile.VolumePercent, StringFormat='{}{0:0}%'}" />
            </Grid>

            <TextBlock Text="{x:Static res:Strings.SoundboardTileFadeOutLabel}" Opacity="0.7" FontSize="11" />
            <NumericUpDown FormatString="0" Minimum="0" Maximum="60000" Increment="250"
                           Value="{Binding SelectedTile.FadeOutMs, Mode=TwoWay}" />

            <CheckBox Content="{x:Static res:Strings.SoundboardTileLoopLabel}"
                      IsChecked="{Binding SelectedTile.Loop, Mode=TwoWay}" />

            <Button Content="{x:Static res:Strings.SoundboardClearTileButton}"
                    Command="{Binding ClearSelectedTileCommand}" />
          </StackPanel>
           </StackPanel>
          </HeaderedContentControl>

          <!-- Board settings + defaults (classic group box) -->
          <HeaderedContentControl Header="{x:Static res:Strings.SoundboardBoardSettingsHeader}" Margin="0,4,0,0">
          <StackPanel Spacing="6" IsVisible="{Binding SelectedBoard, Converter={x:Static ObjectConverters.IsNotNull}}">
            <TextBlock Text="{x:Static res:Strings.SoundboardBoardNameLabel}" Opacity="0.7" FontSize="11" />
            <TextBox Text="{Binding SelectedBoard.Name, Mode=TwoWay}" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
              <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="{x:Static res:Strings.SoundboardRowsLabel}" Opacity="0.7" FontSize="11" />
                <NumericUpDown FormatString="0" Minimum="1" Maximum="12" Increment="1"
                               Value="{Binding SelectedBoard.Rows, Mode=TwoWay}" />
              </StackPanel>
              <StackPanel Grid.Column="1" Spacing="4">
                <TextBlock Text="{x:Static res:Strings.SoundboardColumnsLabel}" Opacity="0.7" FontSize="11" />
                <NumericUpDown FormatString="0" Minimum="1" Maximum="12" Increment="1"
                               Value="{Binding SelectedBoard.Columns, Mode=TwoWay}" />
              </StackPanel>
            </Grid>

            <TextBlock Text="{x:Static res:Strings.SoundboardDefaultsHeader}"
                       FontWeight="SemiBold" Margin="0,6,0,0" />

            <TextBlock Text="{x:Static res:Strings.SoundboardTileOutputLabel}" Opacity="0.7" FontSize="11" />
            <ComboBox ItemsSource="{Binding BoardOutputOptions}"
                      SelectedValue="{Binding SelectedBoard.DefaultOutputLineId, Mode=TwoWay}"
                      SelectedValueBinding="{Binding Id}"
                      HorizontalAlignment="Stretch">
              <ComboBox.ItemTemplate>
                <DataTemplate DataType="vm:SoundboardOutputOption">
                  <TextBlock Text="{Binding Name}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock Text="{x:Static res:Strings.SoundboardTileVolumeLabel}" Opacity="0.7" FontSize="11" />
            <Grid ColumnDefinitions="*,44" ColumnSpacing="6">
              <Slider Grid.Column="0" Minimum="0" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True"
                      Value="{Binding SelectedBoard.DefaultVolumePercent, Mode=TwoWay}" />
              <TextBlock Grid.Column="1" VerticalAlignment="Center"
                         Text="{Binding SelectedBoard.DefaultVolumePercent, StringFormat='{}{0:0}%'}" />
            </Grid>

            <TextBlock Text="{x:Static res:Strings.SoundboardTileFadeOutLabel}" Opacity="0.7" FontSize="11" />
            <NumericUpDown FormatString="0" Minimum="0" Maximum="60000" Increment="250"
                           Value="{Binding SelectedBoard.DefaultFadeOutMs, Mode=TwoWay}" />

            <CheckBox Content="{x:Static res:Strings.SoundboardTileLoopLabel}"
                      IsChecked="{Binding SelectedBoard.DefaultLoop, Mode=TwoWay}" />

            <Button Content="{x:Static res:Strings.SoundboardRemoveBoardButton}"
                    Command="{Binding RemoveSelectedBoardCommand}"
                    Margin="0,6,0,0" />

            <Separator Margin="0,4" />

            <!-- Standalone .haplayboards files: one board, the whole collection, or import. -->
            <WrapPanel ItemSpacing="6" LineSpacing="6">
              <Button Content="{x:Static res:Strings.SoundboardSaveBoardButton}"
                      Command="{Binding SaveSelectedBoardAsCommand}" />
              <Button Content="{x:Static res:Strings.SoundboardSaveAllBoardsButton}"
                      Command="{Binding SaveAllBoardsAsCommand}" />
              <Button Content="{x:Static res:Strings.SoundboardImportBoardsButton}"
                      Command="{Binding ImportBoardsCommand}" />
            </WrapPanel>
          </StackPanel>
          </HeaderedContentControl>
        </StackPanel>
      </ScrollViewer>
    </Border>

    <!-- Tile grid - one classic group box per board, headed by the board's name. -->
    <HeaderedContentControl Header="{Binding SelectedBoard.Name}" Padding="6">
    <Panel>
    <!-- UX-10: empty-board call-to-action (icon + one line + primary action), matching the I/O workspace's
         empty state instead of showing a blank grid. Hidden in edit mode (the tiles show "+" drop hints). -->
    <StackPanel Spacing="10" HorizontalAlignment="Center" VerticalAlignment="Center"
                MaxWidth="380" IsVisible="{Binding ShowEmptyBoardHint}">
      <PathIcon Data="{x:Static views:AppIcons.Grid}" Width="34" Height="34" Opacity="0.3"
                HorizontalAlignment="Center" />
      <TextBlock Text="{x:Static res:Strings.SoundboardEmptyBoardHint}" Opacity="0.65"
                 TextWrapping="Wrap" TextAlignment="Center" />
      <Button Content="{x:Static res:Strings.SoundboardEmptyBoardAction}"
              Command="{Binding EnableEditModeCommand}" HorizontalAlignment="Center" />
    </StackPanel>
    <ItemsControl x:Name="TileGrid" ItemsSource="{Binding SelectedBoard.Tiles}"
                  IsVisible="{Binding !ShowEmptyBoardHint}">
      <ItemsControl.ItemsPanel>
        <ItemsPanelTemplate>
          <UniformGrid Rows="{Binding SelectedBoard.Rows}" Columns="{Binding SelectedBoard.Columns}" />
        </ItemsPanelTemplate>
      </ItemsControl.ItemsPanel>
      <ItemsControl.ItemTemplate>
        <DataTemplate DataType="vm:SoundboardTileViewModel">
          <Button Classes="tile"
                  Classes.bound="{Binding IsBound}"
                  Classes.playing="{Binding IsPlaying}"
                  Classes.fading="{Binding IsFading}"
                  Classes.editing="{Binding IsEditing}"
                  Margin="3" CornerRadius="0" BorderThickness="1.5" MinHeight="84"
                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                  AutomationProperties.Name="{Binding DisplayName}"
                  Click="OnTileTapped">
            <!-- ConverterParameter can't bind, so the old ObjectConverters.Equal selected-highlight
                 never matched - compare via MultiBinding instead. -->
            <Classes.selected>
              <MultiBinding Converter="{x:Static views:AllEqualConverter.Instance}">
                <Binding Path="$parent[ItemsControl].((vm:SoundboardWorkspaceViewModel)DataContext).SelectedTile" />
                <Binding />
              </MultiBinding>
            </Classes.selected>
            <!-- Keyboard-accessible overflow (Menu key / Shift+F10 once the tile is focused). -->
            <Button.ContextMenu>
              <ContextMenu>
                <MenuItem Header="{x:Static res:Strings.CopyApiUrlMenuItem}"
                          Click="OnCopyTileApiUrlClick" />
              </ContextMenu>
            </Button.ContextMenu>
            <Panel Margin="8,6">
              <!-- Unbound + edit mode: drop-target hint. -->
              <TextBlock Text="+" FontSize="26" Opacity="0.3"
                         HorizontalAlignment="Center" VerticalAlignment="Center"
                         IsVisible="{Binding ShowsDropHint}" />

              <!-- Bound tile face. -->
              <Grid RowDefinitions="*,Auto,Auto,Auto" IsVisible="{Binding IsBound}">
                <Grid Grid.Row="0">
                  <TextBlock Text="{Binding DisplayName}"
                             FontWeight="SemiBold" TextWrapping="Wrap"
                             TextTrimming="CharacterEllipsis" MaxLines="3"
                             TextAlignment="Center"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                  <PathIcon Data="{x:Static views:AppIcons.Loop}" Width="11" Height="11" Opacity="0.6"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            IsVisible="{Binding Loop}" />
                </Grid>
                <ProgressBar Grid.Row="1" Height="8" MinWidth="0" Margin="0,4,0,2"
                             Minimum="0" Maximum="100"
                             Value="{Binding ProgressPercent}"
                             Background="#28808080" />
                <TextBlock Grid.Row="2" Text="{Binding TimeLabel}"
                           FontSize="11" Opacity="0.75" HorizontalAlignment="Center" />
                <!-- Fade countdown: only while a tap-to-fade is running. -->
                <ProgressBar Grid.Row="3" Height="5" MinWidth="0" Margin="0,3,0,0"
                             Minimum="0" Maximum="100"
                             Value="{Binding FadeProgressPercent}"
                             Foreground="#DAAA3A" Background="#28808080"
                             IsVisible="{Binding IsFading}" />
              </Grid>

              <!-- Tile number badge (the {tile} segment of the remote API URL). -->
              <TextBlock Text="{Binding GridIndex}"
                         FontSize="9" Opacity="0.45"
                         HorizontalAlignment="Right" VerticalAlignment="Bottom"
                         Margin="0,0,1,-2"
                         IsVisible="{Binding ShowsGridIndex}" />
            </Panel>
          </Button>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>
    </Panel>
    </HeaderedContentControl>
  </DockPanel>
</UserControl>
