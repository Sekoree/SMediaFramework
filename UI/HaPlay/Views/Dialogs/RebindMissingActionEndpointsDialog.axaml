<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="using:HaPlay.Resources"
        xmlns:vm="using:HaPlay.ViewModels.Dialogs"
        x:Class="HaPlay.Views.Dialogs.RebindMissingActionEndpointsDialog"
        x:DataType="vm:RebindMissingActionEndpointsDialogViewModel"
        Title="{x:Static res:Strings.RebindMissingActionEndpointsTitle}"
        Width="620" Height="420"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        MinWidth="480" MinHeight="280">
  <DockPanel Margin="16">
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,16,0,0">
      <Button Content="{x:Static res:Strings.SkipButton}" Click="SkipClick" IsCancel="True" />
      <Button Content="{x:Static res:Strings.ApplyButton}" Click="OkClick" IsDefault="True" />
    </StackPanel>

    <TextBlock DockPanel.Dock="Top" TextWrapping="Wrap" Margin="0,0,0,12" Opacity="0.85"
               Text="{x:Static res:Strings.RebindMissingActionEndpointsDescription}" />

    <ListBox ItemsSource="{Binding Rows}">
      <ListBox.ItemTemplate>
        <DataTemplate DataType="vm:RebindMissingActionEndpointRowViewModel">
          <Grid ColumnDefinitions="*,*" ColumnSpacing="8" Margin="0,4">
            <StackPanel Grid.Column="0" Spacing="2">
              <TextBlock Text="{Binding MissingLabel}" VerticalAlignment="Center" />
              <TextBlock FontSize="11" Opacity="0.65" Text="{Binding Kind}" />
            </StackPanel>
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding ReplacementOptions}"
                      SelectedItem="{Binding SelectedReplacement, Mode=TwoWay}">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Name}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </Grid>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </DockPanel>
</Window>
