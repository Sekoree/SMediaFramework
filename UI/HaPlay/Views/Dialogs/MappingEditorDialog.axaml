<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="using:HaPlay.Views"
        xmlns:vmd="using:HaPlay.ViewModels.Dialogs"
        x:Class="HaPlay.Views.Dialogs.MappingEditorDialog"
        x:DataType="vmd:MappingEditorViewModel"
        Title="{Binding DialogTitle}"
        Width="1060" Height="640"
        MinWidth="820" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        CanResize="True">
  <DockPanel Margin="12">

    <!-- Top bar: enable, output size, splitter, grid toggle. -->
    <WrapPanel DockPanel.Dock="Top" ItemSpacing="10" LineSpacing="6" Margin="0,0,0,10">
      <CheckBox Content="{Binding EnableLabel}" IsChecked="{Binding MappingEnabled, Mode=TwoWay}" />
      <StackPanel Orientation="Horizontal" Spacing="4" IsVisible="{Binding CanEditOutputSize}">
        <TextBlock Text="{Binding SizeLabel}" VerticalAlignment="Center" />
        <NumericUpDown FormatString="0" Value="{Binding OutputWidth, Mode=TwoWay}" PlaceholderText="canvas" Minimum="16" Maximum="16384" Width="120" />
        <TextBlock Text="×" VerticalAlignment="Center" />
        <NumericUpDown FormatString="0" Value="{Binding OutputHeight, Mode=TwoWay}" PlaceholderText="canvas" Minimum="16" Maximum="16384" Width="120" />
      </StackPanel>
      <StackPanel Orientation="Horizontal" Spacing="4">
        <TextBlock Text="Split into" VerticalAlignment="Center" />
        <NumericUpDown FormatString="0" Value="{Binding SplitColumns, Mode=TwoWay}" Minimum="1" Maximum="64" Width="100" />
        <TextBlock Text="cols ×" VerticalAlignment="Center" />
        <NumericUpDown FormatString="0" Value="{Binding SplitRows, Mode=TwoWay}" Minimum="1" Maximum="64" Width="100" />
        <TextBlock Text="rows" VerticalAlignment="Center" />
        <Button Content="Split" Command="{Binding SplitIntoGridCommand}"
                ToolTip.Tip="Replace all sections with an even grid (one per panel), then nudge each into place" />
      </StackPanel>
      <Button Content="Reset" Command="{Binding ResetToIdentityCommand}"
              ToolTip.Tip="Back to a single full-canvas section" />
      <CheckBox Content="{Binding TestPatternLabel}"
                IsChecked="{Binding ShowTestPattern, Mode=TwoWay}"
                IsVisible="{Binding CanShowTestPattern}"
                ToolTip.Tip="Pushes a labeled grid through the composition (and its mapping) so sections can be aligned against the physical surface" />
    </WrapPanel>

    <Grid ColumnDefinitions="280,12,*">

      <!-- Section list + list ops. -->
      <DockPanel Grid.Column="0">
        <WrapPanel DockPanel.Dock="Top" ItemSpacing="4" Margin="0,0,0,6">
          <Button Content="+" Command="{Binding AddSectionCommand}" ToolTip.Tip="Add section" />
          <Button Command="{Binding DuplicateSectionCommand}" ToolTip.Tip="Duplicate selected">
            <PathIcon Data="{x:Static views:AppIcons.Duplicate}" Width="11" Height="11" />
          </Button>
          <Button Content="–" Command="{Binding RemoveSectionCommand}" ToolTip.Tip="Remove selected" />
          <Button Content="↑" Command="{Binding MoveSectionUpCommand}" ToolTip.Tip="Draw earlier (further back)" />
          <Button Content="↓" Command="{Binding MoveSectionDownCommand}" ToolTip.Tip="Draw later (further front)" />
        </WrapPanel>
        <ListBox ItemsSource="{Binding Sections}"
                 SelectedItem="{Binding SelectedSection, Mode=TwoWay}">
          <ListBox.ItemTemplate>
            <DataTemplate DataType="vmd:MappingSectionViewModel">
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
                <CheckBox Grid.Column="0" IsChecked="{Binding Enabled, Mode=TwoWay}" />
                <TextBox Grid.Column="1" Text="{Binding Name, Mode=TwoWay}" BorderThickness="0" Background="Transparent" />
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>

      <!-- Preview + selected-section fields. -->
      <DockPanel Grid.Column="2">
        <Border DockPanel.Dock="Bottom" BorderBrush="#22808080" BorderThickness="1" CornerRadius="0"
                Padding="8" Margin="0,8,0,0"
                IsEnabled="{Binding SelectedSection, Converter={x:Static ObjectConverters.IsNotNull}}">
          <Grid ColumnDefinitions="Auto,110,Auto,110,Auto,110,Auto,110" RowDefinitions="Auto,Auto,Auto,Auto"
                ColumnSpacing="6" RowSpacing="6">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Src X" VerticalAlignment="Center" ToolTip.Tip="Normalized 0–1 of the composition canvas" />
            <NumericUpDown Grid.Row="0" Grid.Column="1" Value="{Binding SelectedSection.SrcX, Mode=TwoWay}" Minimum="0" Maximum="1" Increment="0.01" FormatString="0.###" />
            <TextBlock Grid.Row="0" Grid.Column="2" Text="Src Y" VerticalAlignment="Center" />
            <NumericUpDown Grid.Row="0" Grid.Column="3" Value="{Binding SelectedSection.SrcY, Mode=TwoWay}" Minimum="0" Maximum="1" Increment="0.01" FormatString="0.###" />
            <TextBlock Grid.Row="0" Grid.Column="4" Text="Src W" VerticalAlignment="Center" />
            <NumericUpDown Grid.Row="0" Grid.Column="5" Value="{Binding SelectedSection.SrcWidth, Mode=TwoWay}" Minimum="0.001" Maximum="1" Increment="0.01" FormatString="0.###" />
            <TextBlock Grid.Row="0" Grid.Column="6" Text="Src H" VerticalAlignment="Center" />
            <NumericUpDown Grid.Row="0" Grid.Column="7" Value="{Binding SelectedSection.SrcHeight, Mode=TwoWay}" Minimum="0.001" Maximum="1" Increment="0.01" FormatString="0.###" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Dest X" VerticalAlignment="Center" ToolTip.Tip="Output pixels (drag the section in the preview)" />
            <NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding SelectedSection.DestX, Mode=TwoWay}" Increment="1" FormatString="0.#" />
            <TextBlock Grid.Row="1" Grid.Column="2" Text="Dest Y" VerticalAlignment="Center" />
            <NumericUpDown Grid.Row="1" Grid.Column="3" Value="{Binding SelectedSection.DestY, Mode=TwoWay}" Increment="1" FormatString="0.#" />
            <TextBlock Grid.Row="1" Grid.Column="4" Text="Dest W" VerticalAlignment="Center" ToolTip.Tip="0 = natural slice size" />
            <NumericUpDown Grid.Row="1" Grid.Column="5" Value="{Binding SelectedSection.DestWidth, Mode=TwoWay}" Minimum="0" Increment="1" FormatString="0.#" />
            <TextBlock Grid.Row="1" Grid.Column="6" Text="Dest H" VerticalAlignment="Center" ToolTip.Tip="0 = natural slice size" />
            <NumericUpDown Grid.Row="1" Grid.Column="7" Value="{Binding SelectedSection.DestHeight, Mode=TwoWay}" Minimum="0" Increment="1" FormatString="0.#" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Rotation°" VerticalAlignment="Center" />
            <NumericUpDown Grid.Row="2" Grid.Column="1" Value="{Binding SelectedSection.RotationDegrees, Mode=TwoWay}" Minimum="-360" Maximum="360" Increment="0.1" FormatString="0.##" />
            <TextBlock Grid.Row="2" Grid.Column="2" Text="Opacity" VerticalAlignment="Center" />
            <NumericUpDown Grid.Row="2" Grid.Column="3" Value="{Binding SelectedSection.Opacity, Mode=TwoWay}" Minimum="0" Maximum="1" Increment="0.05" FormatString="0.##" />
            <TextBlock Grid.Row="2" Grid.Column="4" Text="Brightness" VerticalAlignment="Center" ToolTip.Tip="Panel brightness matching" />
            <NumericUpDown Grid.Row="2" Grid.Column="5" Value="{Binding SelectedSection.Brightness, Mode=TwoWay}" Minimum="0" Maximum="1" Increment="0.05" FormatString="0.##" />

            <CheckBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Content="Mesh warp"
                      IsChecked="{Binding SelectedSection.MeshEnabled, Mode=TwoWay}"
                      ToolTip.Tip="Bend this section through a control-point grid for projection onto non-flat surfaces (GL output path). Drag the points in the preview." />
            <TextBlock Grid.Row="3" Grid.Column="2" Text="Cols" VerticalAlignment="Center" />
            <NumericUpDown Grid.Row="3" Grid.Column="3" Value="{Binding SelectedSection.MeshColumns, Mode=TwoWay}"
                           Minimum="2" Maximum="16" Increment="1" FormatString="0"
                           IsEnabled="{Binding SelectedSection.MeshEnabled}" />
            <TextBlock Grid.Row="3" Grid.Column="4" Text="Rows" VerticalAlignment="Center" />
            <NumericUpDown Grid.Row="3" Grid.Column="5" Value="{Binding SelectedSection.MeshRows, Mode=TwoWay}"
                           Minimum="2" Maximum="16" Increment="1" FormatString="0"
                           IsEnabled="{Binding SelectedSection.MeshEnabled}" />
            <Button Grid.Row="3" Grid.Column="6" Grid.ColumnSpan="2" Content="Reset mesh"
                    Command="{Binding SelectedSection.ResetMeshCommand}"
                    IsEnabled="{Binding SelectedSection.MeshEnabled}"
                    ToolTip.Tip="Back to the flat identity grid" />
          </Grid>
        </Border>

        <!-- Dest-space preview: sections drawn to scale; drag to move. Rendered in code-behind. -->
        <Border BorderBrush="#22808080" BorderThickness="1" CornerRadius="0" Padding="4"
                Background="#10000000">
          <!-- ClipToBounds on the host (not the canvas): sections dragged past the output rect stay
               visible in the surrounding "offstage" area but never paint over the section list. -->
          <Panel x:Name="PreviewHost" ClipToBounds="True">
            <Canvas x:Name="PreviewCanvas" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="#FF101010" ClipToBounds="False" />
          </Panel>
        </Border>
      </DockPanel>
    </Grid>
  </DockPanel>
</Window>
