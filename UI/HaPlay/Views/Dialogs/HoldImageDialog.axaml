<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HaPlay.ViewModels"
        xmlns:res="using:HaPlay.Resources"
        x:Class="HaPlay.Views.Dialogs.HoldImageDialog"
        x:DataType="vm:MediaPlayerViewModel"
        Title="{x:Static res:Strings.HoldImageDialogTitle}"
        Width="520" Height="220"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        MinWidth="420" MinHeight="180">
  <DockPanel Margin="16">
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,16,0,0">
      <Button Content="{x:Static res:Strings.ClearButton}" Command="{Binding ClearFallbackImageCommand}" />
      <Button Content="{x:Static res:Strings.CloseButton}" Click="CloseClick" IsDefault="True" IsCancel="True" />
    </StackPanel>

    <StackPanel Spacing="10">
      <TextBlock TextWrapping="Wrap" Opacity="0.8"
                 Text="{x:Static res:Strings.IdleImageHeaderTooltip}" />
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
        <TextBox Grid.Column="0"
                 PlaceholderText="{x:Static res:Strings.FallbackPathPlaceholder}"
                 Text="{Binding FallbackImagePath}" />
        <Button Grid.Column="1" Content="{x:Static res:Strings.BrowseButton}"
                Command="{Binding BrowseFallbackCommand}" />
      </Grid>
      <TextBlock Text="{Binding HoldImageSummary}" Opacity="0.6" FontSize="12" />
    </StackPanel>
  </DockPanel>
</Window>
