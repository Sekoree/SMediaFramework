<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="using:HaPlay.Resources"
        xmlns:vm="using:HaPlay.ViewModels"
        xmlns:models="using:HaPlay.Models"
        xmlns:tdg="using:Avalonia.Controls"
        x:Class="HaPlay.Views.Dialogs.AudioMatrixDialog"
        x:DataType="vm:MediaPlayerViewModel"
        Title="{x:Static res:Strings.AudioMatrixDialogTitle}"
        Width="860" Height="620"
        MinWidth="640" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        CanResize="True">
  <DockPanel Margin="10">
    <StackPanel DockPanel.Dock="Bottom"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,10,0,0">
      <Button Content="{x:Static res:Strings.CloseButton}" Click="CloseClick" IsCancel="True" />
    </StackPanel>

    <ScrollViewer HorizontalScrollBarVisibility="Auto">
      <StackPanel Spacing="8">

        <Grid ColumnDefinitions="Auto,96,*" ColumnSpacing="8" Margin="0,0,0,4">
          <TextBlock Grid.Column="0" Text="Source channels" VerticalAlignment="Center" />
          <NumericUpDown Grid.Column="1"
                         Minimum="1"
                         Maximum="64"
                         FormatString="0"
                         Value="{Binding AudioMatrixSourceChannels, Mode=TwoWay}"
                         ToolTip.Tip="Expected source channel count for preparing the matrix before media is opened." />
        </Grid>

        <!-- P5b: auto-preset rules — "when an N-channel source loads, apply this preset". This is
             the predetermined answer for the occasional 5.1 file in a stereo show. -->
        <Border Classes="Card" Padding="8">
          <StackPanel Spacing="6">
            <TextBlock Classes="SectionText" Text="{x:Static res:Strings.AutoPresetRulesTitle}" />
            <TextBlock Classes="CaptionText" TextWrapping="Wrap"
                       Text="{x:Static res:Strings.AutoPresetRulesHint}" />
            <ItemsControl ItemsSource="{Binding ChannelPresetRules}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="models:ChannelPresetRule">
                  <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" Margin="0,1">
                    <TextBlock Grid.Column="0" VerticalAlignment="Center"
                               Text="{Binding SourceChannels, StringFormat='{}{0} ch →'}" />
                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Opacity="0.85"
                               Text="{Binding Preset}" />
                    <Button Grid.Column="2" Classes="Dense" Content="{x:Static res:Strings.RemoveButton}"
                            Command="{Binding $parent[Window].((vm:MediaPlayerViewModel)DataContext).RemoveChannelPresetRuleCommand}"
                            CommandParameter="{Binding}" />
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Grid ColumnDefinitions="Auto,90,Auto,*,Auto" ColumnSpacing="8">
              <TextBlock Grid.Column="0" Text="{x:Static res:Strings.AutoPresetWhenLabel}" VerticalAlignment="Center" />
              <NumericUpDown Grid.Column="1" Minimum="1" Maximum="64" FormatString="0"
                             Value="{Binding NewRuleChannels, Mode=TwoWay}" />
              <TextBlock Grid.Column="2" Text="{x:Static res:Strings.AutoPresetApplyLabel}" VerticalAlignment="Center" />
              <ComboBox Grid.Column="3" HorizontalAlignment="Stretch"
                        ItemsSource="{Binding DownmixPresetChoices}"
                        SelectedItem="{Binding NewRulePreset, Mode=TwoWay}" />
              <Button Grid.Column="4" Classes="Std" Content="{x:Static res:Strings.AddRuleButton}"
                      Command="{Binding AddChannelPresetRuleCommand}" />
            </Grid>
          </StackPanel>
        </Border>

        <!-- Per-output mix-mode preset row -->
        <ItemsControl ItemsSource="{Binding Outputs}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:PlayerOutputBinding">
              <StackPanel Spacing="2" Margin="0,2" IsVisible="{Binding IsSelected}">
                <Grid ColumnDefinitions="*,128,Auto,140,64" ColumnSpacing="8">
                  <TextBlock Grid.Column="0" VerticalAlignment="Center"
                             Text="{Binding Line.EffectiveName}" />
                  <ComboBox Grid.Column="1" MinWidth="128"
                            ItemsSource="{Binding $parent[Window].((vm:MediaPlayerViewModel)DataContext).MixModes}"
                            SelectedItem="{Binding MixMode}"
                            ToolTip.Tip="{x:Static res:Strings.MixPresetTooltip}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding Converter={x:Static vm:EnumDisplayConverter.Instance}}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                  <CheckBox Grid.Column="2" Content="{x:Static res:Strings.MuteToggleLabel}"
                            IsChecked="{Binding IsMuted}"
                            ToolTip.Tip="{x:Static res:Strings.DeviceOutputMuteTooltip}" />
                  <Slider Grid.Column="3" Minimum="-60" Maximum="12"
                          Value="{Binding GainDb, Mode=TwoWay}"
                          ToolTip.Tip="{x:Static res:Strings.PerDeviceGainTooltip}" />
                  <TextBlock Grid.Column="4" FontFamily="Consolas,monospace"
                             Text="{Binding GainText}"
                             VerticalAlignment="Center" />
                </Grid>
                <!-- Multichannel downmix quick-apply (no-op if the preset doesn't fit the channel layout). -->
                <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,0,2"
                            ToolTip.Tip="{x:Static res:Strings.DownmixPresetsTooltip}">
                  <TextBlock Text="{x:Static res:Strings.DownmixPresetsLabel}" Opacity="0.6"
                             FontSize="11" VerticalAlignment="Center" />
                  <Button Content="Pass-through" Padding="6,2" FontSize="11"
                          Command="{Binding Matrix.ApplyDownmixPresetCommand}"
                          CommandParameter="{x:Static models:AudioDownmixPreset.PassThrough}" />
                  <Button Content="Mono to stereo" Padding="6,2" FontSize="11"
                          Command="{Binding Matrix.ApplyDownmixPresetCommand}"
                          CommandParameter="{x:Static models:AudioDownmixPreset.MonoToStereo}" />
                  <Button Content="5.1 to stereo" Padding="6,2" FontSize="11"
                          Command="{Binding Matrix.ApplyDownmixPresetCommand}"
                          CommandParameter="{x:Static models:AudioDownmixPreset.Surround51ToStereo}" />
                  <Button Content="Drop LFE" Padding="6,2" FontSize="11"
                          Command="{Binding Matrix.ApplyDownmixPresetCommand}"
                          CommandParameter="{x:Static models:AudioDownmixPreset.DropLfe}" />
                </StackPanel>
              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Border BorderBrush="#22FFFFFF" BorderThickness="0,1,0,0" Margin="0,2,0,0" Padding="0,8,0,0"
                IsVisible="{Binding HasAudioMatrixInputTrims}">
          <StackPanel Spacing="4">
            <TextBlock Text="{x:Static res:Strings.InputTrimsTitle}" FontWeight="SemiBold" />
            <ItemsControl ItemsSource="{Binding AudioMatrixInputTrims}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:AudioMatrixInputTrimViewModel">
                  <Grid ColumnDefinitions="80,Auto,140,60" ColumnSpacing="8" Margin="0,1">
                    <TextBlock Grid.Column="0" VerticalAlignment="Center"
                               Text="{Binding Label}" />
                    <CheckBox Grid.Column="1" Content="{x:Static res:Strings.MuteToggleLabel}"
                              IsChecked="{Binding Muted}" />
                    <Slider Grid.Column="2" Minimum="-24" Maximum="24"
                            Value="{Binding GainDb, Mode=TwoWay}" />
                    <TextBlock Grid.Column="3" FontFamily="Consolas,monospace" VerticalAlignment="Center"
                               Text="{Binding GainDb, StringFormat={}{0:0.#} dB}" />
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <!-- Per-cell matrix -->
        <TreeDataGrid Name="MatrixTreeGrid"
                      MinHeight="120" MaxHeight="400"
                      IsVisible="{Binding HasAudioMatrix}"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="False"
                      ShowColumnHeaders="True" />
        <TextBlock Opacity="0.55" FontSize="11"
                   IsVisible="{Binding !HasAudioMatrix}"
                   Text="{x:Static res:Strings.AudioMatrixEmptyHint}" />

        <Border BorderBrush="#22FFFFFF" BorderThickness="0,1,0,0" Margin="0,4,0,0" Padding="0,8,0,0">
          <StackPanel Spacing="6">
            <TextBlock Text="{x:Static res:Strings.ActiveRoutesTitle}" FontWeight="SemiBold" />
            <TreeDataGrid Name="MatrixRoutesTreeGrid"
                          MinHeight="96" MaxHeight="280"
                          IsVisible="{Binding HasAudioMatrixRoutes}"
                          CanUserResizeColumns="True"
                          CanUserSortColumns="False"
                          ShowColumnHeaders="True" />
            <TextBlock Opacity="0.55" FontSize="11"
                       IsVisible="{Binding !HasAudioMatrixRoutes}"
                       Text="{x:Static res:Strings.NoActiveRoutesHint}" />
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</Window>
