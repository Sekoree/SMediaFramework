<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="using:HaPlay.Resources"
        xmlns:vm="using:HaPlay.ViewModels.Dialogs"
        x:Class="HaPlay.Views.Dialogs.RenumberSelectionDialog"
        x:DataType="vm:RenumberSelectionDialogViewModel"
        Title="{Binding DialogTitle}"
        Width="420" Height="260"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        SizeToContent="Height"
        MinWidth="360">
  <DockPanel Margin="16">
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,16,0,0">
      <Button Content="{x:Static res:Strings.CancelButton}" Click="CancelClick" IsCancel="True" />
      <Button Content="{x:Static res:Strings.OkButton}" Click="OkClick" IsDefault="True" />
    </StackPanel>

    <StackPanel Spacing="10">
      <Grid ColumnDefinitions="100,*" RowDefinitions="Auto,Auto" RowSpacing="8" ColumnSpacing="8">
        <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static res:Strings.RenumberStartLabel}" VerticalAlignment="Center" />
        <NumericUpDown Grid.Row="0" Grid.Column="1" Value="{Binding Start, Mode=TwoWay}" Minimum="0" Maximum="9999" Increment="1" FormatString="0.##" />
        <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static res:Strings.RenumberStepLabel}" VerticalAlignment="Center" />
        <NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding Step, Mode=TwoWay}" Minimum="0.01" Maximum="100" Increment="0.5" FormatString="0.##" />
      </Grid>
      <StackPanel Spacing="4" Margin="0,4,0,0">
        <TextBlock Text="{x:Static res:Strings.RenumberScopeLabel}" FontWeight="SemiBold" />
        <RadioButton Content="{x:Static res:Strings.RenumberScopeAllLabel}" IsChecked="{Binding ScopeAll, Mode=TwoWay}" GroupName="renumber-scope" />
        <RadioButton Content="{x:Static res:Strings.RenumberScopeRootLabel}" IsChecked="{Binding ScopeRoot, Mode=TwoWay}" GroupName="renumber-scope" />
        <RadioButton Content="{x:Static res:Strings.RenumberScopeSelectionLabel}" IsChecked="{Binding ScopeSelection, Mode=TwoWay}" GroupName="renumber-scope" />
      </StackPanel>
    </StackPanel>
  </DockPanel>
</Window>
