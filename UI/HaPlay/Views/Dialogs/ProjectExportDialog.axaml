<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="using:HaPlay.Resources"
        xmlns:dialogs="using:HaPlay.Views.Dialogs"
        x:Class="HaPlay.Views.Dialogs.ProjectExportDialog"
        x:DataType="dialogs:ProjectExportDialog"
        Title="{x:Static res:Strings.ExportSectionsDialogTitle}"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
  <StackPanel Margin="14" Spacing="10">
    <TextBlock Classes="CaptionText" TextWrapping="Wrap"
               Text="{x:Static res:Strings.ExportSectionsDialogHint}" />

    <ItemsControl ItemsSource="{Binding Choices}">
      <ItemsControl.ItemTemplate>
        <DataTemplate DataType="dialogs:SectionChoice">
          <CheckBox Margin="0,2" Content="{Binding Label}" IsChecked="{Binding IsChecked, Mode=TwoWay}" />
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>

    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
      <Button Content="{x:Static res:Strings.CancelButton}" IsCancel="True" Click="OnCancelClick" />
      <Button Content="{x:Static res:Strings.ExportButton}" Classes="Go" IsDefault="True" Click="OnExportClick" />
    </StackPanel>
  </StackPanel>
</Window>
