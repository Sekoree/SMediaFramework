<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HaPlay.ViewModels.Dialogs"
        x:Class="HaPlay.Views.Dialogs.RebindMissingOutputsDialog"
        x:DataType="vm:RebindMissingOutputsDialogViewModel"
        Title="Rebind Missing Outputs"
        Width="560" Height="420"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        MinWidth="440" MinHeight="280">
  <DockPanel Margin="16">
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,16,0,0">
      <Button Content="Skip" Click="SkipClick" IsCancel="True" />
      <Button Content="Apply" Click="OkClick" IsDefault="True" />
    </StackPanel>

    <TextBlock DockPanel.Dock="Top" TextWrapping="Wrap" Margin="0,0,0,12" Opacity="0.85"
               Text="Some player routes reference outputs that are not in this project. Pick a replacement for each missing name." />

    <ListBox ItemsSource="{Binding Rows}">
      <ListBox.ItemTemplate>
        <DataTemplate DataType="vm:RebindMissingOutputRowViewModel">
          <Grid ColumnDefinitions="*,*" ColumnSpacing="8" Margin="0,4">
            <TextBlock Grid.Column="0" Text="{Binding MissingDisplayName}" VerticalAlignment="Center" />
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding ReplacementOptions}"
                      SelectedItem="{Binding SelectedReplacement, Mode=TwoWay}" />
          </Grid>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </DockPanel>
</Window>
