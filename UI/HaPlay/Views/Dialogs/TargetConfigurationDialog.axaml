<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="using:HaPlay.Resources"
        xmlns:views="using:HaPlay.Views"
        xmlns:vm="using:HaPlay.ViewModels"
        x:Class="HaPlay.Views.Dialogs.TargetConfigurationDialog"
        x:DataType="vm:MainViewModel"
        Title="{x:Static res:Strings.TargetConfigurationTitle}"
        Width="980" Height="760"
        MinWidth="780" MinHeight="560"
        WindowStartupLocation="CenterOwner"
        CanResize="True">
  <DockPanel Margin="10">
    <StackPanel DockPanel.Dock="Bottom"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,10,0,0">
      <Button Content="{x:Static res:Strings.CloseButton}" Click="CloseClick" IsCancel="True" />
    </StackPanel>

    <TabControl>
      <TabItem Header="{x:Static res:Strings.TargetOscTabHeader}">
        <views:OscConnectionsView DataContext="{Binding}" />
      </TabItem>
      <TabItem Header="{x:Static res:Strings.TargetMidiTabHeader}">
        <views:MidiDevicesView DataContext="{Binding}" />
      </TabItem>
    </TabControl>
  </DockPanel>
</Window>
