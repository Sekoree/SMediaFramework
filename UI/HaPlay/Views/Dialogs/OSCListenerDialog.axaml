<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HaPlay.ViewModels.Dialogs"
        x:Class="HaPlay.Views.Dialogs.OSCListenerDialog"
        x:DataType="vm:OSCListenerDialogViewModel"
        Title="{Binding Title}"
        Width="420" Height="220"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        SizeToContent="Height">
  <DockPanel Margin="16">
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,16,0,0">
      <Button Content="Cancel" Click="CancelClick" IsCancel="True" />
      <Button Content="Save" Click="OkClick" IsDefault="True" IsEnabled="{Binding IsValid}" />
    </StackPanel>

    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="10">
      <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" VerticalAlignment="Center" />
      <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Name}" PlaceholderText="OSC Listener" />

      <TextBlock Grid.Row="1" Grid.Column="0" Text="Local port" VerticalAlignment="Center" />
      <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding LocalPortText}" PlaceholderText="10020" />

      <CheckBox Grid.Row="2" Grid.Column="1" Content="Enabled" IsChecked="{Binding IsEnabled}" />
    </Grid>
  </DockPanel>
</Window>
