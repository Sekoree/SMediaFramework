<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="using:HaPlay.Resources"
        xmlns:vm="using:HaPlay.ViewModels.Dialogs"
        x:Class="HaPlay.Views.Dialogs.KeyboardShortcutsDialog"
        x:DataType="vm:KeyboardShortcutsDialogViewModel"
        Title="{x:Static res:Strings.KeyboardShortcutsDialogTitle}"
        Width="620" Height="680" MinWidth="520" MinHeight="500"
        WindowStartupLocation="CenterOwner">
  <DockPanel Margin="14">
    <TextBox DockPanel.Dock="Top"
             x:Name="SearchBox"
             PlaceholderText="{x:Static res:Strings.ShortcutsSearchPlaceholder}"
             Text="{Binding SearchText, Mode=TwoWay}"
             Margin="0,0,0,10" />

    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right"
                Spacing="8" Margin="0,10,0,0">
      <Button Content="Reset cue defaults" Click="OnResetClick" />
      <Button Content="Save" IsDefault="True" Click="OnSaveClick" />
      <Button Content="{x:Static res:Strings.CloseButton}" IsCancel="True" Click="OnCloseClick" />
    </StackPanel>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="12">
        <Border BorderBrush="#44808080" BorderThickness="1" Padding="10">
          <StackPanel Spacing="7">
            <TextBlock Text="Cue player hotkeys" FontWeight="SemiBold" />
            <TextBlock Text="Enter a key or combination such as Space, N or Ctrl+Escape. Leave a field blank to disable it. The Stop hotkey stops on the first press and panic-stops when pressed again within 600 ms."
                       TextWrapping="Wrap" Opacity="0.7" />
            <ItemsControl ItemsSource="{Binding CueHotkeyRows}">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="vm:CueHotkeyEditorRow">
                  <Grid ColumnDefinitions="*,180" ColumnSpacing="12" Margin="0,2">
                    <TextBlock Grid.Column="0" Text="{Binding Description}" VerticalAlignment="Center"
                               TextWrapping="Wrap" />
                    <TextBox Grid.Column="1" Text="{Binding Gesture, Mode=TwoWay}" />
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock Text="{Binding ValidationMessage}" Foreground="#C62828"
                       TextWrapping="Wrap" IsVisible="{Binding ValidationMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
          </StackPanel>
        </Border>

        <TextBlock Text="Shortcut reference" FontWeight="SemiBold" />
        <TextBlock Text="{x:Static res:Strings.ShortcutsNoResults}" Opacity="0.6"
                   IsVisible="{Binding !HasResults}" />
        <ItemsControl ItemsSource="{Binding FilteredGroups}" Grid.IsSharedSizeScope="True">
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="vm:ShortcutGroup">
              <StackPanel Spacing="3" Margin="0,0,0,4">
                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Margin="0,0,0,2" />
                <ItemsControl ItemsSource="{Binding Entries}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:ShortcutEntry">
                      <Grid ColumnSpacing="12" Margin="0,1">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="Auto" SharedSizeGroup="Gesture" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#1A808080" CornerRadius="3" Padding="6,1">
                          <TextBlock Text="{Binding Gesture}" FontFamily="monospace" FontSize="12" />
                        </Border>
                        <TextBlock Grid.Column="1" Text="{Binding Description}"
                                   VerticalAlignment="Center" TextWrapping="Wrap" />
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</Window>
