<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="using:HaPlay.Resources"
        xmlns:vm="using:HaPlay.ViewModels.Dialogs"
        x:Class="HaPlay.Views.Dialogs.KeyboardShortcutsDialog"
        x:DataType="vm:KeyboardShortcutsDialogViewModel"
        Title="{x:Static res:Strings.KeyboardShortcutsDialogTitle}"
        Width="460" Height="440"
        WindowStartupLocation="CenterOwner">
  <DockPanel Margin="14">
    <TextBox DockPanel.Dock="Top"
             x:Name="SearchBox"
             PlaceholderText="{x:Static res:Strings.ShortcutsSearchPlaceholder}"
             Text="{Binding SearchText, Mode=TwoWay}"
             Margin="0,0,0,10" />

    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right"
                Margin="0,10,0,0">
      <Button Content="{x:Static res:Strings.CloseButton}" IsCancel="True" IsDefault="True"
              Click="OnCloseClick" />
    </StackPanel>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="12">
        <TextBlock Text="{x:Static res:Strings.ShortcutsNoResults}" Opacity="0.6"
                   IsVisible="{Binding !HasResults}" />
        <ItemsControl ItemsSource="{Binding FilteredGroups}" Grid.IsSharedSizeScope="True">
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="vm:ShortcutGroup">
              <StackPanel Spacing="3" Margin="0,0,0,4">
                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Margin="0,0,0,2" />
                <ItemsControl ItemsSource="{Binding Entries}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:ShortcutEntry">
                      <Grid ColumnSpacing="12" Margin="0,1">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="Auto" SharedSizeGroup="Gesture" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#1A808080" CornerRadius="3" Padding="6,1">
                          <TextBlock Text="{Binding Gesture}" FontFamily="monospace" FontSize="12" />
                        </Border>
                        <TextBlock Grid.Column="1" Text="{Binding Description}"
                                   VerticalAlignment="Center" TextWrapping="Wrap" />
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</Window>
