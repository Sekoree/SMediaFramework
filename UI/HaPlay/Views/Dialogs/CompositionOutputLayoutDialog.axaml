<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vmd="using:HaPlay.ViewModels.Dialogs"
        xmlns:controls="using:HaPlay.Views.Controls"
        x:Class="HaPlay.Views.Dialogs.CompositionOutputLayoutDialog"
        x:DataType="vmd:CompositionOutputLayoutViewModel"
        Title="Output layout"
        Width="940" Height="600"
        MinWidth="640" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        CanResize="True">
  <DockPanel Margin="12">

    <TextBlock DockPanel.Dock="Top" Margin="0,0,0,8" TextWrapping="Wrap" Opacity="0.85"
               Text="Drag each output to the part of the composition canvas it shows; the bottom-right handle resizes it. Select an output and use the arrow keys to nudge one pixel (Shift = 10). Where outputs overlap is a blend zone; canvas not covered by any output stays black (a gap)." />

    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right"
                Spacing="8" Margin="0,8,0,0">
      <Button Content="Save" Click="SaveClick" IsDefault="True" />
      <Button Content="Cancel" Click="CancelClick" IsCancel="True" />
    </StackPanel>

    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
      <Border Grid.Column="0" BorderBrush="#33808080" BorderThickness="1" Background="#0A0A0A">
        <controls:OutputLayoutCanvas Items="{Binding Items}"
                                     SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                                     AspectRatio="{Binding AspectRatio}"
                                     CanvasWidth="{Binding CanvasWidth}"
                                     CanvasHeight="{Binding CanvasHeight}" />
      </Border>

      <DockPanel Grid.Column="1" Width="280">
        <TextBlock DockPanel.Dock="Top" Text="Outputs" FontWeight="SemiBold" Margin="0,0,0,4" />
        <ContentControl DockPanel.Dock="Bottom" Content="{Binding SelectedItem}" Margin="0,10,0,0">
          <ContentControl.ContentTemplate>
            <DataTemplate x:DataType="vmd:OutputLayoutItemViewModel">
              <StackPanel Spacing="8">
                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextWrapping="Wrap" />

                <TextBlock Text="Output resolution (pixels this output is sent at)" Opacity="0.65" />
                <Grid ColumnDefinitions="Auto,8,*,14,Auto,8,*">
                  <TextBlock Grid.Column="0" Text="W" VerticalAlignment="Center" />
                  <NumericUpDown Grid.Column="2" Minimum="16" Maximum="7680" Increment="2" FormatString="0"
                                 Value="{Binding OutputWidth, Mode=TwoWay}" />
                  <TextBlock Grid.Column="4" Text="H" VerticalAlignment="Center" />
                  <NumericUpDown Grid.Column="6" Minimum="16" Maximum="4320" Increment="2" FormatString="0"
                                 Value="{Binding OutputHeight, Mode=TwoWay}" />
                </Grid>

                <TextBlock Text="Canvas slice (source region this output shows, pixels)" Opacity="0.65" Margin="0,4,0,0" />
                <CheckBox Content="Lock aspect ratio"
                          IsChecked="{Binding AspectLocked, Mode=TwoWay}" />
                <Grid ColumnDefinitions="Auto,8,*" RowDefinitions="Auto,6,Auto,6,Auto,6,Auto">
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="X" VerticalAlignment="Center" />
                  <NumericUpDown Grid.Row="0" Grid.Column="2"
                                 Minimum="0" Maximum="{Binding CanvasWidth}" Increment="1" FormatString="0"
                                 Value="{Binding PixelX, Mode=TwoWay}" />
                  <TextBlock Grid.Row="2" Grid.Column="0" Text="Y" VerticalAlignment="Center" />
                  <NumericUpDown Grid.Row="2" Grid.Column="2"
                                 Minimum="0" Maximum="{Binding CanvasHeight}" Increment="1" FormatString="0"
                                 Value="{Binding PixelY, Mode=TwoWay}" />
                  <TextBlock Grid.Row="4" Grid.Column="0" Text="W" VerticalAlignment="Center" />
                  <NumericUpDown Grid.Row="4" Grid.Column="2"
                                 Minimum="1" Maximum="{Binding CanvasWidth}" Increment="1" FormatString="0"
                                 Value="{Binding PixelWidth, Mode=TwoWay}" />
                  <TextBlock Grid.Row="6" Grid.Column="0" Text="H" VerticalAlignment="Center" />
                  <NumericUpDown Grid.Row="6" Grid.Column="2"
                                 Minimum="1" Maximum="{Binding CanvasHeight}" Increment="1" FormatString="0"
                                 Value="{Binding PixelHeight, Mode=TwoWay}" />
                </Grid>
              </StackPanel>
            </DataTemplate>
          </ContentControl.ContentTemplate>
        </ContentControl>

        <ListBox ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem, Mode=TwoWay}">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vmd:OutputLayoutItemViewModel">
              <StackPanel Spacing="1" Margin="0,2">
                <TextBlock Text="{Binding DisplayName}" />
                <TextBlock Opacity="0.6" FontSize="11"
                           Text="{Binding OutputSummary}" />
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Grid>
  </DockPanel>
</Window>
