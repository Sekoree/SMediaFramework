<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="using:HaPlay.Resources"
        xmlns:rootvm="using:HaPlay.ViewModels"
        xmlns:vm="using:HaPlay.ViewModels.Dialogs"
        xmlns:dlg="using:HaPlay.ViewModels.Dialogs"
        x:Class="HaPlay.Views.Dialogs.AddNDIOutputDialog"
        x:DataType="vm:AddNDIOutputDialogViewModel"
        Title="{Binding DialogTitle}"
        Width="520" Height="560"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        MinWidth="420" MinHeight="480">
  <DockPanel Margin="16">
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,16,0,0">
      <Button Content="{x:Static res:Strings.CancelButton}" Click="CancelClick" IsCancel="True" />
      <Button Content="{Binding PrimaryButtonLabel}" Click="OkClick" IsDefault="True" />
    </StackPanel>

    <ScrollViewer>
      <StackPanel Spacing="10">
        <TextBlock Text="{Binding ValidationMessage}" Foreground="#C62828" TextWrapping="Wrap" />

        <TextBlock Text="{x:Static res:Strings.DisplayNameLabel}" FontWeight="SemiBold" />
        <TextBox Text="{Binding DisplayName}" />

        <TextBlock Text="{x:Static res:Strings.NdiSourceNameLabel}" FontWeight="SemiBold" />
        <TextBox Text="{Binding SourceName}" />

        <TextBlock Text="{x:Static res:Strings.NdiGroupsOptionalLabel}" FontWeight="SemiBold" />
        <TextBox Text="{Binding Groups}" PlaceholderText="{x:Static res:Strings.NdiGroupsPlaceholder}" />

        <TextBlock Text="{x:Static res:Strings.StreamsLabel}" FontWeight="SemiBold" />
        <ComboBox ItemsSource="{Binding StreamModes}" SelectedItem="{Binding StreamMode}">
          <ComboBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Converter={x:Static rootvm:EnumDisplayConverter.Instance}}" />
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>

        <StackPanel Spacing="8" IsVisible="{Binding ShowAudioSettings}">
          <TextBlock Text="{x:Static res:Strings.NdiAudioChannelCountLabel}" FontWeight="SemiBold" />
          <NumericUpDown Minimum="1" Maximum="64" Value="{Binding AudioChannelCount}" />

          <TextBlock Text="{x:Static res:Strings.NdiAudioSampleRateLabel}" FontWeight="SemiBold" />
          <NumericUpDown Minimum="8000" Maximum="192000" Increment="1000" Value="{Binding AudioSampleRate}" />
        </StackPanel>

        <Border BorderBrush="#22808080" BorderThickness="0,1,0,0" Margin="0,8,0,0" Padding="0,8,0,0">
          <StackPanel Spacing="8">
            <TextBlock Text="{x:Static res:Strings.VideoFormatLockOptionalLabel}" FontWeight="SemiBold" />
            <TextBlock Opacity="0.7" FontSize="11" TextWrapping="Wrap"
                       Text="{x:Static res:Strings.VideoFormatLockHint}" />

            <TextBlock Text="{x:Static res:Strings.PixelFormatLabel}" />
            <ComboBox ItemsSource="{Binding PixelFormatChoices}"
                      SelectedItem="{Binding SelectedPixelFormat}">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="dlg:NDIPixelFormatChoice">
                  <TextBlock Text="{Binding Label}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock Text="{x:Static res:Strings.ResolutionLabel}" />
            <ComboBox ItemsSource="{Binding ResolutionChoices}"
                      SelectedItem="{Binding SelectedResolution}">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="dlg:NDIResolutionChoice">
                  <TextBlock Text="{Binding Label}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</Window>
