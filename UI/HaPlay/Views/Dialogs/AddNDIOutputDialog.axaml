<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HaPlay.ViewModels.Dialogs"
        xmlns:dlg="using:HaPlay.ViewModels.Dialogs"
        x:Class="HaPlay.Views.Dialogs.AddNDIOutputDialog"
        x:DataType="vm:AddNDIOutputDialogViewModel"
        Title="{Binding DialogTitle}"
        Width="520" Height="560"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        MinWidth="420" MinHeight="480">
  <DockPanel Margin="16">
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,16,0,0">
      <Button Content="Cancel" Click="CancelClick" IsCancel="True" />
      <Button Content="{Binding PrimaryButtonLabel}" Click="OkClick" IsDefault="True" />
    </StackPanel>

    <ScrollViewer>
      <StackPanel Spacing="10">
        <TextBlock Text="{Binding ValidationMessage}" Foreground="#C62828" TextWrapping="Wrap" />

        <TextBlock Text="Display name" FontWeight="SemiBold" />
        <TextBox Text="{Binding DisplayName}" />

        <TextBlock Text="NDI source name" FontWeight="SemiBold" />
        <TextBox Text="{Binding SourceName}" />

        <TextBlock Text="NDI groups (optional)" FontWeight="SemiBold" />
        <TextBox Text="{Binding Groups}" PlaceholderText="e.g. HaPlay" />

        <TextBlock Text="Streams" FontWeight="SemiBold" />
        <ComboBox ItemsSource="{Binding StreamModes}" SelectedItem="{Binding StreamMode}" />

        <StackPanel Spacing="8" IsVisible="{Binding ShowAudioSettings}">
          <TextBlock Text="NDI audio channel count" FontWeight="SemiBold" />
          <NumericUpDown Minimum="1" Maximum="64" Value="{Binding AudioChannelCount}" />

          <TextBlock Text="NDI audio sample rate (Hz)" FontWeight="SemiBold" />
          <NumericUpDown Minimum="8000" Maximum="192000" Increment="1000" Value="{Binding AudioSampleRate}" />
        </StackPanel>

        <Border BorderBrush="#22808080" BorderThickness="0,1,0,0" Margin="0,8,0,0" Padding="0,8,0,0">
          <StackPanel Spacing="8">
            <TextBlock Text="Video format lock (optional)" FontWeight="SemiBold" />
            <TextBlock Opacity="0.7" FontSize="11" TextWrapping="Wrap"
                       Text="When set, receivers see a fixed pixel format and/or resolution regardless of the source. Leave on 'Auto' for receivers to pick the cheapest negotiation." />

            <TextBlock Text="Pixel format" />
            <ComboBox ItemsSource="{Binding PixelFormatChoices}"
                      SelectedItem="{Binding SelectedPixelFormat}">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="dlg:NDIPixelFormatChoice">
                  <TextBlock Text="{Binding Label}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock Text="Resolution" />
            <ComboBox ItemsSource="{Binding ResolutionChoices}"
                      SelectedItem="{Binding SelectedResolution}">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="dlg:NDIResolutionChoice">
                  <TextBlock Text="{Binding Label}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</Window>
