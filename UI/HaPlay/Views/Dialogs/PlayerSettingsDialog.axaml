<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="using:HaPlay.Resources"
        xmlns:vm="using:HaPlay.ViewModels"
        x:Class="HaPlay.Views.Dialogs.PlayerSettingsDialog"
        x:DataType="vm:MediaPlayerViewModel"
        Title="{x:Static res:Strings.PlayerSettingsDialogTitle}"
        Width="620" Height="460"
        MinWidth="480" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        CanResize="True">
  <DockPanel Margin="10">
    <StackPanel DockPanel.Dock="Bottom"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,10,0,0">
      <Button Content="{x:Static res:Strings.CloseButton}" Click="CloseClick" IsCancel="True" />
    </StackPanel>

    <TabControl>
      <!-- Tab 1: Output & Transitions -->
      <TabItem Header="{x:Static res:Strings.OutputAndTransitionsTab}">
        <StackPanel Spacing="12" Margin="8">
          <Grid ColumnDefinitions="Auto,*,Auto,*" ColumnSpacing="10" RowDefinitions="Auto,Auto" RowSpacing="10">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static res:Strings.OutputPresetLabel}" VerticalAlignment="Center" />
            <ComboBox Grid.Row="0" Grid.Column="1"
                      ItemsSource="{Binding OutputPresets}"
                      SelectedItem="{Binding OutputPreset}"
                      HorizontalAlignment="Stretch" />
            <TextBlock Grid.Row="0" Grid.Column="2" Text="{x:Static res:Strings.TransitionLabel}" VerticalAlignment="Center"
                       ToolTip.Tip="{x:Static res:Strings.TransitionTooltip}" />
            <ComboBox Grid.Row="0" Grid.Column="3"
                      ItemsSource="{Binding TransitionModes}"
                      SelectedItem="{Binding TransitionMode}"
                      ToolTip.Tip="{x:Static res:Strings.TransitionTooltip}"
                      HorizontalAlignment="Stretch" />
            <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static res:Strings.MillisecondsShort}" VerticalAlignment="Center" />
            <NumericUpDown Grid.Row="1" Grid.Column="1" Width="120"
                           Minimum="0" Maximum="10000" Increment="50"
                           Value="{Binding TransitionDurationMs}"
                           ToolTip.Tip="{x:Static res:Strings.TransitionTooltip}"
                           HorizontalAlignment="Left" />
          </Grid>
          <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*" ColumnSpacing="8"
                IsVisible="{Binding IsCustomOutputPreset}"
                ToolTip.Tip="{x:Static res:Strings.CustomOutputTooltip}">
            <TextBlock Grid.Column="0" Text="{x:Static res:Strings.CustomWidthLabel}" VerticalAlignment="Center" />
            <NumericUpDown Grid.Column="1" Width="96"
                           Minimum="16" Maximum="7680" Increment="2"
                           Value="{Binding CustomOutputWidth}" />
            <TextBlock Grid.Column="2" Text="{x:Static res:Strings.CustomHeightLabel}" VerticalAlignment="Center" />
            <NumericUpDown Grid.Column="3" Width="96"
                           Minimum="16" Maximum="4320" Increment="2"
                           Value="{Binding CustomOutputHeight}" />
            <TextBlock Grid.Column="4" Opacity="0.55" FontSize="11" VerticalAlignment="Center"
                       Text="{x:Static res:Strings.CustomOutputAppliedHint}" />
          </Grid>
          <ToggleButton Content="{x:Static res:Strings.LiveUyvyPassthroughLabel}"
                        IsChecked="{Binding PreferLiveUyvyPassthrough}"
                        HorizontalAlignment="Left"
                        ToolTip.Tip="{x:Static res:Strings.LiveUyvyPassthroughTooltip}" />
        </StackPanel>
      </TabItem>

      <!-- Tab 2: Idle / Fallback Image -->
      <TabItem Header="{x:Static res:Strings.IdleImageTab}">
        <StackPanel Spacing="12" Margin="8">
          <TextBlock Opacity="0.7" FontSize="12"
                     Text="{x:Static res:Strings.IdleImageHeaderTooltip}" TextWrapping="Wrap" />
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBox Grid.Column="0" PlaceholderText="{x:Static res:Strings.FallbackPathPlaceholder}"
                     Text="{Binding FallbackImagePath}" />
            <Button Grid.Column="1" Content="{x:Static res:Strings.BrowseButton}"
                    Command="{Binding BrowseFallbackCommand}" />
          </Grid>
          <ToggleButton Content="{x:Static res:Strings.ShowWhenNoMediaPlaying}"
                        IsChecked="{Binding HoldFallbackVideo}"
                        HorizontalAlignment="Left"
                        ToolTip.Tip="{x:Static res:Strings.HoldFallbackToggleTooltip}" />
        </StackPanel>
      </TabItem>

      <!-- Tab 3: Headphones Cue Bus -->
      <TabItem Header="{x:Static res:Strings.HeadphonesCueBusTab}">
        <StackPanel Spacing="12" Margin="8">
          <StackPanel Spacing="8" IsVisible="{Binding HasHeadphonesCueOutputs}">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10">
              <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"
                         Text="{x:Static res:Strings.Enable}" />
              <ToggleButton Grid.Row="0" Grid.Column="1"
                            Content="{x:Static res:Strings.Enable}"
                            IsChecked="{Binding HeadphonesCueEnabled}"
                            HorizontalAlignment="Left" />

              <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Target" />
              <ComboBox Grid.Row="1" Grid.Column="1"
                        ItemsSource="{Binding HeadphonesCueTargets}"
                        SelectedItem="{Binding SelectedHeadphonesCueTarget}"
                        IsEnabled="{Binding HeadphonesCueEnabled}"
                        HorizontalAlignment="Stretch">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:HeadphonesCueTargetOption">
                    <TextBlock Text="{Binding Display}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>

              <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"
                         Text="{x:Static res:Strings.Tap}" />
              <ComboBox Grid.Row="2" Grid.Column="1" MinWidth="140"
                        ItemsSource="{Binding HeadphonesCueTapPoints}"
                        SelectedItem="{Binding HeadphonesCueTapPoint}"
                        IsEnabled="{Binding HeadphonesCueEnabled}"
                        HorizontalAlignment="Left" />

              <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Gain" />
              <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <NumericUpDown Minimum="-60" Maximum="12" Increment="1"
                               Value="{Binding HeadphonesCueGainDb}"
                               IsEnabled="{Binding HeadphonesCueEnabled}"
                               Width="140" />
                <TextBlock VerticalAlignment="Center" FontFamily="Consolas,monospace"
                           Text="{Binding HeadphonesCueGainDb, StringFormat='{}{0:0.#} dB'}" />
              </StackPanel>
            </Grid>
            <TextBlock Opacity="0.55" FontSize="11"
                       Text="{x:Static res:Strings.HeadphonesCueMatrixHint}" TextWrapping="Wrap" />
          </StackPanel>
          <TextBlock Opacity="0.55" FontSize="12"
                     IsVisible="{Binding !HasHeadphonesCueOutputs}"
                     Text="{x:Static res:Strings.NoOutputsConfiguredHint}" TextWrapping="Wrap" />
        </StackPanel>
      </TabItem>
    </TabControl>
  </DockPanel>
</Window>
