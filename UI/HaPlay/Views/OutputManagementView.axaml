<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:HaPlay.ViewModels"
             xmlns:ctrls="using:HaPlay.Views.Controls"
             xmlns:res="using:HaPlay.Resources"
             mc:Ignorable="d" d:DesignWidth="960" d:DesignHeight="640"
             x:Class="HaPlay.Views.OutputManagementView"
             x:DataType="vm:OutputManagementViewModel">

  <UserControl.Styles>
    <Style Selector="Border.card">
      <Setter Property="BorderBrush" Value="#22808080" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Padding" Value="6" />
      <Setter Property="Background" Value="#08808080" />
    </Style>
    <Style Selector="TextBlock.hint">
      <Setter Property="Opacity" Value="0.65" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
  </UserControl.Styles>

  <DockPanel Margin="16">
    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,12">
      <StackPanel Grid.Column="0" Spacing="2">
        <TextBlock Text="{x:Static res:Strings.OutputManagementHeader}" FontSize="22" FontWeight="SemiBold" />
        <TextBlock Classes="hint"
                   Text="{x:Static res:Strings.OutputManagementHint}" />
      </StackPanel>
      <!-- §8.1 aggregate health chip — recolors when any line is warn/error. -->
      <Border Grid.Column="1" Margin="0,0,8,0" Padding="10,4" CornerRadius="12"
              VerticalAlignment="Center"
              Background="{Binding HasAggregateIssues, Converter={x:Static vm:AggregateBrushConverter.Instance}}">
        <TextBlock Text="{Binding AggregateSummary}" FontSize="12" FontWeight="SemiBold"
                   Foreground="#FFE6E6" />
      </Border>
      <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
        <Button Content="{x:Static res:Strings.AddPortAudioButton}" Command="{Binding AddPortAudioCommand}" />
        <Button Content="{x:Static res:Strings.AddLocalVideoButton}" Command="{Binding AddLocalVideoCommand}" />
        <Button Content="{x:Static res:Strings.AddNdiButton}" Command="{Binding AddNDICommand}" />
      </StackPanel>
    </Grid>

    <Border Classes="card">
      <ListBox ItemsSource="{Binding Outputs}" Background="Transparent">
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="vm:OutputLineViewModel">
            <Grid ColumnDefinitions="*,Auto" Margin="{Binding IndentMargin}">
              <Grid.ContextFlyout>
                <MenuFlyout>
                  <MenuItem Header="{x:Static res:Strings.NoPreviewActionsMenuHeader}"
                            IsVisible="{Binding IsNotLocalVideo}"
                            IsEnabled="False" />
                  <MenuItem Header="{x:Static res:Strings.StartPreviewWindowMenuHeader}"
                            Command="{Binding StartPreviewCommand}"
                            IsVisible="{Binding IsLocalVideo}" />
                  <MenuItem Header="{x:Static res:Strings.StopPreviewWindowMenuHeader}"
                            Command="{Binding StopPreviewCommand}"
                            IsVisible="{Binding IsLocalVideo}" />
                  <MenuItem Header="{x:Static res:Strings.FullscreenPreviewMenuHeader}"
                            Command="{Binding FullscreenPreviewCommand}"
                            IsVisible="{Binding IsLocalVideo}" />
                  <MenuItem Header="{x:Static res:Strings.WindowedPreviewMenuHeader}"
                            Command="{Binding WindowedPreviewCommand}"
                            IsVisible="{Binding IsLocalVideo}" />
                </MenuFlyout>
              </Grid.ContextFlyout>
              <StackPanel Grid.Column="0" Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <Ellipse Width="10" Height="10"
                           VerticalAlignment="Center"
                           Fill="{Binding HealthColor}"
                           ToolTip.Tip="{Binding HealthToolTip}" />
                  <Border IsVisible="{Binding IsNdiRecording}"
                          Background="#CCB00020"
                          BorderBrush="#FFDF4A4A"
                          BorderThickness="1"
                          CornerRadius="3"
                          Padding="4,1">
                    <TextBlock Text="{x:Static res:Strings.RecBadgeLabel}" FontSize="10" FontWeight="SemiBold" Foreground="#FFF5D4D4" />
                  </Border>
                  <TextBlock Text="{x:Static res:Strings.CloneOutputGlyph}" Opacity="0.6" IsVisible="{Binding IsClone}" />
                  <TextBlock Text="{Binding KindLabel}" FontWeight="SemiBold"
                             ToolTip.Tip="{Binding KindTechnicalLabel}" />
                  <TextBlock Text="{x:Static res:Strings.EmDash}" Opacity="0.5" />
                  <TextBlock Text="{Binding Definition.DisplayName}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding CloneParentLabel}"
                             Opacity="0.55" FontSize="12" VerticalAlignment="Center"
                             IsVisible="{Binding IsClone}" />
                </StackPanel>
                <TextBlock Classes="hint" Text="{Binding Summary}" />
              </StackPanel>
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <!-- §8.1 inline sparkline — frames+chunks per second over last 60 s. -->
                <ctrls:SparklineControl Width="120" Height="22"
                                        Samples="{Binding SparklineSamples}"
                                        PeakSample="{Binding SparklinePeakSample}"
                                        Revision="{Binding SparklineRevision}"
                                        Stroke="{Binding HealthColor, Converter={x:Static vm:BrushFromHexConverter.Instance}}"
                                        AreaFill="{Binding HealthColor, Converter={x:Static vm:BrushFromHexConverter.AreaInstance}}"
                                        ToolTip.Tip="{x:Static res:Strings.OutputThroughputTooltip}" />
                <Button Content="{Binding NdiRecordingButtonText}"
                        Command="{Binding ToggleNdiRecordingCommand}"
                        IsVisible="{Binding IsNdi}" />
                <Button Content="{x:Static res:Strings.EditButton}" Command="{Binding EditCommand}" />
                <Button Content="{x:Static res:Strings.RemoveButton}" Command="{Binding RemoveCommand}" />
              </StackPanel>
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Border>

    <Border Classes="card" Margin="0,10,0,0">
      <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="{x:Static res:Strings.SharedHeadphonesBusesLabel}" FontWeight="SemiBold" Margin="0,0,0,6" />
        <TextBlock DockPanel.Dock="Top" Classes="hint"
                   Text="{x:Static res:Strings.SharedHeadphonesBusesHint}" />
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
          <Button Content="{x:Static res:Strings.AddBusButton}" Command="{Binding AddSharedHeadphonesBusCommand}" />
        </StackPanel>
        <ListBox ItemsSource="{Binding SharedHeadphonesBuses}" Background="Transparent" Margin="0,6,0,0">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vm:SharedHeadphonesBusViewModel">
              <Grid ColumnDefinitions="220,*,Auto" ColumnSpacing="8" Margin="0,2">
                <TextBox Grid.Column="0" Text="{Binding Label, Mode=TwoWay}" />
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding $parent[UserControl].((vm:OutputManagementViewModel)DataContext).PortAudioOutputLines}"
                          SelectedValueBinding="{Binding Definition.Id}"
                          SelectedValue="{Binding PortAudioOutputId, Mode=TwoWay}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:OutputLineViewModel">
                      <TextBlock Text="{Binding Definition.DisplayName}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Grid.Column="2" Content="{x:Static res:Strings.RemoveButton}"
                        Command="{Binding $parent[UserControl].((vm:OutputManagementViewModel)DataContext).RemoveSharedHeadphonesBusCommand}"
                        CommandParameter="{Binding}" />
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>

    <Border Classes="card" Margin="0,10,0,0">
      <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="{x:Static res:Strings.VirtualAudioChannelsHeader}" FontWeight="SemiBold" Margin="0,0,0,6" />
        <TextBlock DockPanel.Dock="Top" Classes="hint"
                   Text="{x:Static res:Strings.VirtualAudioChannelsHint}" />
        <Border DockPanel.Dock="Top"
                IsVisible="{Binding HasVirtualChannelCollisions}"
                Background="#33C00000" BorderBrush="#88C00000" BorderThickness="1"
                CornerRadius="4" Padding="8,4" Margin="0,6,0,0">
          <TextBlock Text="{Binding VirtualChannelCollisionMessage}" Foreground="#FFE6E6" />
        </Border>
        <ListBox ItemsSource="{Binding VirtualAudioChannelAssignments}" Background="Transparent" Margin="0,6,0,0">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vm:OutputVirtualChannelAssignmentViewModel">
              <Grid ColumnDefinitions="220,90,100,90,*" ColumnSpacing="8" Margin="0,2">
                <TextBlock Grid.Column="0" Text="{Binding OutputDisplayName}" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="{Binding OutputChannelLabel}" VerticalAlignment="Center" />
                <NumericUpDown Grid.Column="2"
                               Minimum="1"
                               Maximum="512"
                               ShowButtonSpinner="False"
                               Value="{Binding VirtualOutputChannel, Mode=TwoWay}" />
                <TextBlock Grid.Column="3"
                           IsVisible="{Binding IsDuplicate}"
                           Text="{x:Static res:Strings.DuplicateLabel}"
                           Foreground="#FFCC6666"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="4" Text="{Binding VirtualOutputChannel, StringFormat='VOut {0}'}"
                           VerticalAlignment="Center" Opacity="0.75" />
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>
  </DockPanel>
</UserControl>
