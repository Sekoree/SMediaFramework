<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:HaPlay.ViewModels"
             xmlns:views="using:HaPlay.Views"
             xmlns:models="using:HaPlay.Models"
             xmlns:res="using:HaPlay.Resources"
             xmlns:controls="using:HaPlay.Views.Controls"
             xmlns:mpp="using:HaPlay.Views.MediaPlayerPanels"
             mc:Ignorable="d" d:DesignWidth="460" d:DesignHeight="600"
             x:Class="HaPlay.Views.MediaPlayerView"
             x:DataType="vm:MediaPlayerViewModel">

    <!--
      Deck layout rules (2026-07 rewrite):
      · Every header row is ALWAYS present with reserved height - media-type differences (file vs
        live vs idle) swap content IN PLACE (clocks↔LIVE badge, enabled↔disabled) but never add or
        remove a layout row, so the transport buttons never move under the operator's finger.
      · One timeline row: position · scrubber · middle clock · duration share a single 26px line
        (the old separate clock row with under-labels is folded in; labels live in tooltips).
      · The busy bar owns a fixed 3px slot; its status text sits in the fixed status line row.
      · Routing lives ONLY in the header chip (always visible) + its flyout - the old bottom
        summary strip duplicated it and cost a full row.
      · The playlist toolbar and the Set tab strip share one row.
    -->

    <UserControl.Resources>
        <!-- Classic notebook-tab look for the playlist set strip: REAL TabItems restyled for the strip
             (padding only). A hand-rolled TabStripItem theme drew its own ClassicBorderDecorator, but a
             decorator instantiated from a view-local ControlTheme misses the bevel brushes its implicit
             theme provides and the tab rendered outline-less - reusing the package's proven TabItem
             theme (via a header-only TabControl) gets the exact Player-tab chrome for free. -->
        <ControlTheme x:Key="PlaylistSetTabItemTheme" TargetType="TabItem"
                      BasedOn="{StaticResource {x:Type TabItem}}">
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="FontSize" Value="12" />
        </ControlTheme>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="TextBlock.time">
            <Setter Property="FontFamily" Value="Consolas,monospace" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <!-- Low-time warning: highlight the clock when a finite track is near its end. -->
        <Style Selector="TextBlock.time.lowtime">
            <Setter Property="Foreground" Value="#E53935" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Border.card">
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Background" Value="{StaticResource SurfaceRaised}" />
        </Style>
        <!-- Small square pills for the playback-state + source-kind indicators. -->
        <Style Selector="Border.chip">
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <!-- Count badge on the Options button. -->
        <Style Selector="Border.badge">
            <Setter Property="Background" Value="#2E7D32" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="MinWidth" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Border.badge TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <!-- The slim indeterminate busy bar (lives in a fixed 3px slot). -->
        <Style Selector="ProgressBar.busy">
            <Setter Property="MinHeight" Value="3" />
            <Setter Property="Height" Value="3" />
        </Style>
        <!-- Live-source mode: the scrubber goes transparent but keeps its layout slot (the LIVE
             badge overlays it), so the timeline row height never changes with the media type. -->
        <Style Selector="Grid.scrubber.live">
            <Setter Property="Opacity" Value="0" />
        </Style>
        <!-- Drag affordance on each playlist row. -->
        <Style Selector="TextBlock.drag-handle">
            <Setter Property="Text" Value="&#x2261;" />
            <Setter Property="Opacity" Value="0.35" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Cursor" Value="SizeNorthSouth" />
        </Style>

        <!-- Compact mode: shrink/hide secondary controls when the player is narrow. -->
        <Style Selector="UserControl.compact TextBlock.hide-compact">
            <Setter Property="IsVisible" Value="False" />
        </Style>
        <Style Selector="UserControl.compact StackPanel.hide-compact">
            <Setter Property="IsVisible" Value="False" />
        </Style>
        <Style Selector="UserControl.compact Border.hide-compact">
            <Setter Property="IsVisible" Value="False" />
        </Style>
        <Style Selector="UserControl.compact StackPanel.transport-jump">
            <Setter Property="IsVisible" Value="False" />
        </Style>
        <Style Selector="UserControl.compact Slider.vol">
            <Setter Property="Width" Value="78" />
        </Style>
        <Style Selector="UserControl.compact Border.card">
            <Setter Property="Padding" Value="6" />
        </Style>
    </UserControl.Styles>

    <!-- The whole deck scrolls when the window is too short for its minimum layout. Height is bound to
         the viewport so at normal sizes the DockPanel fills it exactly (playlist scrolls INTERNALLY and
         the transport header stays pinned); once the viewport drops under MinHeight the content keeps
         its minimum and the outer scrollbar takes over instead of the docked rows overlapping. -->
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <DockPanel LastChildFill="True" MinHeight="440"
               Background="{Binding TintBrush}"
               Height="{Binding $parent[ScrollViewer].Viewport.Height}">

        <!-- ============ Now-playing / transport deck header (pinned) ============ -->
        <Border DockPanel.Dock="Top" Classes="card" Margin="0,0,0,4">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="6">

                <!-- Title row: state pill · editable name · source kind · current media · menus -->
                <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,Auto,*,Auto" ColumnSpacing="6">
                    <Border Grid.Column="0" Classes="chip"
                            Background="{Binding PlaybackStateColor}">
                        <TextBlock FontSize="10" FontWeight="SemiBold"
                                   Text="{Binding PlaybackStateLabel}" />
                    </Border>

                    <TextBox Grid.Column="1" FontWeight="SemiBold" FontSize="16"
                             VerticalAlignment="Center" Text="{Binding Name, Mode=TwoWay}"
                             BorderThickness="0" Background="Transparent"
                             MinWidth="60" Padding="2,0"
                             IsReadOnly="True"
                             DoubleTapped="OnPlayerNameDoubleTapped"
                             LostFocus="OnPlayerNameLostFocus"
                             KeyDown="OnPlayerNameKeyDown" />

                    <Border Grid.Column="2" Classes="chip hide-compact"
                            Background="{StaticResource ChipNeutral}"
                            ToolTip.Tip="{x:Static res:Strings.SourceKindTooltip}">
                        <TextBlock FontSize="11" FontWeight="SemiBold"
                                   Text="{Binding SourceKindLabel}" />
                    </Border>

                    <TextBlock Grid.Column="3" Opacity="0.7" FontSize="12" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Text="{Binding CurrentMediaDisplay, FallbackValue={x:Static res:Strings.NoMediaLoadedHint}, TargetNullValue={x:Static res:Strings.NoMediaLoadedHint}}"
                               ToolTip.Tip="{Binding CurrentMediaDisplay}" />

                    <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="4">
                        <!-- Deck color: tints this player so decks are easy to tell apart. -->
                        <mpp:MediaPlayerTintPicker VerticalAlignment="Center" />
                        <!-- Multi-output aggregate: worst-case health dot + routed-output count, with a
                             per-output health flyout. ALWAYS visible (shows "No output" when unrouted) -
                             this chip is the deck's single routing surface; edits live in the flyout's
                             Edit button → routing editor. -->
                        <Button Padding="8,4" VerticalAlignment="Center"
                                ToolTip.Tip="{x:Static res:Strings.DeckRoutingChipTooltip}">
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <Ellipse Width="9" Height="9" VerticalAlignment="Center"
                                         Fill="{Binding DeckOutputHealthColor, FallbackValue=#666666}" />
                                <TextBlock FontSize="11" VerticalAlignment="Center"
                                           Text="{Binding DeckOutputSummary}" />
                                <TextBlock Text="&#x25BE;" FontSize="10" Opacity="0.7" VerticalAlignment="Center" />
                            </StackPanel>
                            <Button.Flyout>
                                <Flyout Placement="Bottom">
                                    <StackPanel Spacing="6" Margin="4" MinWidth="220" MaxWidth="340">
                                        <TextBlock FontWeight="SemiBold" FontSize="12"
                                                   Text="{x:Static res:Strings.DeckRoutingFlyoutTitle}" />
                                        <!-- "N selected of M" summary (was the bottom routing strip). -->
                                        <TextBlock FontSize="11"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   Text="{Binding RoutingSummary}" />
                                        <TextBlock TextWrapping="Wrap" FontSize="11"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   IsVisible="{Binding !HasRoutedOutputs}"
                                                   Text="{x:Static res:Strings.DeckRoutingNoneHint}" />
                                        <ItemsControl ItemsSource="{Binding SelectedOutputs}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8"
                                                          Margin="0,2"
                                                          ToolTip.Tip="{Binding Line.HealthToolTip}">
                                                        <Ellipse Grid.Column="0" Width="9" Height="9"
                                                                 VerticalAlignment="Center"
                                                                 Fill="{Binding Line.HealthColor, FallbackValue=#666666}" />
                                                        <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Text="{Binding Line.EffectiveName}" />
                                                        <TextBlock Grid.Column="2" FontSize="11"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{StaticResource TextSecondary}"
                                                                   Text="{Binding Line.KindLabel}" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Button HorizontalAlignment="Stretch" Margin="0,2,0,0"
                                                Content="{x:Static res:Strings.RoutingEditButton}"
                                                Command="{Binding OpenRoutingCommand}"
                                                ToolTip.Tip="{x:Static res:Strings.RoutingEditTooltip}" />
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>

                        <!-- Single overflow menu, labelled so its dropdown nature is obvious
                             (gear + "Player" + ▾). Player Settings lives inside it. -->
                        <Button Padding="8,4"
                                ToolTip.Tip="{x:Static res:Strings.MediaPlayerSettingsTooltip}">
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <PathIcon Data="{x:Static views:AppIcons.Gear}" Width="12" Height="12" />
                                <TextBlock Text="{x:Static res:Strings.PlayerMenuButtonLabel}" VerticalAlignment="Center" />
                                <TextBlock Text="&#x25BE;" FontSize="10" Opacity="0.7" VerticalAlignment="Center" />
                            </StackPanel>
                            <Button.Flyout>
                                <MenuFlyout>
                                    <MenuItem Header="{x:Static res:Strings.PlayerSettingsButton}"
                                              Command="{Binding OpenPlayerSettingsCommand}" />
                                    <MenuItem Header="{x:Static res:Strings.AudioMatrixButton}"
                                              Command="{Binding OpenAudioMatrixCommand}" />
                                    <Separator />
                                    <MenuItem Header="{x:Static res:Strings.SavePlayerConfigMenuHeader}"
                                              Command="{Binding SavePlayerConfigCommand}" />
                                    <MenuItem Header="{x:Static res:Strings.LoadPlayerConfigMenuHeader}"
                                              Command="{Binding LoadPlayerConfigCommand}" />
                                    <Separator />
                                    <MenuItem Header="{x:Static res:Strings.SaveTabButton}"
                                              Command="{Binding SavePlaylistTabCommand}" />
                                    <MenuItem Header="{x:Static res:Strings.LoadTabButton}"
                                              Command="{Binding LoadPlaylistTabCommand}" />
                                    <Separator />
                                    <MenuItem Header="{x:Static res:Strings.UnloadCurrentSessionMenuHeader}"
                                              Command="{Binding CloseSessionCommand}" />
                                    <MenuItem Header="{x:Static res:Strings.RemoveThisPlayerMenuHeader}"
                                              Command="{Binding RemovePlayerCommand}"
                                              IsVisible="{Binding CanRemove}" />
                                    <Separator />
                                    <MenuItem Header="{x:Static res:Strings.DetachPlayerButton}"
                                              Command="{Binding DetachPlayerCommand}"
                                              ToolTip.Tip="{x:Static res:Strings.DetachPlayerTooltip}" />
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Fixed-height status row: transient status + sticky load errors on the left
                     (and in toasts); busy status (loading / analysing / waiting) on the right.
                     Nothing above the transport ever appears/disappears. -->
                <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <controls:StatusLineControl Grid.Column="0"
                                                Text="{Binding DeckStatusText}"
                                                Severity="{Binding DeckStatusSeverity}"
                                                ToolTip.Tip="{Binding DeckStatusText}" />
                    <TextBlock Grid.Column="1" FontSize="11" Opacity="0.7" VerticalAlignment="Center"
                               MaxWidth="280" TextTrimming="CharacterEllipsis"
                               Text="{Binding BusyStatusText}" />
                </Grid>

                <!-- Timeline row: position · scrubber-with-waveform · middle clock (click toggles
                     elapsed/remaining) · duration, all on one line. For live sources the scrubber is
                     opacity-hidden (NOT collapsed - it keeps reserving its natural height under every
                     theme's slider size) and a LIVE badge overlays it, so the row never changes height
                     when the media type changes. -->
                <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="8">
                    <TextBlock Grid.Column="0" Classes="time" VerticalAlignment="Center"
                               IsVisible="{Binding !IsLiveSource}"
                               Text="{Binding CurrentPositionText}"
                               ToolTip.Tip="{x:Static res:Strings.PositionTimeLabel}" />

                    <Panel Grid.Column="1">
                        <Grid Classes="scrubber" Classes.live="{Binding IsLiveSource}"
                              IsHitTestVisible="{Binding !IsLiveSource}">
                            <controls:WaveformControl Height="24" Margin="8,0"
                                                      Peaks="{Binding WaveformPeaks}"
                                                      Revision="{Binding WaveformRevision}"
                                                      IsHitTestVisible="False" />
                            <Slider Name="SeekSlider"
                                    Minimum="0" Maximum="1000"
                                    Value="{Binding SeekSliderValue, Mode=TwoWay}"
                                    IsEnabled="{Binding IsTransportSeekable}"
                                    ToolTip.ShowDelay="200"
                                    ToolTip.Tip="{x:Static res:Strings.SeekSliderTooltip}" />
                        </Grid>
                        <Border IsVisible="{Binding IsLiveSource}" Margin="0,2"
                                Background="{StaticResource SurfaceSunken}">
                            <StackPanel Orientation="Horizontal" Spacing="6"
                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource StateLive}" />
                                <TextBlock FontSize="11" FontWeight="SemiBold" Opacity="0.8"
                                           Text="{x:Static res:Strings.LiveTimelineLabel}" />
                            </StackPanel>
                        </Border>
                    </Panel>

                    <TextBlock Grid.Column="2" Classes="time" VerticalAlignment="Center"
                               Classes.lowtime="{Binding IsNearEndOfTrack}"
                               IsVisible="{Binding !IsLiveSource}"
                               Cursor="Hand" Tapped="OnMiddleTimeTapped"
                               Text="{Binding MiddleTimeText}">
                        <ToolTip.Tip>
                            <StackPanel Spacing="2">
                                <TextBlock FontWeight="SemiBold" Text="{Binding MiddleTimeLabel}" />
                                <TextBlock Text="{x:Static res:Strings.ToggleTimeDisplayTooltip}" />
                            </StackPanel>
                        </ToolTip.Tip>
                    </TextBlock>

                    <TextBlock Grid.Column="3" Classes="time" Opacity="0.6" VerticalAlignment="Center"
                               IsVisible="{Binding !IsLiveSource}"
                               Text="{Binding DurationText}"
                               ToolTip.Tip="{x:Static res:Strings.DurationTimeLabel}" />

                    <!-- Jump-to-position: type a timecode (mm:ss / hh:mm:ss, optional .ms) and press
                         Enter to seek. Lives on the timeline row with the other seek controls; always
                         present, disabled (not hidden) for live/idle so the row never reflows. Input
                         is restricted to digits, ':' and '.' in code-behind. -->
                    <StackPanel Grid.Column="4" Classes="transport-jump"
                                Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <TextBlock Text="{x:Static res:Strings.JumpToLabel}" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondary}" FontSize="12" />
                        <TextBox Name="JumpBox" Width="92" MaxLength="12"
                                 PlaceholderText="{x:Static res:Strings.JumpToWatermark}"
                                 FontFamily="Consolas,monospace" VerticalContentAlignment="Center"
                                 IsEnabled="{Binding IsTransportSeekable}"
                                 KeyDown="OnJumpBoxKeyDown" TextInput="OnJumpBoxTextInput"
                                 ToolTip.Tip="{x:Static res:Strings.JumpToTooltip}" />
                    </StackPanel>
                </Grid>

                <!-- Busy bar in a fixed 3px slot - indicates loading / analysing / waiting without
                     ever pushing the transport down. -->
                <Panel Grid.Row="3" Height="3">
                    <ProgressBar Classes="busy" Minimum="0" Maximum="100"
                                 IsIndeterminate="{Binding IsBusy}"
                                 IsVisible="{Binding IsBusy}" />
                </Panel>

                <!-- Transport (touch tier). Prev · Play · HOLD · Next are the panic-path controls;
                     HOLD sits next to Play so pushing the idle image is one thumb-move from Pause
                     (▾ opens the image picker). Stop is isolated on the far right and tinted (Danger)
                     so it can't be fat-fingered in place of Pause. -->
                <Grid Grid.Row="4" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button Classes="Touch"
                                Command="{Binding PreviousTrackCommand}"
                                ToolTip.Tip="{x:Static res:Strings.PreviousTrackTooltip}"
                                AutomationProperties.Name="{x:Static res:Strings.PreviousTrackTooltip}">
                            <PathIcon Data="{x:Static views:AppIcons.Previous}" Width="14" Height="14" />
                        </Button>
                        <Button Classes="Touch Go" MinWidth="84"
                                Command="{Binding TogglePlayPauseCommand}"
                                ToolTip.Tip="{x:Static res:Strings.PlayPauseTooltip}">
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <PathIcon Data="{x:Static views:AppIcons.Play}" Width="14" Height="14"
                                          IsVisible="{Binding !IsPlaying}" />
                                <PathIcon Data="{x:Static views:AppIcons.Pause}" Width="14" Height="14"
                                          IsVisible="{Binding IsPlaying}" />
                                <TextBlock Text="{Binding PlayPauseLabel}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <!-- HOLD (latched amber via ToggleButton.Warn) + its image-setup ▾, next to Play. -->
                        <ToggleButton Classes="Touch Warn"
                                      IsChecked="{Binding HoldFallbackVideo}"
                                      Content="{x:Static res:Strings.HoldButtonLabel}"
                                      ToolTip.Tip="{x:Static res:Strings.HoldButtonTooltip}" />
                        <!-- VIZ: projectM audio visualizer layer over the deck composition (greyed
                             without libprojectM-4; see scripts/build-projectm.sh). -->
                        <ToggleButton Classes="Touch"
                                      IsChecked="{Binding VisualizerEnabled}"
                                      IsEnabled="{Binding IsVisualizerAvailable}"
                                      Content="{x:Static res:Strings.VisualizerToggleLabel}"
                                      ToolTip.Tip="{Binding VisualizerTooltip}" />
                        <Button Classes="Std" VerticalAlignment="Center"
                                Click="OnHoldImageSetupClick"
                                ToolTip.Tip="{x:Static res:Strings.HoldImagePickerTooltip}">
                            <TextBlock Text="&#x25BE;" FontSize="10" Opacity="0.7" />
                        </Button>
                        <Button Classes="Touch"
                                Command="{Binding NextTrackCommand}"
                                ToolTip.Tip="{x:Static res:Strings.NextTrackTooltip}"
                                AutomationProperties.Name="{x:Static res:Strings.NextTrackTooltip}">
                            <PathIcon Data="{x:Static views:AppIcons.Next}" Width="14" Height="14" />
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                                HorizontalAlignment="Right" VerticalAlignment="Center">
                        <ToggleButton Classes="Std" Content="{x:Static res:Strings.MuteToggleLabel}"
                                      IsChecked="{Binding MasterMuted}"
                                      ToolTip.Tip="{x:Static res:Strings.MuteToggleTooltip}" />
                        <Slider Name="VolumeSlider" Classes="vol" Width="140" Minimum="-60" Maximum="12"
                                Value="{Binding MasterVolumeDb, Mode=TwoWay}"
                                VerticalAlignment="Center"
                                ToolTip.Tip="{x:Static res:Strings.ResetVolumeTooltip}" />
                        <TextBlock Classes="time hide-compact" Width="52" VerticalAlignment="Center"
                                   Text="{Binding MasterVolumeDb, StringFormat='{}{0:0.#} dB'}" />
                        <!-- Options flyout: loop / auto-advance / shuffle / repeat-all + active badge. -->
                        <Button Classes="Std" Padding="10,6"
                                ToolTip.Tip="{x:Static res:Strings.PlaybackOptionsTooltip}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{x:Static res:Strings.PlaybackOptionsButton}"
                                           VerticalAlignment="Center" />
                                <Border Classes="badge" IsVisible="{Binding HasActiveOptions}">
                                    <TextBlock Text="{Binding ActiveOptionCount}" />
                                </Border>
                                <TextBlock Text="&#x25BE;" FontSize="10" Opacity="0.7"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <Button.Flyout>
                                <Flyout Placement="Bottom">
                                    <StackPanel Spacing="6" Margin="4" MinWidth="160">
                                        <CheckBox Content="{x:Static res:Strings.LoopToggleLabel}"
                                                  IsChecked="{Binding IsLooping}"
                                                  IsEnabled="{Binding AutoAdvancePlaylist}"
                                                  ToolTip.Tip="{x:Static res:Strings.LoopToggleTooltip}" />
                                        <CheckBox Content="{x:Static res:Strings.AutoAdvanceToggleLabel}"
                                                  IsChecked="{Binding AutoAdvancePlaylist}"
                                                  ToolTip.Tip="{x:Static res:Strings.AutoAdvanceToggleTooltip}" />
                                        <CheckBox Content="{x:Static res:Strings.ShuffleToggleLabel}"
                                                  IsChecked="{Binding ShufflePlaylist}"
                                                  ToolTip.Tip="{x:Static res:Strings.ShuffleToggleTooltip}" />
                                        <CheckBox Content="{x:Static res:Strings.RepeatAllToggleLabel}"
                                                  IsChecked="{Binding RepeatAllPlaylist}"
                                                  ToolTip.Tip="{x:Static res:Strings.RepeatAllToggleTooltip}" />
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                        <!-- Panic-path exit, isolated on the far right and tinted (Danger). -->
                        <Button Classes="Touch Danger" VerticalAlignment="Center"
                                Command="{Binding StopCommand}"
                                ToolTip.Tip="{x:Static res:Strings.StopTrackTooltip}"
                                AutomationProperties.Name="{x:Static res:Strings.StopTrackTooltip}">
                            <PathIcon Data="{x:Static views:AppIcons.Stop}" Width="14" Height="14" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- ============ Playlist (fills remaining height, classic group box) ============ -->
        <HeaderedContentControl Header="{x:Static res:Strings.PlaylistGroupHeader}" Margin="0,2,0,0">
            <Grid RowDefinitions="Auto,*">

                <!-- One shared row: "+ Set" · the Set tab strip (scrolls, bottom-aligned so the
                     selected tab's classic chrome merges into the list below) · Add ▾ / Properties /
                     Remove for the selection (the context menu still offers them too). -->
                <DockPanel Grid.Row="0" LastChildFill="True">
                    <Button DockPanel.Dock="Left" Padding="8,4" Margin="0,0,0,3"
                            VerticalAlignment="Stretch"
                            VerticalContentAlignment="Center"
                            Content="{x:Static res:Strings.AddPlaylistTabButton}"
                            Command="{Binding AddPlaylistTabCommand}"
                            ToolTip.Tip="{x:Static res:Strings.AddPlaylistTabTooltip}" />
                    <Button DockPanel.Dock="Right" Padding="8,4" Margin="4,0,0,3"
                            VerticalAlignment="Stretch"
                            VerticalContentAlignment="Center"
                            Command="{Binding RemoveFromPlaylistCommand}"
                            ToolTip.Tip="{x:Static res:Strings.PlaylistContextRemove}">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <PathIcon Data="{x:Static views:AppIcons.Close}" Width="9" Height="9" />
                            <TextBlock Text="{x:Static res:Strings.PlaylistRemoveButtonLabel}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button DockPanel.Dock="Right" Padding="8,4" Margin="6,0,0,3"
                            VerticalAlignment="Stretch"
                            VerticalContentAlignment="Center"
                            Command="{Binding ShowItemPropertiesCommand}"
                            ToolTip.Tip="{x:Static res:Strings.PlaylistPropertiesButtonTooltip}"
                            Content="{x:Static res:Strings.PlaylistContextProperties}" />
                    <Button DockPanel.Dock="Right" Padding="10,4" Margin="6,0,0,3"
                            VerticalAlignment="Stretch"
                            VerticalContentAlignment="Center"
                            ToolTip.Tip="{x:Static res:Strings.AddToPlaylistTooltip}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{x:Static res:Strings.AddToPlaylistButton}"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="&#x25BE;" FontSize="10" Opacity="0.7"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuItem Header="{x:Static res:Strings.AddFilesButton}"
                                          Command="{Binding AddFilesToPlaylistCommand}" />
                                <Separator />
                                <MenuItem Header="{x:Static res:Strings.PortAudioInputMenuHeader}"
                                          Command="{Binding AddPortAudioInputCommand}" />
                                <MenuItem Header="{x:Static res:Strings.NDIInputMenuHeader}"
                                          Command="{Binding AddNDIInputCommand}"
                                          IsVisible="{Binding IsNDIAvailable}" />
                                <MenuItem Header="{x:Static res:Strings.AddYouTubeMenuItem}"
                                          Command="{Binding AddYouTubeCommand}" />
                                <MenuItem Header="{x:Static res:Strings.AddMMDMenuItem}"
                                          Command="{Binding AddMMDCommand}" />
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>

                    <!-- Set tabs fill the space between the buttons and WRAP onto extra lines when
                         they don't fit (no scrolling - every Set stays visible). Bottom-aligned +
                         ZIndex so the last line's selected-tab chrome sits on the playlist pane edge
                         (per-Set removal lives on each tab: the X in rename mode + the right-click
                         Remove/Duplicate menu). -->
                    <!-- Header-only TabControl: the template renders JUST the tab headers (real
                         TabItems with the theme's classic chrome - same look as the player tabs);
                         the playlist ListBox below acts as the "pane" the selected tab merges into. -->
                    <TabControl ZIndex="1" Margin="6,0,6,0"
                                VerticalAlignment="Bottom"
                                ItemsSource="{Binding PlaylistTabs}"
                                SelectedItem="{Binding SelectedPlaylistTab}"
                                Padding="3,3,3,0"
                                ItemContainerTheme="{StaticResource PlaylistSetTabItemTheme}">
                        <TabControl.Template>
                            <ControlTemplate>
                                <ItemsPresenter Name="PART_ItemsPresenter"
                                                Margin="{TemplateBinding Padding}"
                                                ItemsPanel="{TemplateBinding ItemsPanel}" />
                            </ControlTemplate>
                        </TabControl.Template>
                        <TabControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" ItemSpacing="2" LineSpacing="2" />
                            </ItemsPanelTemplate>
                        </TabControl.ItemsPanel>
                        <TabControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:PlaylistTabViewModel">
                                <!-- Label by default (clicks select the tab); double-click swaps in
                                     the rename box. The old always-editable TextBox ate every click,
                                     making set tabs impossible to switch. -->
                                <Panel Background="Transparent"
                                       DoubleTapped="OnPlaylistTabDoubleTapped">
                                    <!-- Right-click a Set: duplicate or remove it. Code-behind rather
                                         than a command (the menu is in a popup an ancestor binding
                                         can't cross). -->
                                    <Panel.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="{x:Static res:Strings.DuplicateTabMenuItem}"
                                                      Click="OnPlaylistTabDuplicateClick" />
                                            <Separator />
                                            <MenuItem Header="{x:Static res:Strings.RemoveButton}"
                                                      Click="OnPlaylistTabRemoveClick" />
                                        </ContextMenu>
                                    </Panel.ContextMenu>
                                    <StackPanel Orientation="Horizontal" Spacing="4"
                                                IsVisible="{Binding !IsRenaming}">
                                        <!-- Marks the Set the player is currently playing from. -->
                                        <TextBlock Text="&#x25B6;" FontSize="9" VerticalAlignment="Center"
                                                   Foreground="{StaticResource StateHealthy}"
                                                   IsVisible="{Binding IsPlaying}" />
                                        <TextBlock Text="{Binding Name}" MinWidth="60"
                                                   VerticalAlignment="Center" Padding="2,0" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="2"
                                                IsVisible="{Binding IsRenaming}">
                                        <TextBox Text="{Binding Name, Mode=TwoWay}"
                                                 MinWidth="64" VerticalAlignment="Center"
                                                 LostFocus="OnPlaylistTabRenameLostFocus"
                                                 KeyDown="OnPlaylistTabRenameKeyDown" />
                                        <!-- Focusable=False so clicking it doesn't blur the TextBox
                                             (which would exit rename and hide this button first). -->
                                        <Button Focusable="False" Padding="4,0" VerticalAlignment="Center"
                                                Click="OnPlaylistTabRemoveClick"
                                                ToolTip.Tip="{x:Static res:Strings.RemovePlaylistTabTooltip}">
                                            <PathIcon Data="{x:Static views:AppIcons.Close}" Width="8" Height="8" />
                                        </Button>
                                    </StackPanel>
                                </Panel>
                            </DataTemplate>
                        </TabControl.ItemTemplate>
                    </TabControl>
                </DockPanel>

                <!-- Drag-to-reorder via Xaml.Behaviors (ListBox.draggable from the package styles).
                     External OS file drops are handled in code-behind. The old below-list hint row is
                     folded into the tooltip's second line. -->
                <ListBox Grid.Row="1" Name="PlaylistListBox" Classes="draggable" MinHeight="160"
                         ItemsSource="{Binding PlaylistItems}"
                         SelectedItem="{Binding SelectedPlaylistItem, Mode=TwoWay}"
                         DoubleTapped="OnPlaylistItemDoubleTapped">
                    <ToolTip.Tip>
                        <StackPanel Spacing="2">
                            <TextBlock Text="{x:Static res:Strings.PlaylistCardTooltip}" />
                            <TextBlock Opacity="0.7" Text="{x:Static res:Strings.PlaylistDragReorderHint}" />
                        </StackPanel>
                    </ToolTip.Tip>
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="{x:Static res:Strings.PlaylistContextMoveUp}"
                                      Command="{Binding MovePlaylistItemUpCommand}" />
                            <MenuItem Header="{x:Static res:Strings.PlaylistContextMoveDown}"
                                      Command="{Binding MovePlaylistItemDownCommand}" />
                            <Separator />
                            <MenuItem Header="{x:Static res:Strings.PlaylistContextRemove}"
                                      Command="{Binding RemoveFromPlaylistCommand}" />
                            <Separator />
                            <MenuItem Header="{x:Static res:Strings.CopyApiUrlMenuItem}"
                                      Click="OnCopyPlaylistItemApiUrlClick" />
                            <Separator />
                            <!-- Audio-track AND subtitle selection both live in the Properties dialog's Tracks
                                 tab (shown only when the file has multiple audio / any subtitle streams) - no
                                 more per-row track submenus on the context menu. -->
                            <MenuItem Header="{x:Static res:Strings.PlaylistContextProperties}"
                                      Command="{Binding ShowItemPropertiesCommand}" />
                        </ContextMenu>
                    </ListBox.ContextMenu>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:PlaylistItem">
                            <!-- The now-playing row gets an accent border (transparent otherwise so the row
                                 keeps its size). Matched by PlaylistItem.Id, so two same-file items and
                                 record 'with' edits both resolve correctly. -->
                            <Border BorderThickness="1" CornerRadius="3" Padding="3,1" Margin="0,0,2,0">
                                <Border.BorderBrush>
                                    <MultiBinding Converter="{x:Static views:PlaylistItemIsPlayingConverter.Instance}">
                                        <Binding />
                                        <Binding Path="((vm:MediaPlayerViewModel)DataContext).CurrentPlayingItem"
                                                 RelativeSource="{RelativeSource AncestorType=ListBox}" />
                                    </MultiBinding>
                                </Border.BorderBrush>
                                <Grid ColumnDefinitions="Auto,Auto,*" >
                                    <TextBlock Grid.Column="0" Classes="drag-handle" Margin="0,0,8,0" />
                                    <PathIcon Grid.Column="1" Width="12" Height="12"
                                              Data="{Binding Converter={x:Static views:PlaylistItemIconConverter.Instance}}"
                                              Opacity="0.85" Margin="0,0,6,0" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2" Text="{Binding DisplayName}"
                                               ToolTip.Tip="{Binding ToolTip}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </HeaderedContentControl>
    </DockPanel>
    </ScrollViewer>
</UserControl>
