<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:HaPlay.ViewModels"
             xmlns:views="using:HaPlay.Views"
             xmlns:models="using:HaPlay.Models"
             xmlns:res="using:HaPlay.Resources"
             xmlns:tdg="using:Avalonia.Controls"
             mc:Ignorable="d" d:DesignWidth="780" d:DesignHeight="900"
             x:Class="HaPlay.Views.MediaPlayerView"
             x:DataType="vm:MediaPlayerViewModel">

  <UserControl.Resources>
    <views:FilenameConverter x:Key="FilenameConverter" />
  </UserControl.Resources>

  <UserControl.Styles>
    <Style Selector="TextBlock.section-title">
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Margin" Value="0,0,0,4" />
    </Style>
    <Style Selector="TextBlock.time">
      <Setter Property="FontFamily" Value="Consolas,monospace" />
      <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="TextBlock.time-label">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Opacity" Value="0.6" />
      <Setter Property="TextAlignment" Value="Center" />
    </Style>
    <Style Selector="Border.card">
      <Setter Property="BorderBrush" Value="#22808080" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Padding" Value="14" />
      <Setter Property="Background" Value="#08808080" />
    </Style>
    <Style Selector="Button.transport">
      <Setter Property="MinWidth" Value="56" />
      <Setter Property="Padding" Value="12,8" />
    </Style>
    <Style Selector="Button.play-pause">
      <Setter Property="MinWidth" Value="96" />
      <Setter Property="Padding" Value="14,8" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
  </UserControl.Styles>
    <DockPanel LastChildFill="True">

      <!-- Status banner -->
      <Border DockPanel.Dock="Top"
              IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
              Background="#33C00000" BorderBrush="#88C00000" BorderThickness="1"
              CornerRadius="4" Padding="10,6" Margin="0,0,0,12">
        <TextBlock Text="{Binding StatusMessage}" Foreground="#FFE6E6" TextWrapping="Wrap" />
      </Border>

      <ScrollViewer>
      <StackPanel Spacing="12">

        <!-- Now-playing / transport card -->
        <Border Classes="card">
          <StackPanel Spacing="12">

            <!-- Header: player name + settings flyout -->
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" FontWeight="SemiBold" FontSize="16"
                         VerticalAlignment="Center" Text="{Binding Name}" />
              <Button Grid.Column="1" Padding="8,4" Content="{x:Static res:Strings.MediaPlayerSettingsButtonLabel}"
                      ToolTip.Tip="{x:Static res:Strings.MediaPlayerSettingsTooltip}">
                <Button.Flyout>
                  <MenuFlyout>
                    <MenuItem Header="{x:Static res:Strings.SavePlayerConfigMenuHeader}" Command="{Binding SavePlayerConfigCommand}" />
                    <MenuItem Header="{x:Static res:Strings.LoadPlayerConfigMenuHeader}" Command="{Binding LoadPlayerConfigCommand}" />
                    <Separator />
                    <MenuItem Header="{x:Static res:Strings.UnloadCurrentSessionMenuHeader}"
                              Command="{Binding CloseSessionCommand}" />
                    <MenuItem Header="{x:Static res:Strings.RemoveThisPlayerMenuHeader}"
                              Command="{Binding RemovePlayerCommand}"
                              IsVisible="{Binding CanRemove}" />
                  </MenuFlyout>
                </Button.Flyout>
              </Button>
            </Grid>

            <!-- Current source -->
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Border Background="#22808080" CornerRadius="3" Padding="6,2"
                      VerticalAlignment="Center"
                      ToolTip.Tip="{x:Static res:Strings.SourceKindTooltip}">
                <TextBlock FontSize="11" FontWeight="SemiBold"
                           Text="{Binding SourceKindLabel}" />
              </Border>
              <TextBlock Opacity="0.75" FontSize="12" TextTrimming="CharacterEllipsis"
                         VerticalAlignment="Center"
                         Text="{Binding CurrentMediaDisplay, FallbackValue={x:Static res:Strings.NoMediaLoadedHint}, TargetNullValue={x:Static res:Strings.NoMediaLoadedHint}}"
                         ToolTip.Tip="{Binding CurrentMediaDisplay}" />
            </StackPanel>

            <!-- Phase C.5 (§6.9) — "waiting for source" banner for live inputs that aren't currently
                 resolvable. The transport bar stays interactive (Stop cancels retries). -->
            <Border IsVisible="{Binding IsWaitingForSource}"
                    Background="#332E7DAA" CornerRadius="3" Padding="8,4">
              <TextBlock FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap"
                         Text="{Binding WaitingForSourceMessage}" />
            </Border>

            <!-- Scrubber: TwoWay binding for visual tracking; commit on PointerReleased (code-behind).
                 Keyboard transport: Space play/pause, [ ] prev/next, , . jog -5/+5 s (handled in code-behind).
                 Hidden for live items (§6.5) — no finite duration, no seek. -->
            <Slider Name="SeekSlider"
                    Minimum="0" Maximum="1000"
                    Value="{Binding SeekSliderValue, Mode=TwoWay}"
                    IsEnabled="{Binding IsMediaLoaded}"
                    IsVisible="{Binding IsTransportSeekable}"
                    ToolTip.Tip="{x:Static res:Strings.SeekSliderTooltip}" />

            <!-- Three times: position / remaining / total. Hidden for live items (§6.5). -->
            <Grid ColumnDefinitions="*,*,*" IsVisible="{Binding IsTransportSeekable}">
              <StackPanel Grid.Column="0">
                <TextBlock Classes="time" HorizontalAlignment="Center"
                           Text="{Binding CurrentPositionText}" />
                <TextBlock Classes="time-label" Text="{x:Static res:Strings.PositionTimeLabel}" />
              </StackPanel>
              <StackPanel Grid.Column="1">
                <TextBlock Classes="time" HorizontalAlignment="Center"
                           Text="{Binding RemainingTimeText}" />
                <TextBlock Classes="time-label" Text="{x:Static res:Strings.RemainingTimeLabel}" />
              </StackPanel>
              <StackPanel Grid.Column="2">
                <TextBlock Classes="time" HorizontalAlignment="Center" Opacity="0.75"
                           Text="{Binding DurationText}" />
                <TextBlock Classes="time-label" Text="{x:Static res:Strings.DurationTimeLabel}" />
              </StackPanel>
            </Grid>

            <!-- Transport row: prev / play-pause / next / stop + loop + display-mode -->
            <Grid ColumnDefinitions="*,Auto,*">
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                          HorizontalAlignment="Center">
                <Button Classes="transport" Content="{x:Static res:Strings.PreviousTrackGlyph}"
                        Command="{Binding PreviousTrackCommand}"
                        ToolTip.Tip="{x:Static res:Strings.PreviousTrackTooltip}" />
                <Button Classes="play-pause"
                        Content="{Binding PlayPauseLabel}"
                        Command="{Binding TogglePlayPauseCommand}"
                        ToolTip.Tip="{x:Static res:Strings.PlayPauseTooltip}" />
                <Button Classes="transport" Content="{x:Static res:Strings.NextTrackGlyph}"
                        Command="{Binding NextTrackCommand}"
                        ToolTip.Tip="{x:Static res:Strings.NextTrackTooltip}" />
                <Button Classes="transport" Content="{x:Static res:Strings.StopTrackGlyph}"
                        Command="{Binding StopCommand}"
                        ToolTip.Tip="{x:Static res:Strings.StopTrackTooltip}" />
              </StackPanel>
              <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6"
                          HorizontalAlignment="Right">
                <ToggleButton Content="{x:Static res:Strings.MuteToggleLabel}"
                              IsChecked="{Binding MasterMuted}"
                              Padding="10,6"
                              ToolTip.Tip="{x:Static res:Strings.MuteToggleTooltip}" />
                <Slider Width="120" Minimum="-60" Maximum="12"
                        Value="{Binding MasterVolumeDb, Mode=TwoWay}"
                        VerticalAlignment="Center"
                        ToolTip.Tip="{x:Static res:Strings.MasterGainTooltip}" />
                <TextBlock Classes="time" Width="56" VerticalAlignment="Center"
                           Text="{Binding MasterVolumeDb, StringFormat='{}{0:0.#} dB'}" />
                <ToggleButton Content="{x:Static res:Strings.LoopToggleLabel}" IsChecked="{Binding IsLooping}" Padding="10,6"
                              ToolTip.Tip="{x:Static res:Strings.LoopToggleTooltip}" />
                <ToggleButton Content="{x:Static res:Strings.AutoAdvanceToggleLabel}"
                              IsChecked="{Binding AutoAdvancePlaylist}" Padding="10,6"
                              ToolTip.Tip="{x:Static res:Strings.AutoAdvanceToggleTooltip}" />
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>

        <!-- Playlist card -->
        <Border Classes="card"
                ToolTip.Tip="{x:Static res:Strings.PlaylistCardTooltip}">
          <DockPanel LastChildFill="True">
            <DockPanel DockPanel.Dock="Top" LastChildFill="False" Margin="0,0,0,8">
              <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="4" Margin="0,0,0,8">
                <TabStrip ItemsSource="{Binding PlaylistTabs}"
                          SelectedItem="{Binding SelectedPlaylistTab}"
                          MinWidth="260">
                  <TabStrip.ItemTemplate>
                    <DataTemplate x:DataType="vm:PlaylistTabViewModel">
                      <TextBox Text="{Binding Name, Mode=TwoWay}"
                               MinWidth="72"
                               BorderThickness="0"
                               Background="Transparent" />
                    </DataTemplate>
                  </TabStrip.ItemTemplate>
                </TabStrip>
                <Button Content="{x:Static res:Strings.AddPlaylistTabButton}" MinWidth="34"
                        Command="{Binding AddPlaylistTabCommand}"
                        ToolTip.Tip="{x:Static res:Strings.AddPlaylistTabTooltip}" />
                <Button Content="{x:Static res:Strings.RemoveTabButton}"
                        Command="{Binding RemovePlaylistTabCommand}" />
              </StackPanel>
            </DockPanel>

            <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto,Auto,Auto" Margin="0,0,0,8" ColumnSpacing="4">
              <TextBlock Grid.Column="0" Text="{x:Static res:Strings.PlaylistSectionTitle}" Classes="section-title" VerticalAlignment="Center" />
              <Button Grid.Column="1" Content="{x:Static res:Strings.MoveUpButton}" Command="{Binding MovePlaylistItemUpCommand}"
                      MinWidth="34" ToolTip.Tip="{x:Static res:Strings.MoveUpTooltip}" />
              <Button Grid.Column="2" Content="{x:Static res:Strings.MoveDownButton}" Command="{Binding MovePlaylistItemDownCommand}"
                      MinWidth="34" ToolTip.Tip="{x:Static res:Strings.MoveDownTooltip}" />
              <Button Grid.Column="3" Content="{x:Static res:Strings.RemoveButton}" Command="{Binding RemoveFromPlaylistCommand}"
                      ToolTip.Tip="{x:Static res:Strings.RemovePlaylistItemTooltip}" />
              <Button Grid.Column="4" Content="{x:Static res:Strings.SaveTabButton}"
                      Command="{Binding SavePlaylistTabCommand}" />
              <Button Grid.Column="5" Content="{x:Static res:Strings.LoadTabButton}"
                      Command="{Binding LoadPlaylistTabCommand}" />
              <Button Grid.Column="6" Content="{x:Static res:Strings.AddFilesButton}"
                      Command="{Binding AddFilesToPlaylistCommand}" />
              <Button Grid.Column="7" Content="{x:Static res:Strings.AddLiveInputButton}"
                      ToolTip.Tip="{x:Static res:Strings.AddLiveInputTooltip}">
                <Button.Flyout>
                  <MenuFlyout>
                    <MenuItem Header="{x:Static res:Strings.PortAudioInputMenuHeader}"
                              Command="{Binding AddPortAudioInputCommand}" />
                    <MenuItem Header="{x:Static res:Strings.NdiInputMenuHeader}"
                              Command="{Binding AddNDIInputCommand}" />
                  </MenuFlyout>
                </Button.Flyout>
              </Button>
            </Grid>

            <ListBox Name="PlaylistListBox" MinHeight="220" MaxHeight="380"
                     ItemsSource="{Binding PlaylistItems}"
                     SelectedItem="{Binding SelectedPlaylistItem, Mode=TwoWay}"
                     DoubleTapped="OnPlaylistItemDoubleTapped">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="models:PlaylistItem">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="{Binding KindGlyph}" Opacity="0.85" />
                    <TextBlock Text="{Binding DisplayName}"
                               ToolTip.Tip="{Binding ToolTip}"
                               TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </DockPanel>
        </Border>

        <!-- Routing expander (collapsed once configured; shows count when collapsed) -->
        <Expander IsExpanded="{Binding IsRoutingExpanded, Mode=TwoWay}"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Stretch">
          <Expander.Header>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="{x:Static res:Strings.RoutingSectionTitle}" FontWeight="SemiBold" />
              <TextBlock Opacity="0.7" Text="{Binding RoutingSummary}" />
            </StackPanel>
          </Expander.Header>
          <Border Classes="card" Padding="10">
            <StackPanel Spacing="6">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Opacity="0.7" FontSize="12"
                           Text="{x:Static res:Strings.RoutingHint}" />
                <Button Grid.Column="1" Content="{x:Static res:Strings.AddOutputButton}" Padding="10,4">
                  <Button.Flyout>
                    <MenuFlyout>
                      <MenuItem Header="{x:Static res:Strings.PortAudioOutputMenuHeader}"
                                Command="{Binding AddPortAudioOutputCommand}" />
                      <MenuItem Header="{x:Static res:Strings.LocalVideoOutputMenuHeader}"
                                Command="{Binding AddLocalVideoOutputCommand}" />
                      <MenuItem Header="{x:Static res:Strings.NdiOutputMenuHeader}"
                                Command="{Binding AddNDIOutputCommand}" />
                    </MenuFlyout>
                  </Button.Flyout>
                </Button>
              </Grid>
              <ItemsControl ItemsSource="{Binding Outputs}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:PlayerOutputBinding">
                    <Grid ColumnDefinitions="Auto,*" Margin="0,2">
                      <CheckBox Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0"
                                IsChecked="{Binding IsSelected}"
                                IsEnabled="{Binding Line.SupportsMediaPlayerRouting}" />
                      <StackPanel Grid.Column="1" Spacing="1"
                                  ToolTip.Tip="{Binding Line.Summary}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                          <TextBlock FontWeight="SemiBold" Text="{Binding Line.KindLabel}" />
                          <TextBlock Text="{x:Static res:Strings.EmDash}" Opacity="0.5" />
                          <TextBlock Text="{Binding Line.Definition.DisplayName}" />
                        </StackPanel>
                      </StackPanel>
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <Border BorderBrush="#22FFFFFF" BorderThickness="0,1,0,0" Margin="0,4,0,0" Padding="0,8,0,0"
                      IsVisible="{Binding HasHeadphonesCueOutputs}">
                <StackPanel Spacing="6">
                  <TextBlock Opacity="0.8" FontSize="12"
                             Text="{x:Static res:Strings.HeadphonesCueBusLabel}" />
                  <Grid ColumnDefinitions="Auto,2*,Auto,Auto,140,64" ColumnSpacing="8">
                    <ToggleButton Grid.Column="0"
                                  Content="{x:Static res:Strings.Enable}"
                                  IsChecked="{Binding HeadphonesCueEnabled}" />
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding HeadphonesCueTargets}"
                              SelectedItem="{Binding SelectedHeadphonesCueTarget}"
                              IsEnabled="{Binding HeadphonesCueEnabled}">
                      <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:HeadphonesCueTargetOption">
                          <TextBlock Text="{Binding Display}" />
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{x:Static res:Strings.Tap}" />
                    <ComboBox Grid.Column="3" MinWidth="110"
                              ItemsSource="{Binding HeadphonesCueTapPoints}"
                              SelectedItem="{Binding HeadphonesCueTapPoint}"
                              IsEnabled="{Binding HeadphonesCueEnabled}" />
                    <NumericUpDown Grid.Column="4"
                                   Minimum="-60" Maximum="12" Increment="1"
                                   Value="{Binding HeadphonesCueGainDb}"
                                   IsEnabled="{Binding HeadphonesCueEnabled}" />
                    <TextBlock Grid.Column="5" Classes="time" VerticalAlignment="Center"
                               Text="{Binding HeadphonesCueGainDb, StringFormat='{}{0:0.#} dB'}" />
                  </Grid>
                  <TextBlock Opacity="0.55" FontSize="11"
                             Text="{x:Static res:Strings.HeadphonesCueMatrixHint}" />
                </StackPanel>
              </Border>

              <TextBlock Opacity="0.55" FontSize="11"
                         IsVisible="{Binding HasNoOutputs}"
                         Text="{x:Static res:Strings.NoOutputsConfiguredHint}" />
            </StackPanel>
          </Border>
        </Expander>

        <!-- Audio matrix: per-(output-channel × input-channel) gain in dB. Rows are device channels;
             columns are input channels from the loaded source. Per-output mix-mode + per-output master
             gain still ride on top of every cell via the playback session's compound envelope. -->
        <Expander HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Stretch">
          <Expander.Header>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="{x:Static res:Strings.AudioMatrixSectionTitle}" FontWeight="SemiBold" />
              <TextBlock Opacity="0.7" Text="{x:Static res:Strings.AudioMatrixSectionSubtitle}" />
            </StackPanel>
          </Expander.Header>
          <Border Classes="card" Padding="10">
            <StackPanel Spacing="8">

              <!-- Per-output mix-mode preset row (instantly fills the matrix with a common layout). -->
              <ItemsControl ItemsSource="{Binding Outputs}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:PlayerOutputBinding">
                    <Grid ColumnDefinitions="*,128,Auto,140,64" ColumnSpacing="8" Margin="0,2"
                          IsVisible="{Binding IsSelected}">
                      <TextBlock Grid.Column="0" VerticalAlignment="Center"
                                 Text="{Binding Line.Definition.DisplayName}" />
                      <ComboBox Grid.Column="1" MinWidth="128"
                                ItemsSource="{Binding $parent[UserControl].((vm:MediaPlayerViewModel)DataContext).MixModes}"
                                SelectedItem="{Binding MixMode}"
                                ToolTip.Tip="{x:Static res:Strings.MixPresetTooltip}" />
                      <CheckBox Grid.Column="2" Content="{x:Static res:Strings.MuteToggleLabel}"
                                IsChecked="{Binding IsMuted}"
                                ToolTip.Tip="{x:Static res:Strings.DeviceOutputMuteTooltip}" />
                      <Slider Grid.Column="3" Minimum="-60" Maximum="12"
                              Value="{Binding GainDb, Mode=TwoWay}"
                              ToolTip.Tip="{x:Static res:Strings.PerDeviceGainTooltip}" />
                      <TextBlock Grid.Column="4" Classes="time"
                                 Text="{Binding GainText}"
                                 VerticalAlignment="Center" />
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <Border BorderBrush="#22FFFFFF" BorderThickness="0,1,0,0" Margin="0,2,0,0" Padding="0,8,0,0"
                      IsVisible="{Binding HasAudioMatrixInputTrims}">
                <StackPanel Spacing="4">
                  <TextBlock Text="{x:Static res:Strings.InputTrimsTitle}" FontWeight="SemiBold" />
                  <ItemsControl ItemsSource="{Binding AudioMatrixInputTrims}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:AudioMatrixInputTrimViewModel">
                        <Grid ColumnDefinitions="80,Auto,140,60" ColumnSpacing="8" Margin="0,1">
                          <TextBlock Grid.Column="0" VerticalAlignment="Center"
                                     Text="{Binding Label}" />
                          <CheckBox Grid.Column="1" Content="{x:Static res:Strings.MuteToggleLabel}"
                                    IsChecked="{Binding Muted}" />
                          <Slider Grid.Column="2" Minimum="-24" Maximum="24"
                                  Value="{Binding GainDb, Mode=TwoWay}" />
                          <TextBlock Grid.Column="3" Classes="time" VerticalAlignment="Center"
                                     Text="{Binding GainDb, StringFormat={}{0:0.#} dB}" />
                        </Grid>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </Border>

              <!-- Per-cell matrix: rows = device channels, columns = input channels (built in code-behind
                   because the input-channel count comes from the loaded source — TreeDataGrid columns are
                   dynamic). The first column always shows the row label; following columns are gain
                   editors for each input channel. -->
              <TreeDataGrid Name="MatrixTreeGrid"
                            MinHeight="120" MaxHeight="320"
                            IsVisible="{Binding HasAudioMatrix}"
                            CanUserResizeColumns="True"
                            CanUserSortColumns="False"
                            ShowColumnHeaders="True" />
              <TextBlock Opacity="0.55" FontSize="11"
                         IsVisible="{Binding !HasAudioMatrix}"
                         Text="{x:Static res:Strings.AudioMatrixEmptyHint}" />

              <Border BorderBrush="#22FFFFFF" BorderThickness="0,1,0,0" Margin="0,4,0,0" Padding="0,8,0,0">
                <StackPanel Spacing="6">
                  <TextBlock Text="{x:Static res:Strings.ActiveRoutesTitle}" FontWeight="SemiBold" />
                  <TreeDataGrid Name="MatrixRoutesTreeGrid"
                                MinHeight="96" MaxHeight="220"
                                IsVisible="{Binding HasAudioMatrixRoutes}"
                                CanUserResizeColumns="True"
                                CanUserSortColumns="False"
                                ShowColumnHeaders="True" />
                  <TextBlock Opacity="0.55" FontSize="11"
                             IsVisible="{Binding !HasAudioMatrixRoutes}"
                             Text="{x:Static res:Strings.NoActiveRoutesHint}" />
                </StackPanel>
              </Border>
            </StackPanel>
          </Border>
        </Expander>

        <!-- Output preset + transition controls -->
        <Border Classes="card">
          <StackPanel Spacing="6">
            <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,Auto" ColumnSpacing="10">
              <TextBlock Grid.Column="0" Text="{x:Static res:Strings.OutputPresetLabel}" VerticalAlignment="Center" />
              <ComboBox Grid.Column="1"
                        ItemsSource="{Binding OutputPresets}"
                        SelectedItem="{Binding OutputPreset}" />
              <TextBlock Grid.Column="2" Text="{x:Static res:Strings.TransitionLabel}" VerticalAlignment="Center" />
              <ComboBox Grid.Column="3"
                        ItemsSource="{Binding TransitionModes}"
                        SelectedItem="{Binding TransitionMode}" />
              <TextBlock Grid.Column="4" Text="{x:Static res:Strings.MillisecondsShort}" VerticalAlignment="Center" />
              <NumericUpDown Grid.Column="5" Width="92"
                             Minimum="0" Maximum="10000" Increment="50"
                             Value="{Binding TransitionDurationMs}" />
            </Grid>
            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*" ColumnSpacing="8"
                  IsVisible="{Binding IsCustomOutputPreset}"
                  ToolTip.Tip="{x:Static res:Strings.CustomOutputTooltip}">
              <TextBlock Grid.Column="0" Text="{x:Static res:Strings.CustomWidthLabel}" VerticalAlignment="Center" />
              <NumericUpDown Grid.Column="1" Width="96"
                             Minimum="16" Maximum="7680" Increment="2"
                             Value="{Binding CustomOutputWidth}" />
              <TextBlock Grid.Column="2" Text="{x:Static res:Strings.CustomHeightLabel}" VerticalAlignment="Center" />
              <NumericUpDown Grid.Column="3" Width="96"
                             Minimum="16" Maximum="4320" Increment="2"
                             Value="{Binding CustomOutputHeight}" />
              <TextBlock Grid.Column="4" Opacity="0.55" FontSize="11" VerticalAlignment="Center"
                         Text="{x:Static res:Strings.CustomOutputAppliedHint}" />
            </Grid>
            <ToggleButton Content="{x:Static res:Strings.LiveUyvyPassthroughLabel}"
                          IsChecked="{Binding PreferLiveUyvyPassthrough}"
                          HorizontalAlignment="Left"
                          ToolTip.Tip="{x:Static res:Strings.LiveUyvyPassthroughTooltip}" />
          </StackPanel>
        </Border>

        <!-- Idle image expander -->
        <Expander HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Stretch">
          <Expander.Header>
            <StackPanel Orientation="Horizontal" Spacing="8"
                        ToolTip.Tip="{x:Static res:Strings.IdleImageHeaderTooltip}">
              <TextBlock Text="{x:Static res:Strings.IdleImageLabel}" FontWeight="SemiBold" />
              <TextBlock Opacity="0.7" Text="{Binding HoldImageSummary}" />
            </StackPanel>
          </Expander.Header>
          <Border Classes="card" Padding="10" HorizontalAlignment="Stretch">
            <StackPanel Spacing="8">
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBox Grid.Column="0" PlaceholderText="{x:Static res:Strings.FallbackPathPlaceholder}"
                         Text="{Binding FallbackImagePath}" />
                <Button Grid.Column="1" Content="{x:Static res:Strings.BrowseButton}"
                        Command="{Binding BrowseFallbackCommand}" />
              </Grid>
              <ToggleButton Content="{x:Static res:Strings.ShowWhenNoMediaPlaying}"
                            IsChecked="{Binding HoldFallbackVideo}"
                            HorizontalAlignment="Left"
                            ToolTip.Tip="{x:Static res:Strings.HoldFallbackToggleTooltip}" />
            </StackPanel>
          </Border>
        </Expander>
      </StackPanel>
      </ScrollViewer>
    </DockPanel>
</UserControl>
