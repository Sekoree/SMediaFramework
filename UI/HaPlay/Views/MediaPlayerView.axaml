<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:HaPlay.ViewModels"
             xmlns:views="using:HaPlay.Views"
             mc:Ignorable="d" d:DesignWidth="1040" d:DesignHeight="660"
             x:Class="HaPlay.Views.MediaPlayerView"
             x:DataType="vm:MediaPlayerViewModel">

  <UserControl.Resources>
    <views:FilenameConverter x:Key="FilenameConverter" />
  </UserControl.Resources>

  <UserControl.Styles>
    <Style Selector="TextBlock.section-title">
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Margin" Value="0,0,0,4" />
    </Style>
    <Style Selector="TextBlock.time">
      <Setter Property="FontFamily" Value="Consolas,monospace" />
      <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="TextBlock.time-label">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Opacity" Value="0.6" />
      <Setter Property="TextAlignment" Value="Center" />
    </Style>
    <Style Selector="Border.card">
      <Setter Property="BorderBrush" Value="#22808080" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Padding" Value="14" />
      <Setter Property="Background" Value="#08808080" />
    </Style>
    <Style Selector="Button.transport">
      <Setter Property="MinWidth" Value="80" />
      <Setter Property="Padding" Value="14,8" />
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
  </UserControl.Styles>

  <DockPanel Margin="14">

    <!-- Status banner -->
    <Border DockPanel.Dock="Top"
            IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
            Background="#33C00000" BorderBrush="#88C00000" BorderThickness="1"
            CornerRadius="4" Padding="10,6" Margin="0,0,0,12">
      <TextBlock Text="{Binding StatusMessage}" Foreground="#FFE6E6" TextWrapping="Wrap" />
    </Border>

    <!-- Two-column body: controls left, playlist right -->
    <Grid ColumnDefinitions="*,12,360">

      <!-- Left column: controls -->
      <DockPanel Grid.Column="0">

        <!-- Top: now-playing / transport card -->
        <Border DockPanel.Dock="Top" Classes="card" Margin="0,0,0,12">
          <StackPanel Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock FontWeight="SemiBold" FontSize="16" VerticalAlignment="Center"
                         Text="{Binding Name}" />
              <Button Content="Save…"
                      Command="{Binding SavePlayerConfigCommand}"
                      ToolTip.Tip="Save this player's name, playlist, fallback image, transport flags, and selected outputs."
                      Padding="8,2" />
              <Button Content="Load…"
                      Command="{Binding LoadPlayerConfigCommand}"
                      ToolTip.Tip="Replace this player's state with a saved configuration file."
                      Padding="8,2" />
              <Button Content="Remove player"
                      Command="{Binding RemovePlayerCommand}"
                      IsVisible="{Binding CanRemove}"
                      Padding="8,2" />
            </StackPanel>

            <TextBlock Opacity="0.65" FontSize="12" TextTrimming="CharacterEllipsis"
                       Text="{Binding MediaFilePath, FallbackValue='No media loaded — pick a file from the playlist.', TargetNullValue='No media loaded — pick a file from the playlist.'}"
                       ToolTip.Tip="{Binding MediaFilePath}" />

            <!-- Scrubber -->
            <Slider Minimum="0" Maximum="1000"
                    Value="{Binding SeekSliderValue}"
                    IsEnabled="{Binding IsMediaLoaded}" />

            <!-- Three times: position / remaining / total -->
            <Grid ColumnDefinitions="*,*,*">
              <StackPanel Grid.Column="0">
                <TextBlock Classes="time" HorizontalAlignment="Center"
                           Text="{Binding CurrentPositionText}" />
                <TextBlock Classes="time-label" Text="Position" />
              </StackPanel>
              <StackPanel Grid.Column="1">
                <TextBlock Classes="time" HorizontalAlignment="Center"
                           Text="{Binding RemainingTimeText}" />
                <TextBlock Classes="time-label" Text="Remaining" />
              </StackPanel>
              <StackPanel Grid.Column="2">
                <TextBlock Classes="time" HorizontalAlignment="Center" Opacity="0.75"
                           Text="{Binding DurationText}" />
                <TextBlock Classes="time-label" Text="Duration" />
              </StackPanel>
            </Grid>

            <!-- Transport row -->
            <DockPanel>
              <ToggleButton DockPanel.Dock="Right" Content="Loop"
                            IsChecked="{Binding IsLooping}" MinWidth="64" Padding="14,8"
                            ToolTip.Tip="When on, the current track restarts after it ends instead of advancing the playlist." />
              <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                <Button Content="Play" Classes="transport primary"
                        Command="{Binding PlayCommand}"
                        ToolTip.Tip="Start (or auto-load + start) the selected playlist item." />
                <Button Content="Pause" Classes="transport"
                        Command="{Binding PauseCommand}" />
                <Button Content="Stop" Classes="transport"
                        Command="{Binding StopCommand}"
                        ToolTip.Tip="Stop playback and rewind to 00:00." />
                <Button Content="Seek" Classes="transport"
                        Command="{Binding SeekToSliderCommand}"
                        ToolTip.Tip="Jump to the position selected on the slider above." />
              </StackPanel>
            </DockPanel>
          </StackPanel>
        </Border>

        <!-- Routing + fallback below the transport card -->
        <ScrollViewer HorizontalScrollBarVisibility="Disabled">
          <StackPanel Spacing="10">

            <Expander IsExpanded="True"
                      ToolTip.Tip="Tick the outputs this player should drive. Two players can independently route to different outputs (e.g. main → NDI, secondary → local SDL).">
              <Expander.Header>
                <TextBlock Text="Routing — outputs used by this player" />
              </Expander.Header>
              <Border Classes="card" Padding="6">
                <ItemsControl ItemsSource="{Binding Outputs}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:PlayerOutputBinding">
                      <Grid ColumnDefinitions="Auto,*" Margin="0,2">
                        <CheckBox Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0"
                                  IsChecked="{Binding IsSelected}"
                                  IsEnabled="{Binding Line.SupportsMediaPlayerRouting}" />
                        <StackPanel Grid.Column="1" Spacing="1"
                                    ToolTip.Tip="{Binding Line.Summary}">
                          <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock FontWeight="SemiBold" Text="{Binding Line.KindLabel}" />
                            <TextBlock Text="—" Opacity="0.5" />
                            <TextBlock Text="{Binding Line.Definition.DisplayName}" />
                          </StackPanel>
                        </StackPanel>
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </Border>
            </Expander>

            <Expander IsExpanded="False"
                      ToolTip.Tip="When enabled, every video output displays this image instead of decoded pixels — useful for audio-only files, idle slates, or branding overlays.">
              <Expander.Header>
                <TextBlock Text="Video fallback (logo)" />
              </Expander.Header>
              <StackPanel Spacing="8">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                  <TextBox PlaceholderText="PNG / JPEG path…" Text="{Binding FallbackImagePath}" />
                  <Button Grid.Column="1" Content="Browse…" Command="{Binding BrowseFallbackCommand}" />
                  <Button Grid.Column="2" Content="Unload session" Command="{Binding CloseSessionCommand}"
                          ToolTip.Tip="Close the current playback session without removing the player." />
                </Grid>
                <ToggleButton Content="Hold fallback on video outputs"
                              IsChecked="{Binding HoldFallbackVideo}"
                              HorizontalAlignment="Left"
                              ToolTip.Tip="Keep displaying the fallback image even while playing — useful for audio-only files." />
              </StackPanel>
            </Expander>

          </StackPanel>
        </ScrollViewer>
      </DockPanel>

      <!-- Right column: playlist -->
      <Border Grid.Column="2" Classes="card" Padding="10"
              ToolTip.Tip="Double-click an entry to load + play it. Otherwise click Play with a row selected to auto-load.">
        <DockPanel>
          <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
            <TextBlock Grid.Column="0" Text="Playlist" Classes="section-title" VerticalAlignment="Center" />
            <Button Grid.Column="1" Content="Add files…"
                    Command="{Binding AddFilesToPlaylistCommand}"
                    Padding="10,2" />
          </Grid>

          <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*,*,*" ColumnSpacing="4" Margin="0,8,0,0">
            <Button Grid.Column="0" Content="↑" Command="{Binding MovePlaylistItemUpCommand}"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    ToolTip.Tip="Move the selected entry up." />
            <Button Grid.Column="1" Content="↓" Command="{Binding MovePlaylistItemDownCommand}"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    ToolTip.Tip="Move the selected entry down." />
            <Button Grid.Column="2" Content="Remove" Command="{Binding RemoveFromPlaylistCommand}"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
          </Grid>

          <ListBox Name="PlaylistListBox"
                   ItemsSource="{Binding PlaylistPaths}"
                   SelectedItem="{Binding SelectedPlaylistPath, Mode=TwoWay}"
                   DoubleTapped="OnPlaylistItemDoubleTapped">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Converter={StaticResource FilenameConverter}}"
                           ToolTip.Tip="{Binding}"
                           TextTrimming="CharacterEllipsis" />
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
      </Border>

    </Grid>
  </DockPanel>
</UserControl>
