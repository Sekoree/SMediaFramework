<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HaPlay.ViewModels"
             x:Class="HaPlay.Views.ControlPanes.ControlScriptsView"
             x:DataType="vm:ControlWorkspaceViewModel">
  <!-- Scripts dock tab (extracted for Dock.Avalonia). Double-tap / Edit opens a separate ScriptEditorWindow. -->
  <Border Classes="Card" Margin="0,8,0,0">
    <DockPanel>
      <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="4" Margin="0,0,0,8">
        <TextBlock Grid.Column="0" Classes="SectionText" Text="Scripts" VerticalAlignment="Center" />
        <Button Grid.Column="1" Content="+" Classes="Dense" ToolTip.Tip="Add script" Command="{Binding AddScriptCommand}" />
        <Button Grid.Column="2" Content="Add helper" Classes="Dense" ToolTip.Tip="Add imported helper script file" Command="{Binding AddHelperFileCommand}" />
        <Button Grid.Column="3" Content="–" Classes="Dense" ToolTip.Tip="Remove selected script" Command="{Binding RemoveSelectedScriptCommand}" />
        <Button Grid.Column="4" Content="Edit…" Classes="Dense" Click="OnEditScriptClick"
                ToolTip.Tip="Open the selected script in a separate editor window" />
      </Grid>
      <TextBlock DockPanel.Dock="Bottom" Margin="0,8,0,0" Classes="CaptionText" TextWrapping="Wrap"
                 Text="Double-click a script (or use Edit…) to open it in a separate editor window with the code editor, triggers, and learn mode." />
      <ListBox x:Name="ScriptList"
               ItemsSource="{Binding ScriptRows}"
               SelectedItem="{Binding SelectedScriptRow, Mode=TwoWay}"
               DoubleTapped="OnScriptListDoubleTapped">
        <ListBox.ItemTemplate>
          <DataTemplate DataType="vm:ControlScriptRowViewModel">
            <StackPanel Spacing="1">
              <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
              <TextBlock Text="{Binding DisplayScriptPath}" FontSize="12" Opacity="0.72" TextTrimming="CharacterEllipsis" />
              <TextBlock Text="{Binding ScopeText}" FontSize="12" Opacity="0.6" />
            </StackPanel>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </DockPanel>
  </Border>
</UserControl>
