<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HaPlay.ViewModels"
             xmlns:res="using:HaPlay.Resources"
             x:Class="HaPlay.Views.ControlPanes.ControlSurfacesView"
             x:DataType="vm:ControlWorkspaceViewModel">
  <!-- Surfaces dock tab (extracted from ControlWorkspaceView for Dock.Avalonia): devices / listeners /
       layers + profiles. DataContext is the shared ControlWorkspaceViewModel (set by the dock tool template). -->
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <StackPanel Margin="0,8,0,0">

      <Border Classes="Card" Margin="0,0,0,10">
        <DockPanel>
          <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="6" Margin="0,0,0,8">
            <TextBlock Grid.Column="0" Classes="SectionText" Text="Project structure" VerticalAlignment="Center" />
            <Button Grid.Column="1" Content="Add layer…"
                    ToolTip.Tip="Add a control layer (mutually-exclusive set of layer-scoped scripts)"
                    Command="{Binding AddLayerCommand}" />
            <Button Grid.Column="2" Content="Add OSC device…"
                    ToolTip.Tip="Add an OSC device such as an X32 or X-Air"
                    Command="{Binding AddOSCDeviceCommand}" />
            <Button Grid.Column="3" Content="Add OSC listener…"
                    ToolTip.Tip="Add an inbound OSC listener port for external control sources"
                    Command="{Binding AddOSCListenerCommand}" />
            <Button Grid.Column="4" Content="Resolve MIDI…"
                    ToolTip.Tip="Pick current ports for ambiguous or missing MIDI devices"
                    Command="{Binding ResolveMIDIDevicesCommand}"
                    IsVisible="{Binding IsMIDIAvailable}" />
          </Grid>
          <ItemsControl DockPanel.Dock="Bottom" ItemsSource="{Binding ProfileWarnings}" Margin="0,8,0,0">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding}" Foreground="#D7A300" TextWrapping="Wrap" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <TextBlock DockPanel.Dock="Top"
                     Text="Scripts can be added from the Scripts tab, or from a layer/device/endpoint row menu."
                     Classes="CaptionText"
                     TextWrapping="Wrap"
                     Margin="0,0,0,6" />
          <ListBox ItemsSource="{Binding StructureRows}"
                   ScrollViewer.VerticalScrollBarVisibility="Disabled"
                   Background="Transparent">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="vm:ControlStructureRowViewModel">
                <Grid ColumnDefinitions="Auto,72,150,*,76,Auto" ColumnSpacing="8" Margin="0,2">
                  <Grid.ContextMenu>
                    <ContextMenu x:DataType="vm:ControlStructureRowViewModel">
                      <MenuItem Header="Add device script" Command="{Binding AddDeviceScriptCommand}" IsVisible="{Binding CanAddDeviceScript}" />
                      <MenuItem Header="Add endpoint script" Command="{Binding AddEndpointScriptCommand}" IsVisible="{Binding CanAddEndpointScript}" />
                      <MenuItem Header="Add OSC listener…" Command="{Binding AddOSCListenerCommand}" />
                      <MenuItem Header="Edit OSC listener…" Command="{Binding EditOSCListenerCommand}" IsVisible="{Binding CanEditOSCListener}" />
                      <MenuItem Header="Remove OSC listener" Command="{Binding RemoveOSCListenerCommand}" IsVisible="{Binding CanEditOSCListener}" />
                      <MenuItem Header="Add layer script" Command="{Binding AddLayerScriptCommand}" IsVisible="{Binding CanAddLayerScript}" />
                      <MenuItem Header="Add layer…" Command="{Binding AddLayerCommand}" />
                      <MenuItem Header="Activate layer" Command="{Binding ActivateLayerCommand}" IsVisible="{Binding CanActivateLayer}" />
                      <MenuItem Header="Edit layer…" Command="{Binding EditLayerCommand}" IsVisible="{Binding CanEditLayer}" />
                      <MenuItem Header="{x:Static res:Strings.ExportLayerMenuHeader}" Command="{Binding ExportLayerCommand}" IsVisible="{Binding CanEditLayer}" />
                      <MenuItem Header="Remove layer" Command="{Binding RemoveLayerCommand}" IsVisible="{Binding CanEditLayer}" />
                      <MenuItem Header="Add periodic OSC send…" Command="{Binding AddPeriodicSendCommand}" IsVisible="{Binding CanAddPeriodicSend}" />
                      <MenuItem Header="Edit periodic send…" Command="{Binding EditPeriodicSendCommand}" IsVisible="{Binding CanEditPeriodicSend}" />
                      <MenuItem Header="Remove periodic send" Command="{Binding RemovePeriodicSendCommand}" IsVisible="{Binding CanEditPeriodicSend}" />
                      <Separator IsVisible="{Binding CanAddDeviceScript}" />
                      <MenuItem Header="Edit OSC device…" Command="{Binding EditOSCDeviceCommand}" IsVisible="{Binding CanEditOSCDevice}" />
                      <MenuItem Header="Remove OSC device" Command="{Binding RemoveOSCDeviceCommand}" IsVisible="{Binding CanEditOSCDevice}" />
                      <MenuItem Header="Test OSC send" Command="{Binding TestOSCCommand}" IsVisible="{Binding CanTestOSC}" />
                      <MenuItem Header="Edit MIDI device…" Command="{Binding EditMIDIDeviceCommand}" IsVisible="{Binding CanEditMIDIDevice}" />
                      <MenuItem Header="Test MIDI send" Command="{Binding TestMIDICommand}" IsVisible="{Binding CanTestMIDI}" />
                    </ContextMenu>
                  </Grid.ContextMenu>
                  <Border Grid.Column="0" Width="{Binding IndentWidth}" />
                  <TextBlock Grid.Column="1" Text="{Binding Kind}" Opacity="0.7" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                  <TextBlock Grid.Column="2" Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                  <TextBlock Grid.Column="3" Text="{Binding Detail}" Opacity="0.72" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                  <TextBlock Grid.Column="4" Text="{Binding State}" Opacity="0.7" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                  <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <Button Content="Activate" Classes="Dense" ToolTip.Tip="Activate this layer (mutually exclusive)"
                            IsVisible="{Binding CanActivateLayer}" Command="{Binding ActivateLayerCommand}" />
                    <Button Content="Edit" Classes="Dense" ToolTip.Tip="Edit layer"
                            IsVisible="{Binding CanEditLayer}" Command="{Binding EditLayerCommand}" />
                    <Button Content="Remove" Classes="Dense" ToolTip.Tip="Remove layer"
                            IsVisible="{Binding CanEditLayer}" Command="{Binding RemoveLayerCommand}" />
                    <Button Content="Edit" Classes="Dense" ToolTip.Tip="Edit OSC device"
                            IsVisible="{Binding CanEditOSCDevice}" Command="{Binding EditOSCDeviceCommand}" />
                    <Button Content="Remove" Classes="Dense" ToolTip.Tip="Remove OSC device"
                            IsVisible="{Binding CanEditOSCDevice}" Command="{Binding RemoveOSCDeviceCommand}" />
                    <Button Content="Edit" Classes="Dense" ToolTip.Tip="Edit OSC listener"
                            IsVisible="{Binding CanEditOSCListener}" Command="{Binding EditOSCListenerCommand}" />
                    <Button Content="Remove" Classes="Dense" ToolTip.Tip="Remove OSC listener"
                            IsVisible="{Binding CanEditOSCListener}" Command="{Binding RemoveOSCListenerCommand}" />
                    <Button Content="Edit" Classes="Dense" ToolTip.Tip="Edit periodic send"
                            IsVisible="{Binding CanEditPeriodicSend}" Command="{Binding EditPeriodicSendCommand}" />
                    <Button Content="Remove" Classes="Dense" ToolTip.Tip="Remove periodic send"
                            IsVisible="{Binding CanEditPeriodicSend}" Command="{Binding RemovePeriodicSendCommand}" />
                  </StackPanel>
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
      </Border>

      <Border Classes="Card" Margin="0,0,0,10">
        <StackPanel Spacing="8">
          <TextBlock Classes="SectionText" Text="Profiles" />
          <StackPanel Orientation="Horizontal" Spacing="4">
            <Button Content="Import" Classes="Dense" Command="{Binding ImportProfileCommand}" />
            <Button Content="Export selected" Classes="Dense" Command="{Binding ExportSelectedProfileCommand}" />
            <Button Content="Export built-ins" Classes="Dense" Command="{Binding ExportBuiltInProfilesCommand}" />
            <Button Content="Remove project" Classes="Dense" Command="{Binding RemoveSelectedProjectProfileCommand}" />
          </StackPanel>
          <Border BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="1" CornerRadius="0" Padding="8"
                  IsVisible="{Binding IsMIDIAvailable}">
            <StackPanel Spacing="6">
              <TextBlock Text="MIDI profile builder" FontWeight="SemiBold" />
              <Grid ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="6" RowSpacing="6">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Profile" VerticalAlignment="Center" />
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ProfileBuilderDisplayName}" PlaceholderText="Custom MIDI Surface" />
                <TextBlock Grid.Row="0" Grid.Column="2" Text="ID" VerticalAlignment="Center" />
                <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding ProfileBuilderId}" PlaceholderText="auto" />
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Control" VerticalAlignment="Center" />
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ProfileBuilderControlName}" PlaceholderText="Fader 1" />
                <StackPanel Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="Channel" VerticalAlignment="Center" />
                  <TextBox Width="54" Text="{Binding ProfileBuilderMIDIChannelText}" />
                  <TextBlock Text="CC" VerticalAlignment="Center" />
                  <TextBox Width="54" Text="{Binding ProfileBuilderMIDIControllerText}" />
                  <CheckBox Content="14-bit CC" IsChecked="{Binding ProfileBuilderHighResolution14Bit}" VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Range" VerticalAlignment="Center" />
                <StackPanel Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="6">
                  <TextBox Width="80" Text="{Binding ProfileBuilderMinValueText}" PlaceholderText="min" />
                  <TextBox Width="80" Text="{Binding ProfileBuilderMaxValueText}" PlaceholderText="max" />
                  <Button Content="Save project profile" Command="{Binding SaveMIDIProfileBuilderCommand}" />
                </StackPanel>
                <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding ProfileBuilderStatus}" Opacity="0.7"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
              </Grid>
            </StackPanel>
          </Border>
          <ListBox ItemsSource="{Binding ProfileRows}"
                   SelectedItem="{Binding SelectedProfileRow}"
                   MaxHeight="180"
                   Background="Transparent">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="vm:ControlProfileRowViewModel">
                <Grid ColumnDefinitions="180,90,90,*" ColumnSpacing="8" Margin="0,2">
                  <TextBlock Grid.Column="0" Text="{Binding DisplayName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                  <TextBlock Grid.Column="1" Text="{Binding Protocol}" Opacity="0.75" TextTrimming="CharacterEllipsis" />
                  <TextBlock Grid.Column="2" Text="{Binding Source}" Opacity="0.75" TextTrimming="CharacterEllipsis" />
                  <TextBlock Grid.Column="3" Text="{Binding Summary}" Opacity="0.75" TextTrimming="CharacterEllipsis" />
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
