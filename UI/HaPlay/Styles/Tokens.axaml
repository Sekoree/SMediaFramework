<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!--
    "Deck" design tokens (UI rewrite P1, 2026-06-10 UI rewrite plan §1).
    The ONLY place spacing, type ramp, surface, accent, and touch-tier values live.
    Views consume the classes/resources below; per-view <UserControl.Styles> color or
    size constants are being removed phase by phase.
  -->

  <Styles.Resources>
    <ResourceDictionary>
      <!-- Spacing scale -->
      <Thickness x:Key="SpaceXS">4</Thickness>
      <Thickness x:Key="SpaceS">8</Thickness>
      <Thickness x:Key="SpaceM">12</Thickness>
      <Thickness x:Key="SpaceL">16</Thickness>
      <Thickness x:Key="SpaceXL">24</Thickness>
      <x:Double x:Key="GapXS">4</x:Double>
      <x:Double x:Key="GapS">8</x:Double>
      <x:Double x:Key="GapM">12</x:Double>
      <x:Double x:Key="GapL">16</x:Double>

      <!-- Semantic COLOR roles are variant-aware (review P3-5): Simple/Fluent honour the dark
           variant, so every status/state/text role carries a Default (light - also what the pinned-
           Light Classic resolves) and a Dark value. Consumers MUST reference these via
           DynamicResource so a runtime theme switch re-resolves them. -->
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Default">
          <!-- Surfaces -->
          <SolidColorBrush x:Key="BorderSubtle" Color="#22808080" />
          <SolidColorBrush x:Key="SurfaceRaised" Color="#08808080" />
          <SolidColorBrush x:Key="SurfaceSunken" Color="#10000000" />

          <!-- Accent roles -->
          <SolidColorBrush x:Key="AccentGo" Color="#2E7D32" />
          <SolidColorBrush x:Key="AccentGoHover" Color="#388E3C" />
          <SolidColorBrush x:Key="AccentWarn" Color="#F9A825" />
          <SolidColorBrush x:Key="AccentDanger" Color="#C62828" />
          <SolidColorBrush x:Key="ChipNeutral" Color="#22808080" />

          <!-- Status-line / toast severity foregrounds: dark shades for light-gray surfaces. -->
          <SolidColorBrush x:Key="StatusInfoFg" Color="#37474F" />
          <SolidColorBrush x:Key="StatusWarnFg" Color="#8A5A00" />
          <SolidColorBrush x:Key="StatusErrorFg" Color="#B71C1C" />

          <!-- Operational-state roles (UX-05): semantic names so a critical state is never
               communicated by a raw hex only; reserved for live operation. -->
          <SolidColorBrush x:Key="StateSelected" Color="#333B82F6" />
          <SolidColorBrush x:Key="AccentSelectedNav" Color="#3B82F6" />  <!-- active-workspace bar -->
          <SolidColorBrush x:Key="StateLive"     Color="#2E9E4B" />
          <SolidColorBrush x:Key="StateHeld"     Color="#E67E22" />
          <SolidColorBrush x:Key="StateHealthy"  Color="#2E9E4B" />
          <SolidColorBrush x:Key="StatePanic"    Color="#C0392B" />
          <SolidColorBrush x:Key="TextSecondary" Color="#888888" />
          <SolidColorBrush x:Key="TextDisabled"  Color="#99888888" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
          <!-- Surfaces: raised = light tint, sunken = deeper black on dark chrome. -->
          <SolidColorBrush x:Key="BorderSubtle" Color="#33A0A0A0" />
          <SolidColorBrush x:Key="SurfaceRaised" Color="#14FFFFFF" />
          <SolidColorBrush x:Key="SurfaceSunken" Color="#26000000" />

          <!-- Accent roles: nudged brighter so they hold their weight on near-black. -->
          <SolidColorBrush x:Key="AccentGo" Color="#388E3C" />
          <SolidColorBrush x:Key="AccentGoHover" Color="#43A047" />
          <SolidColorBrush x:Key="AccentWarn" Color="#FFB300" />
          <SolidColorBrush x:Key="AccentDanger" Color="#E53935" />
          <SolidColorBrush x:Key="ChipNeutral" Color="#33A0A0A0" />

          <!-- Severity foregrounds: light tints - the light-surface shades fail contrast on dark
               (e.g. #8A5A00 amber reads as mud on near-black). -->
          <SolidColorBrush x:Key="StatusInfoFg" Color="#B0BEC5" />
          <SolidColorBrush x:Key="StatusWarnFg" Color="#FFB74D" />
          <SolidColorBrush x:Key="StatusErrorFg" Color="#EF9A9A" />

          <SolidColorBrush x:Key="StateSelected" Color="#4D5B9BF8" />
          <SolidColorBrush x:Key="AccentSelectedNav" Color="#5B9BF8" />  <!-- active-workspace bar -->
          <SolidColorBrush x:Key="StateLive"     Color="#43B564" />
          <SolidColorBrush x:Key="StateHeld"     Color="#FFA726" />
          <SolidColorBrush x:Key="StateHealthy"  Color="#43B564" />
          <SolidColorBrush x:Key="StatePanic"    Color="#E4574A" />
          <SolidColorBrush x:Key="TextSecondary" Color="#A6A6A6" />
          <SolidColorBrush x:Key="TextDisabled"  Color="#99A0A0A0" />
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>
    </ResourceDictionary>
  </Styles.Resources>

  <!-- ===== Type ramp ===== -->
  <Style Selector="TextBlock.TitleText">
    <Setter Property="FontSize" Value="22" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>
  <Style Selector="TextBlock.SectionText">
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>
  <Style Selector="TextBlock.BodyText">
    <Setter Property="FontSize" Value="13" />
  </Style>
  <Style Selector="TextBlock.CaptionText">
    <Setter Property="FontSize" Value="11" />
    <Setter Property="Opacity" Value="0.65" />
  </Style>
  <Style Selector="TextBlock.MonoTime">
    <Setter Property="FontFamily" Value="Consolas,monospace" />
    <Setter Property="FontSize" Value="13" />
  </Style>

  <!-- ===== Surfaces ===== (square corners - the Classic theme has no rounded chrome) -->
  <Style Selector="Border.Card">
    <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Padding" Value="{StaticResource SpaceM}" />
    <Setter Property="Background" Value="{DynamicResource SurfaceRaised}" />
  </Style>
  <Style Selector="Border.Strip">
    <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}" />
    <Setter Property="BorderThickness" Value="0,1,0,0" />
    <Setter Property="Padding" Value="10,6" />
  </Style>
  <Style Selector="Border.Chip">
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Padding" Value="6,2" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="Background" Value="{DynamicResource ChipNeutral}" />
  </Style>

  <!-- ===== Touch tiers =====
       Btn.Touch: panic-path controls only (transport, GO, HOLD, Stop-All). Never shrinks
       with the Density setting. Btn.Std: normal buttons. Btn.Dense: inspector rows. -->
  <Style Selector="Button.Touch, ToggleButton.Touch">
    <Setter Property="MinWidth" Value="56" />
    <Setter Property="MinHeight" Value="56" />
    <Setter Property="FontSize" Value="20" />
    <Setter Property="Padding" Value="14,10" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>
  <Style Selector="Button.Std, ToggleButton.Std">
    <Setter Property="MinHeight" Value="36" />
    <Setter Property="Padding" Value="10,6" />
    <!-- Center content explicitly: Classic centres button content by default but Fluent does not, which
         left a lone glyph (e.g. the HOLD ▾ picker) top-aligned under Fluent. -->
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>
  <Style Selector="Button.Dense, ToggleButton.Dense">
    <Setter Property="MinHeight" Value="28" />
    <Setter Property="Padding" Value="8,3" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <!-- Primary action accent (GO, Play) -->
  <!-- Accent buttons set Background for templates that honour it (Classic/Simple) AND the template
       ContentPresenter for templates that don't (Fluent paints its buttons from theme resources, ignoring
       Button.Background) - so Go stays green / Danger stays red across all base themes. The presenter's
       TextElement.Foreground keeps the label + PathIcon white on the accent fill. -->
  <Style Selector="Button.Go">
    <Setter Property="Background" Value="{DynamicResource AccentGo}" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>
  <Style Selector="Button.Go /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AccentGo}" />
    <Setter Property="TextElement.Foreground" Value="White" />
  </Style>
  <Style Selector="Button.Go:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AccentGoHover}" />
  </Style>
  <!-- Panic-path action (Stop) - mirrors Button.Go in the stop/error hue. -->
  <Style Selector="Button.Danger">
    <Setter Property="Background" Value="{DynamicResource StatePanic}" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>
  <Style Selector="Button.Danger /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource StatePanic}" />
    <Setter Property="TextElement.Foreground" Value="White" />
  </Style>
  <Style Selector="Button.Danger:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AccentDanger}" />
  </Style>
  <!-- Engaged warning state (HOLD active) -->
  <Style Selector="ToggleButton.Warn:checked /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AccentWarn}" />
    <Setter Property="TextElement.Foreground" Value="Black" />
  </Style>

  <!-- Disabled Go/Danger (review P3-7): one deliberate treatment across all base themes - keep the
       semantic hue, dim the whole control. Without this Classic showed a disabled Play at FULL
       saturation while Simple/Light washed it to an unreadable pastel; the same state must read the
       same everywhere. -->
  <Style Selector="Button.Go:disabled /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AccentGo}" />
    <Setter Property="TextElement.Foreground" Value="White" />
  </Style>
  <Style Selector="Button.Go:disabled">
    <Setter Property="Opacity" Value="0.55" />
  </Style>
  <Style Selector="Button.Danger:disabled /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource StatePanic}" />
    <Setter Property="TextElement.Foreground" Value="White" />
  </Style>
  <Style Selector="Button.Danger:disabled">
    <Setter Property="Opacity" Value="0.55" />
  </Style>

  <!-- ===== Segmented tab strip (compact drawer tabs, P4) ===== -->
  <Style Selector="TabControl.Segmented /template/ ItemsPresenter#PART_ItemsPresenter">
    <Setter Property="Margin" Value="0" />
  </Style>
  <Style Selector="TabControl.Segmented TabItem">
    <Setter Property="MinHeight" Value="24" />
    <Setter Property="Padding" Value="10,2" />
    <Setter Property="FontSize" Value="12" />
  </Style>
</Styles>
