<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!--
    "Deck" design tokens (UI rewrite P1, Doc/HaPlay-UI-Rewrite-Plan-2026-06-10.md §1).
    The ONLY place spacing, type ramp, surface, accent, and touch-tier values live.
    Views consume the classes/resources below; per-view <UserControl.Styles> color or
    size constants are being removed phase by phase.
  -->

  <Styles.Resources>
    <ResourceDictionary>
      <!-- Spacing scale -->
      <Thickness x:Key="SpaceXS">4</Thickness>
      <Thickness x:Key="SpaceS">8</Thickness>
      <Thickness x:Key="SpaceM">12</Thickness>
      <Thickness x:Key="SpaceL">16</Thickness>
      <Thickness x:Key="SpaceXL">24</Thickness>
      <x:Double x:Key="GapXS">4</x:Double>
      <x:Double x:Key="GapS">8</x:Double>
      <x:Double x:Key="GapM">12</x:Double>
      <x:Double x:Key="GapL">16</x:Double>

      <!-- Surfaces -->
      <SolidColorBrush x:Key="BorderSubtle" Color="#22808080" />
      <SolidColorBrush x:Key="SurfaceRaised" Color="#08808080" />
      <SolidColorBrush x:Key="SurfaceSunken" Color="#10000000" />

      <!-- Accent roles -->
      <SolidColorBrush x:Key="AccentGo" Color="#2E7D32" />
      <SolidColorBrush x:Key="AccentGoHover" Color="#388E3C" />
      <SolidColorBrush x:Key="AccentWarn" Color="#F9A825" />
      <SolidColorBrush x:Key="AccentDanger" Color="#C62828" />
      <SolidColorBrush x:Key="ChipNeutral" Color="#22808080" />

      <!-- Status-line / toast severity foregrounds. Dark shades: these draw on the Classic theme's
           light-gray surfaces (the old light tints came from the dark-Fluent era and read as
           washed-out white there). -->
      <SolidColorBrush x:Key="StatusInfoFg" Color="#37474F" />
      <SolidColorBrush x:Key="StatusWarnFg" Color="#8A5A00" />
      <SolidColorBrush x:Key="StatusErrorFg" Color="#B71C1C" />
    </ResourceDictionary>
  </Styles.Resources>

  <!-- ===== Type ramp ===== -->
  <Style Selector="TextBlock.TitleText">
    <Setter Property="FontSize" Value="22" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>
  <Style Selector="TextBlock.SectionText">
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>
  <Style Selector="TextBlock.BodyText">
    <Setter Property="FontSize" Value="13" />
  </Style>
  <Style Selector="TextBlock.CaptionText">
    <Setter Property="FontSize" Value="11" />
    <Setter Property="Opacity" Value="0.65" />
  </Style>
  <Style Selector="TextBlock.MonoTime">
    <Setter Property="FontFamily" Value="Consolas,monospace" />
    <Setter Property="FontSize" Value="13" />
  </Style>

  <!-- ===== Surfaces ===== (square corners — the Classic theme has no rounded chrome) -->
  <Style Selector="Border.Card">
    <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Padding" Value="{StaticResource SpaceM}" />
    <Setter Property="Background" Value="{StaticResource SurfaceRaised}" />
  </Style>
  <Style Selector="Border.Strip">
    <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}" />
    <Setter Property="BorderThickness" Value="0,1,0,0" />
    <Setter Property="Padding" Value="10,6" />
  </Style>
  <Style Selector="Border.Chip">
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Padding" Value="6,2" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="Background" Value="{StaticResource ChipNeutral}" />
  </Style>

  <!-- ===== Touch tiers =====
       Btn.Touch: panic-path controls only (transport, GO, HOLD, Stop-All). Never shrinks
       with the Density setting. Btn.Std: normal buttons. Btn.Dense: inspector rows. -->
  <Style Selector="Button.Touch, ToggleButton.Touch">
    <Setter Property="MinWidth" Value="56" />
    <Setter Property="MinHeight" Value="56" />
    <Setter Property="FontSize" Value="20" />
    <Setter Property="Padding" Value="14,10" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>
  <Style Selector="Button.Std, ToggleButton.Std">
    <Setter Property="MinHeight" Value="36" />
    <Setter Property="Padding" Value="10,6" />
  </Style>
  <Style Selector="Button.Dense, ToggleButton.Dense">
    <Setter Property="MinHeight" Value="28" />
    <Setter Property="Padding" Value="8,3" />
    <Setter Property="FontSize" Value="12" />
  </Style>

  <!-- Primary action accent (GO, Play) -->
  <Style Selector="Button.Go">
    <Setter Property="Background" Value="{StaticResource AccentGo}" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>
  <Style Selector="Button.Go:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{StaticResource AccentGoHover}" />
  </Style>
  <!-- Engaged warning state (HOLD active) -->
  <Style Selector="ToggleButton.Warn:checked /template/ ContentPresenter">
    <Setter Property="Background" Value="{StaticResource AccentWarn}" />
    <Setter Property="TextElement.Foreground" Value="Black" />
  </Style>

  <!-- ===== Segmented tab strip (compact drawer tabs, P4) ===== -->
  <Style Selector="TabControl.Segmented /template/ ItemsPresenter#PART_ItemsPresenter">
    <Setter Property="Margin" Value="0" />
  </Style>
  <Style Selector="TabControl.Segmented TabItem">
    <Setter Property="MinHeight" Value="24" />
    <Setter Property="Padding" Value="10,2" />
    <Setter Property="FontSize" Value="12" />
  </Style>
</Styles>
