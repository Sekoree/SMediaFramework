<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HaPlay.ViewModels"
             xmlns:views="using:HaPlay.Views"
             x:Class="HaPlay.App"
             RequestedThemeVariant="Default">
  <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

  <Application.DataTemplates>
    <DataTemplate DataType="vm:MediaPlayerViewModel">
      <views:MediaPlayerView />
    </DataTemplate>
  </Application.DataTemplates>

  <Application.Styles>
    <FluentTheme DensityStyle="Compact"/>
    <StyleInclude Source="avares://Avalonia.Controls.TreeDataGrid/Themes/Fluent.axaml"/>
    <!-- Xaml.Behaviors drag-to-reorder: provides the ListBox.draggable style used by the playlist. -->
    <StyleInclude Source="avares://Xaml.Behaviors.Interactions.Draggable/Styles.axaml"/>
    <!-- Drag feedback: the row being dragged dims + lifts above its neighbours. -->
    <Style Selector="ListBox.draggable ListBoxItem:dragging">
      <Setter Property="Opacity" Value="0.6"/>
      <Setter Property="ZIndex" Value="1"/>
    </Style>
    <Style Selector="NumericUpDown">
      <Setter Property="MinWidth" Value="120"/>
    </Style>
    <Style Selector="Expander.dense /template/ ToggleButton#ExpanderHeader">
      <Setter Property="MinHeight" Value="24"/>
      <Setter Property="Padding" Value="6,2"/>
    </Style>
    <Style Selector="Expander.dense">
      <Setter Property="Padding" Value="0"/>
    </Style>
  </Application.Styles>
</Application>
