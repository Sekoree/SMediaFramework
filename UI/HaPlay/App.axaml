<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HaPlay.ViewModels"
             xmlns:views="using:HaPlay.Views"
             xmlns:themes="using:HaPlay.Themes"
             xmlns:common="clr-namespace:Classic.CommonControls;assembly=Classic.CommonControls.Avalonia"
             x:Class="HaPlay.App"
             RequestedThemeVariant="Light">
  <!-- Forced Light: the Classic theme is a light theme. Following the system variant ("Default") made
       every remaining variant-aware resource (AvaloniaEdit, validation, fallbacks) resolve DARK values
       on dark-mode systems — white text on classic light-gray surfaces. -->

  <Application.DataTemplates>
    <DataTemplate DataType="vm:MediaPlayerViewModel">
      <views:MediaPlayerView />
    </DataTemplate>
  </Application.DataTemplates>

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <!-- Classic Win32 system colours (Classic.CommonControls SystemColors.*BrushKey). Kept merged for
             ALL base themes so the app's classic-coloured accents (info banner, soundboard selection,
             PathIcon foreground, the in-app TreeDataGrid theme) still resolve under Simple/Fluent, which
             don't define these keys. Harmlessly duplicates the values the Classic bundle also brings. -->
        <ResourceInclude Source="avares://Classic.Avalonia.Theme/Colors/Colors.axaml"/>
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>

  <Application.Styles>
    <!-- Slot 0: the active base-theme bundle (control theme + its TreeDataGrid + ColorPicker themes).
         Classic is composed here so the app renders correctly at XAML load; AppearanceController swaps this
         slot live (Classic / Simple / Fluent) from the persisted AppBaseTheme. -->
    <themes:ClassicThemeBundle/>
    <!-- UI rewrite P1: the "Deck" design tokens; the single home for spacing/type/surface/touch styles. -->
    <StyleInclude Source="avares://HaPlay/Styles/Tokens.axaml"/>
    <StyleInclude Source="avares://AvaloniaEdit/Themes/Fluent/AvaloniaEdit.xaml"/>
    <!-- Xaml.Behaviors drag-to-reorder: provides the ListBox.draggable style used by the playlist. -->
    <StyleInclude Source="avares://Xaml.Behaviors.Interactions.Draggable/Styles.axaml"/>
    <!-- Drag feedback: the row being dragged dims + lifts above its neighbours. -->
    <Style Selector="ListBox.draggable ListBoxItem:dragging">
      <Setter Property="Opacity" Value="0.6"/>
      <Setter Property="ZIndex" Value="1"/>
    </Style>
    <Style Selector="Expander.dense /template/ ToggleButton#ExpanderHeader">
      <Setter Property="MinHeight" Value="24"/>
      <Setter Property="Padding" Value="6,2"/>
    </Style>
    <Style Selector="Expander.dense">
      <Setter Property="Padding" Value="0"/>
    </Style>
    <!-- NOTE: the AppIcons PathIcon foreground styling is deliberately NOT here — it's pinned to the Classic
         Win32 text colour, which is dark and would vanish on the Simple/Fluent dark variants. It lives in
         ClassicThemeBundle so only Classic applies it; under Simple/Fluent PathIcons inherit the theme's
         (variant-aware) foreground and stay visible in dark mode. -->
  </Application.Styles>
</Application>
